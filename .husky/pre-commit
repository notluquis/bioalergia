#!/bin/sh

if [ -x /usr/libexec/path_helper ]; then
  # Load macOS system PATH for GUI git clients without invoking shells
  eval "$(/usr/libexec/path_helper -s)"
fi
export PATH="/opt/homebrew/bin:$PATH"
export CI="${CI:-true}"

ROOT_DIR="$(git rev-parse --show-toplevel)"
LINT_STAGED_BIN="$ROOT_DIR/node_modules/.bin/lint-staged"

if [ ! -x "$LINT_STAGED_BIN" ]; then
  echo "Skipping lint-staged: missing executable at $LINT_STAGED_BIN" >&2
else
  "$LINT_STAGED_BIN"
fi

if grep -q '"audit:routes"' "$ROOT_DIR/apps/site/package.json"; then
  (cd "$ROOT_DIR/apps/site" && pnpm run audit:routes)
fi
