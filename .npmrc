# pnpm 11 only reads auth + registry settings from .npmrc. All install/
# linker/hoist tunables now live in pnpm-workspace.yaml. Keep this file
# tiny so future debugging doesn't have to guess where a flag came from.

# Optimization for CI/CD
prefer-frozen-lockfile=true
strict-peer-dependencies=false
auto-install-peers=false

# Caching and Fetching
modules-cache-max-age=21600
verify-store-integrity=false

# pnpm 11 prompts before purging node_modules when the layout changes;
# skip it in non-interactive flows (CI, Husky pre-commit, Docker).
confirm-modules-purge=false

# Workspace-state EPERM workaround on macOS pre-commit hook (see commit
# history; harmless on Linux CI).
check-deps-before-run=false
