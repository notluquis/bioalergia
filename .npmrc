# Linker: default `isolated` since pnpm 10.x; pnpm 11 enforces it strictly.
# We keep `shamefully-hoist=true` so all transitive deps are still visible
# at the workspace root node_modules (covers a handful of phantom
# imports like `@orpc/shared` consumed by features without an explicit
# package.json entry). This is the Tailwind/Storybook/Heroui/oRPC compat
# pattern documented in pnpm.io/docs/npmrc#shamefully-hoist.
#
# We do NOT set `node-linker=hoisted`: that triggers the broken
# `_lockfileToHoistedDepGraph` code path on Railway (pnpm 10.33.x) —
# "Cannot use 'in' operator to search for 'directory' in undefined" during
# `pnpm install --frozen-lockfile` (open issues pnpm/pnpm#5890, #5891,
# #6682). The runtime image is caddy:2-alpine serving dist/client/; Caddy
# never sees node_modules so there is no symlink-compat reason to flip
# the linker.
shamefully-hoist=true

# Optimization for CI/CD
prefer-frozen-lockfile=true
strict-peer-dependencies=false
auto-install-peers=false

# Caching and Fetching
modules-cache-max-age=21600
verify-store-integrity=false
# store-dir=/root/.local/share/pnpm/store (Commented out for local parity)

# Skip pnpm workspace state check (avoids EPERM on node_modules/.pnpm-workspace-state-v1.json)
# This check is done before every pnpm command via checkDepsStatus → loadWorkspaceState.
# Disabling it here prevents the pre-commit hook from failing with EPERM on macOS.
check-deps-before-run=false

# pnpm 11 prompts before purging node_modules when the layout (linker, hoist
# pattern, etc.) changes. Skip the prompt in non-interactive flows (CI,
# Husky pre-commit, Docker builds) — the layout transition is expected
# whenever we bump pnpm major.
confirm-modules-purge=false
