    "lint:fix": "oxlint --fix && oxfmt --write ."
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.12.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=26"
  }
