{
  "name": "@finanzas/social-render",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./brand": {
      "types": "./dist/brand.d.mts",
      "import": "./dist/brand.mjs",
      "default": "./dist/brand.mjs"
    }
  },
  "scripts": {
