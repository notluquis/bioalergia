  mimeType              String?                      @map("mime_type")
  size                  Int?
  modifiedAt            DateTime?                    @map("modified_at") @db.Timestamptz(3)
  documentKind          ClinicalDocumentImportKind   @default(OTHER) @map("document_kind")
  status                ClinicalDocumentImportStatus @default(DISCOVERED)
