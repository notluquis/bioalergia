model ClinicalAllergen {
  id                       String                  @id
  scientificName           String?                 @map("scientific_name")
  commonName               String                  @map("common_name")
  englishName              String?                 @map("english_name")
  category                 String
  categoryEn               String?                 @map("category_en")
  pollenType               String?                 @map("pollen_type")
  pollenTypeEn             String?                 @map("pollen_type_en")
  normalizedScientificName String?                 @map("normalized_scientific_name")
  normalizedCommonName     String                  @map("normalized_common_name")
  source                   String                  @default("lista_alergenos.xlsx")
  sourceRow                Int?                    @map("source_row")
  isActive                 Boolean                 @default(true) @map("is_active")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at")

  aliases                  ClinicalAllergenAlias[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([category])
  @@index([pollenType])
  @@index([normalizedCommonName])
  @@map("clinical_allergens")
}

model ClinicalAllergenAlias {
  id              String           @id
  allergenId      String           @map("allergen_id")
  alias           String
  normalizedAlias String           @map("normalized_alias")
  aliasType       String           @default("SOURCE") @map("alias_type")
  createdAt       DateTime         @default(now()) @map("created_at")

  allergen        ClinicalAllergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([normalizedAlias])
  @@index([allergenId])
  @@index([aliasType])
  @@map("clinical_allergen_aliases")
}

model ClinicalSkinTest {
  id               String                 @id @default(cuid())
  clinicalSeriesId Int                    @map("clinical_series_id")
  sourceImportId   String                 @unique @map("source_import_id")
  testDate         DateTime               @map("test_date") @db.Date
  patientName      String?                @map("patient_name")
  patientRut       String?                @map("patient_rut")
  patientEmail     String?                @map("patient_email")
  patientPhone     String?                @map("patient_phone")
  ageLabel         String?                @map("age_label")
  panelTitle       String?                @map("panel_title")
  clinicalNote     String?                @map("clinical_note")
  physicianName    String?                @map("physician_name")
  physicianSpecialty String?              @map("physician_specialty")
  website          String?
  address          String?
  nonConclusiveDueToHyperreactivity Boolean @default(false) @map("non_conclusive_due_to_hyperreactivity")
  resultHash       String?                @map("result_hash")
  rawHeader        Json?                  @map("raw_header")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at")

  clinicalSeries   ClinicalSeries         @relation(fields: [clinicalSeriesId], references: [id], onDelete: Cascade)
  sourceImport     ClinicalSkinTestImport @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)
  results          ClinicalSkinTestResult[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([clinicalSeriesId])
  @@index([patientRut])
  @@index([testDate])
  @@index([resultHash])
  @@map("clinical_skin_tests")
}

model ClinicalSkinTestResult {
  id             String                       @id @default(cuid())
  skinTestId     String                       @map("skin_test_id")
  sourceImportId String                       @map("source_import_id")
  section        String
  code           String?
  allergenName   String                       @map("allergen_name")
  papuleMm       Float?                       @map("papule_mm")
  erythemaMm     Float?                       @map("erythema_mm")
  rawPapule      String?                      @map("raw_papule")
  rawErythema    String?                      @map("raw_erythema")
  controlType    ClinicalSkinTestControlType? @map("control_type")
  sortOrder      Int                          @map("sort_order")
  rawCells       Json?                        @map("raw_cells")

  skinTest       ClinicalSkinTest             @relation(fields: [skinTestId], references: [id], onDelete: Cascade)
  sourceImport   ClinicalSkinTestImport       @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([sourceImportId, section, code, allergenName])
  @@index([skinTestId])
  @@map("clinical_skin_test_results")
}

model ClinicalSeriesMergeLog {
  id          BigInt         @id @default(autoincrement())
  sourceId    Int            @map("source_id")
  targetId    Int            @map("target_id")
