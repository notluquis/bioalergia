  mergedBy    Int?           @map("merged_by")
  mergeReason String?        @map("merge_reason")
  isAuto      Boolean        @default(false) @map("is_auto")
  createdAt   DateTime       @default(now()) @map("created_at")
  target      ClinicalSeries @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create', auth().status == 'ACTIVE')

  @@index([targetId])
  @@index([sourceId])
  @@map("clinical_series_merge_log")
}

model AbandonmentContact {
