  seriesId         Int                       @map("series_id")
  outcome          AbandonmentContactOutcome
  notes            String?
  contactedById    Int                       @map("contacted_by_id")
  contactedAt      DateTime                  @default(now()) @map("contacted_at")

  series           ClinicalSeries            @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  contactedBy      User                      @relation(fields: [contactedById], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create', auth().status == 'ACTIVE')

  @@index([seriesId])
  @@map("abandonment_contacts")
