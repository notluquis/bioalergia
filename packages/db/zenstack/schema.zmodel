model ClinicalAllergen {
  id                       String                  @id
  scientificName           String?                 @map("scientific_name")
  commonName               String                  @map("common_name")
  englishName              String?                 @map("english_name")
  category                 String
  categoryEn               String?                 @map("category_en")
  pollenType               String?                 @map("pollen_type")
  pollenTypeEn             String?                 @map("pollen_type_en")
  normalizedScientificName String?                 @map("normalized_scientific_name")
  normalizedCommonName     String                  @map("normalized_common_name")
  source                   String                  @default("lista_alergenos.xlsx")
  sourceRow                Int?                    @map("source_row")
  // Free-form tag list. Used by the exam-report PDF generator to detect
  // cross-reactive components (PR-10, profilin, tropomyosin, LTP) and
  // append the EAACI cross-reactivity disclaimer. Lower-cased on write.
  tags                     String[]                @default([])
  isActive                 Boolean                 @default(true) @map("is_active")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @default(now()) @updatedAt @map("updated_at")

  aliases                  ClinicalAllergenAlias[]
  examReportReactions      ExamReportReaction[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([category])
  @@index([pollenType])
  @@index([normalizedCommonName])
  @@map("clinical_allergens")
}

