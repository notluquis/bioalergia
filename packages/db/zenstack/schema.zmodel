  sortOrder      Int                          @map("sort_order")
  rawCells       Json?                        @map("raw_cells")

  skinTest       ClinicalSkinTest             @relation(fields: [skinTestId], references: [id], onDelete: Cascade)
  sourceImport   ClinicalSkinTestImport       @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([sourceImportId, section, code, allergenName])
  @@index([skinTestId])
  @@map("clinical_skin_test_results")
}

