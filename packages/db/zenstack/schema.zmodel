  @@allow('read', true)
  @@allow('update', auth().status == 'ACTIVE')

  @@map("settings")
}

// Append-only audit trail for security-relevant events: login attempts
// (success/fail), MFA verification, password change, role grant/revoke,
// data export, admin actions, blocked contacts, etc.
//
// Retention target: 2 years (Chile Law 20.584 + HIPAA-equivalent). The
// table is queried for forensics + compliance reporting; never updated
// after insert. PII (email, IP) is captured intentionally — this is the
// authoritative incident-response record.
// Web Push preview-content gate. Drives the visible payload an
// operator sees on a lock screen / notification tray:
//   GENERIC      = "Bioalergia · Mensajes nuevos" (no PHI)
//   SENDER_NAME  = sender name visible, no body
//   FULL         = sender + body preview (legacy behaviour)
// Default GENERIC matches the indigitall/HIPAA 2026 recommendation
// that PHI never appears in the visible push payload.
enum WaPushPreviewMode {
  GENERIC
  SENDER_NAME
  FULL
}

enum AuditEventKind {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGIN_LOCKED
  MFA_SUCCESS
  MFA_FAILURE
  PASSWORD_CHANGE
  PASSWORD_RESET
  MFA_ENROLL
  MFA_DISABLE
  PASSKEY_REGISTER
  PASSKEY_DELETE
  ROLE_GRANT
  ROLE_REVOKE
  USER_CREATE
  USER_DEACTIVATE
  USER_REACTIVATE
  DATA_EXPORT
  ADMIN_ACTION
  WA_CONTACT_BLOCK
  WA_CONTACT_UNBLOCK
  SETTINGS_UPDATE
  DATA_UPDATE
  APPOINTMENT_CHANGE
  IMPORT_UPSERT
  FINANCIAL_CHANGE
  OTHER
}

// Mutable dedupe state for security alert throttling. Keyed by
// (scope, alertType) — typically scope = "user:<id>" or "global".
// last_sent_at is updated by lib/security-alerts.ts each time an
// alert is emitted; emissions inside the throttle window are dropped
// (the underlying event still lands in audit_logs).
model SecurityAlertState {
  scope      String   @map("scope")
  alertType  String   @map("alert_type")
  lastSentAt DateTime @map("last_sent_at")

  @@id([scope, alertType])
  @@index([lastSentAt])
  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update', auth().status == 'ACTIVE')
  @@map("security_alert_state")
}

model AuditLog {
  id          BigInt          @id @default(autoincrement())
  occurredAt  DateTime        @default(now()) @map("occurred_at")
  kind        AuditEventKind
  // Null for unauthenticated events (failed logins where the email
  // doesn't match a known user).
  userId      Int?            @map("user_id")
  // Free-form actor description when userId is unavailable
  // (e.g. "anonymous" for failed logins from unknown emails).
  actorLabel  String?         @map("actor_label")
  ip          String?
  userAgent   String?         @map("user_agent")
  resource    String?
  resourceId  String?         @map("resource_id")
  outcome     String          @default("ok")
  message     String?
  metadata    Json?
  // HMAC chain (RFC 6962-style append-only). prevHash links to the
  // previous row's entryHash; entryHash = HMAC-SHA256(key, prev || row).
  // Computed by the BEFORE INSERT trigger `audit_log_chain()` so the
  // app role cannot forge entries even with INSERT privileges. The
  // trigger reads the HMAC key from the session GUC `app.audit_hmac_key`
  // (set per pool connection from AUDIT_HMAC_KEY env). NEVER write
  // these from application code — leave them undefined on insert.
  // `@default(dbgenerated(...))` makes the ORM input type accept
  // omission while the DB keeps the column NOT NULL: the trigger
  // overrides the literal default before the constraint check.
  prevHash    Bytes           @default(dbgenerated("decode('00', 'hex')")) @map("prev_hash")
  entryHash   Bytes           @default(dbgenerated("decode('00', 'hex')")) @map("entry_hash")

  @@index([occurredAt])
  @@index([userId, occurredAt])
  @@index([kind, occurredAt])
  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  // create allowed for any authed user — emitter is server-side, this
  // permits the server context to insert. update/delete denied (append-only).
  @@allow('create', auth().status == 'ACTIVE')
  @@map("audit_logs")
}

model OneDriveAccount {
  id              String    @id @default(cuid())
  accountId       String    @unique @map("account_id") // Microsoft Account ID
