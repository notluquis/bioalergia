  id                    String                       @id @default(cuid())
  oneDriveAccountId     String?                      @map("onedrive_account_id")
  oneDriveItemId        String                       @map("onedrive_item_id")
  oneDriveDriveId       String?                      @map("onedrive_drive_id")
  oneDriveSourceKey     String?                      @map("onedrive_source_key")
  oneDriveSourceDriveId String?                      @map("onedrive_source_drive_id")
  oneDriveSourceItemId  String?                      @map("onedrive_source_item_id")
  oneDriveSharePointUniqueId String?                 @map("onedrive_sharepoint_unique_id")
  oneDriveQuickXorHash  String?                      @map("onedrive_quick_xor_hash")
  oneDriveSha1Hash      String?                      @map("onedrive_sha1_hash")
  oneDriveCrc32Hash     String?                      @map("onedrive_crc32_hash")
  oneDriveETag          String?                      @map("onedrive_etag")
  oneDriveCTag          String?                      @map("onedrive_ctag")
  oneDriveWebUrl        String?                      @map("onedrive_web_url")
  path                  String?
  filename              String
  mimeType              String?                      @map("mime_type")
  size                  Int?
  modifiedAt            DateTime?                    @map("modified_at") @db.Timestamptz(3)
  classification        ClinicalXlsxFileClassification @default(OTHER)
  classificationReason  String?                      @map("classification_reason")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @default(now()) @updatedAt @map("updated_at")

  oneDriveAccount       OneDriveAccount?             @relation(fields: [oneDriveAccountId], references: [accountId], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([classification])
  @@index([modifiedAt])
  @@index([oneDriveAccountId])
  @@index([oneDriveSourceKey])
  @@unique([oneDriveAccountId, oneDriveDriveId, oneDriveItemId])
  @@map("clinical_xlsx_files")
}

model ClinicalSkinTestImport {
  id                    String                    @id @default(cuid())
  oneDriveAccountId     String?                   @map("onedrive_account_id")
  oneDriveItemId        String                    @map("onedrive_item_id")
  oneDriveDriveId       String?                   @map("onedrive_drive_id")
  oneDriveSourceKey     String?                   @map("onedrive_source_key")
  oneDriveSourceDriveId String?                   @map("onedrive_source_drive_id")
  oneDriveSourceItemId  String?                   @map("onedrive_source_item_id")
  oneDriveSharePointUniqueId String?              @map("onedrive_sharepoint_unique_id")
  oneDriveQuickXorHash  String?                   @map("onedrive_quick_xor_hash")
  oneDriveSha1Hash      String?                   @map("onedrive_sha1_hash")
  oneDriveCrc32Hash     String?                   @map("onedrive_crc32_hash")
  oneDriveETag          String?                   @map("onedrive_etag")
  oneDriveCTag          String?                   @map("onedrive_ctag")
  oneDriveWebUrl        String?                   @map("onedrive_web_url")
  path                  String?
  filename              String
  mimeType              String?                   @map("mime_type")
  size                  Int?
  modifiedAt            DateTime?                 @map("modified_at") @db.Timestamptz(3)
  parserVersion         String                    @map("parser_version")
  status                ClinicalSkinTestImportStatus @default(PENDING_REVIEW)
  confidence            Int                       @default(0)
  error                 String?
  issues                Json?
  parsedPayload         Json?                     @map("parsed_payload")
  resultHash            String?                   @map("result_hash")
  duplicateOfImportId   String?                   @map("duplicate_of_import_id")
  workbookSnapshotStatus ClinicalSkinTestWorkbookSnapshotStatus @default(MISSING) @map("workbook_snapshot_status")
  workbookSnapshotError  String?                   @map("workbook_snapshot_error")
  workbookSnapshotArchivedAt DateTime?             @map("workbook_snapshot_archived_at") @db.Timestamptz(3)
  reviewedBy            Int?                      @map("reviewed_by")
  reviewedAt            DateTime?                 @map("reviewed_at") @db.Timestamptz(3)
  reviewNotes           String?                   @map("review_notes")
  importedAt            DateTime?                 @map("imported_at") @db.Timestamptz(3)
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at")

  skinTest              ClinicalSkinTest?
  results               ClinicalSkinTestResult[]
  workbookSnapshot      ClinicalSkinTestWorkbookSnapshot?
  oneDriveAccount       OneDriveAccount?          @relation(fields: [oneDriveAccountId], references: [accountId], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([status])
  @@index([modifiedAt])
  @@index([oneDriveAccountId])
  @@index([oneDriveSourceKey])
  @@index([workbookSnapshotStatus])
  @@unique([oneDriveAccountId, oneDriveDriveId, oneDriveItemId])
  @@map("clinical_skin_test_imports")
}

// ----------------------------------------------------------------------
// Clinical records (fichas clínicas) — see docs/clinical-records.md
// (TBD) and migration 20260512030001_clinical_records.
//
// Pipeline mirrors ClinicalSkinTestImport: OneDrive scanner discovers
// xlsx files matching the ficha-clínica filename pattern (no _PRICK /
// _MULTITEST prefix), enqueues them in clinical_record_imports with
// status PENDING_REVIEW, the parser populates parsed_payload, then a
// matcher resolves to an existing patient (or queues candidates for
// operator decision) and materializes a ClinicalRecord under a
// ClinicalSeries with kind = MEDICAL_CONSULTATION.
// ----------------------------------------------------------------------

model ClinicalRecordImport {
  id                          String                       @id @default(cuid())
  oneDriveAccountId           String?                      @map("onedrive_account_id")
  oneDriveItemId              String                       @map("onedrive_item_id")
  oneDriveDriveId             String?                      @map("onedrive_drive_id")
  oneDriveSourceKey           String?                      @map("onedrive_source_key")
  oneDriveSourceDriveId       String?                      @map("onedrive_source_drive_id")
  oneDriveSourceItemId        String?                      @map("onedrive_source_item_id")
  oneDriveSharePointUniqueId  String?                      @map("onedrive_sharepoint_unique_id")
  oneDriveQuickXorHash        String?                      @map("onedrive_quick_xor_hash")
  oneDriveSha1Hash            String?                      @map("onedrive_sha1_hash")
  oneDriveCrc32Hash           String?                      @map("onedrive_crc32_hash")
  oneDriveETag                String?                      @map("onedrive_etag")
  oneDriveCTag                String?                      @map("onedrive_ctag")
  oneDriveWebUrl              String?                      @map("onedrive_web_url")
  path                        String?
  filename                    String
  mimeType                    String?                      @map("mime_type")
  size                        Int?
  modifiedAt                  DateTime?                    @map("modified_at") @db.Timestamptz(3)
  parserVersion               String                       @map("parser_version")
  status                      ClinicalRecordImportStatus   @default(PENDING_REVIEW)
  confidence                  Int                          @default(0)
  error                       String?
  issues                      Json?
  parsedPayload               Json?                        @map("parsed_payload")
  resultHash                  String?                      @map("result_hash")
  duplicateOfImportId         String?                      @map("duplicate_of_import_id")
  matchedPatientId            Int?                         @map("matched_patient_id")
  matchedClinicalSeriesId     Int?                         @map("matched_clinical_series_id")
  matchCandidates             Json?                        @map("match_candidates")
  reviewedBy                  Int?                         @map("reviewed_by")
  reviewedAt                  DateTime?                    @map("reviewed_at") @db.Timestamptz(3)
  reviewNotes                 String?                      @map("review_notes")
  importedAt                  DateTime?                    @map("imported_at") @db.Timestamptz(3)
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @default(now()) @updatedAt @map("updated_at")

  record                      ClinicalRecord?
  oneDriveAccount             OneDriveAccount?             @relation(fields: [oneDriveAccountId], references: [accountId], onDelete: SetNull)
  matchedPatient              Patient?                     @relation(fields: [matchedPatientId], references: [id], onDelete: SetNull)
  matchedClinicalSeries       ClinicalSeries?              @relation(fields: [matchedClinicalSeriesId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([status])
  @@index([modifiedAt])
  @@index([oneDriveAccountId])
  @@index([matchedPatientId])
  @@unique([oneDriveAccountId, oneDriveDriveId, oneDriveItemId])
  @@map("clinical_record_imports")
}

model ClinicalRecord {
  id                  String              @id @default(cuid())
  clinicalSeriesId    Int                 @map("clinical_series_id")
  sourceImportId      String              @unique @map("source_import_id")
  consultDate         DateTime?           @map("consult_date") @db.Date
  patientName         String?             @map("patient_name")
  ageLabel            String?             @map("age_label")
  history             String?
  physicalExam        String?             @map("physical_exam")
  diagnosis           String?
  // Numbered list 1..n preserved as JSON array of strings.
  indications         Json?
  weightKg            Decimal?            @map("weight_kg") @db.Decimal(6, 2)
  heightCm            Decimal?            @map("height_cm") @db.Decimal(6, 2)
  headCircumferenceCm Decimal?            @map("head_circumference_cm") @db.Decimal(6, 2)
  // P/E, P/T, T/E and any extra anthropometric labels.
  anthropometric      Json?
  // FHIR-mappable extras (HL7 FHIR R5 + IPS-CL Chile R4). Stored as
  // JSONB for the list-shaped fields so v1 can persist free-text
  // string arrays from the xlsx and v2 can upgrade to structured
  // objects ({condition,onset,…} / {name,dose,frequency,…} /
  // {substance,severity,…}) without a column reshape.
  //
  //   antecedents:    { personal: string[], family: string[] }
  //                   → FHIR Condition + FamilyMemberHistory
  //   medications:    string[]
  //                   → FHIR MedicationStatement
  //   knownAllergies: string[]
  //                   → FHIR AllergyIntolerance
  //   observations:   free-text narrative (Composition.section.text)
  antecedents         Json?               @map("antecedents")
  medications         Json?               @map("medications")
  knownAllergies      Json?               @map("known_allergies")
  observations        String?
  rawHeader           Json?               @map("raw_header")
  rawSections         Json?               @map("raw_sections")
  resultHash          String?             @map("result_hash")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")

  clinicalSeries      ClinicalSeries      @relation(fields: [clinicalSeriesId], references: [id], onDelete: Cascade)
  sourceImport        ClinicalRecordImport @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([clinicalSeriesId])
  @@index([consultDate])
  @@map("clinical_records")
}

model ClinicalSkinTestWorkbookFile {
  id               String                 @id @default(cuid())
  extractorVersion String                 @map("extractor_version")
  sha256           String
  sizeBytes        Int?                   @map("size_bytes")
  sheetName        String                 @map("sheet_name")
  cellCount        Int                    @default(0) @map("cell_count")
  mergeCount       Int                    @default(0) @map("merge_count")
  textHash         String                 @map("text_hash")
  snapshotJson     Json                   @map("snapshot_json")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at")

  snapshots        ClinicalSkinTestWorkbookSnapshot[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([sha256, extractorVersion])
  @@index([sha256])
  @@index([textHash])
  @@index([createdAt])
  @@map("clinical_skin_test_workbook_files")
}

model ClinicalSkinTestWorkbookSnapshot {
  id               String                 @id @default(cuid())
  sourceImportId   String                 @unique @map("source_import_id")
  workbookFileId   String                 @map("workbook_file_id")
  sourceETag       String?                @map("source_etag")
  sourceCTag       String?                @map("source_ctag")
  status           ClinicalSkinTestWorkbookSnapshotStatus @default(ARCHIVED)
  error            String?
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at")

  sourceImport     ClinicalSkinTestImport @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)
  workbookFile     ClinicalSkinTestWorkbookFile @relation(fields: [workbookFileId], references: [id], onDelete: Restrict)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([workbookFileId])
  @@index([status])
  @@index([createdAt])
  @@map("clinical_skin_test_workbook_snapshots")
}

model ClinicalDocumentImport {
  id                    String                       @id @default(cuid())
  oneDriveAccountId     String?                      @map("onedrive_account_id")
  oneDriveItemId        String                       @map("onedrive_item_id")
