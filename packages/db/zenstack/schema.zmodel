model CalendarSyncLog {
  id            Int                    @id @default(autoincrement())
  triggerSource String?                @map("trigger_source")
  triggerUserId Int?                   @map("trigger_user_id")
  triggerLabel  String?                @map("trigger_label")
  status        String                 @default("PENDING")
  startedAt     DateTime               @default(now()) @map("started_at")
  endedAt       DateTime?              @map("ended_at")
  fetchedAt     DateTime?              @map("fetched_at")
  eventsSynced  Int                    @default(0) @map("events_synced")
  inserted      Int?                   @default(0)
  updated       Int?                   @default(0)
  skipped       Int?                   @default(0)
  excluded      Int?                   @default(0)
  errorMessage  String?                @map("error_message")
  changeDetails Json?                  @map("change_details")
  logEntries    CalendarSyncLogEntry[]

  @@index([startedAt(sort: Desc)])
  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)

  @@map("calendar_sync_logs")
}

model CalendarSyncLogEntry {
  id         Int             @id @default(autoincrement())
  syncLogId  Int             @map("sync_log_id")
  message    String?
  severity   String          @default("info") // info, warning, error
  attributes Json?              // {level, custom_fields}
  tags       Json?              // {project, environment, service, deployment, replica, tag}
  timestamp  DateTime        @default(now())
  createdAt  DateTime        @default(now()) @map("created_at")

  syncLog    CalendarSyncLog @relation(fields: [syncLogId], references: [id], onDelete: Cascade)

  @@index([syncLogId])
  @@index([timestamp(sort: Desc)])
  @@index([severity])
  
  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)

  @@map("calendar_sync_log_entries")
}

// ============================================================
// DOCTORALIA INTEGRATION
// ============================================================

model DoctoraliaSyncLog {
  id             Int                   @id @default(autoincrement())
  syncType       DoctoraliaSyncType    @default(CALENDAR) @map("sync_type")
  triggerSource  String?               @map("trigger_source")
  triggerUserId  Int?                  @map("trigger_user_id")
  status         String                @default("PENDING")
  startedAt      DateTime              @default(now()) @map("started_at") @db.Timestamptz(3)
  endedAt        DateTime?             @map("ended_at") @db.Timestamptz(3)
  counts         Json                  @default("{}")
  errorMessage   String?               @map("error_message")

  @@index([startedAt(sort: Desc)])
  @@index([syncType])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)

  @@map("doctoralia_sync_logs")
}

enum DoctoraliaSyncType {
  CALENDAR
  EMAIL
}

// ============================================================
// DOCTORALIA CALENDAR (Docplanner Calendar API)
// ============================================================

model DoctoraliaSchedule {
  id                       Int                             @id @default(autoincrement())
  externalId               Int                             @unique @map("external_id")
  name                     String
  displayName              String                          @map("display_name")
  facilityId               Int?                            @map("facility_id")
  specialityId             Int?                            @map("speciality_id")
  doctorId                 Int?                            @map("doctor_id")
  provinceId               Int?                            @map("province_id")
  cityId                   Int?                            @map("city_id")
  hasWaitingRoom           Boolean?                        @map("has_waiting_room")
  scheduleType             Int                             @default(0) @map("schedule_type")
  colorSchemaId            Int?                            @map("color_schema_id")
  isVirtual                Boolean                         @default(false) @map("is_virtual")
  patientsNotificationType Int                             @default(1) @map("patients_notification_type")
  createdAt                DateTime                        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime                        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  appointments             DoctoraliaCalendarAppointment[]
  workPeriods              DoctoraliaWorkPeriod[]

  @@index([externalId])
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("doctoralia_schedules")
}

model DoctoraliaCalendarAppointment {
  id                         Int                @id @default(autoincrement())
  scheduleId                 Int                @map("schedule_id")
  externalId                 Int                @unique @map("external_id")
  title                      String
  startAt                    DateTime           @map("start_at") @db.Timestamptz(3)
  endAt                      DateTime           @map("end_at") @db.Timestamptz(3)
  isBlock                    Boolean            @default(false) @map("is_block")
  eventType                  Int                @map("event_type")
  scheduledBy                Int                @map("scheduled_by")
  status                     Int
  hasPatient                 Boolean            @map("has_patient")
  hasWaitingRoom             Boolean?           @map("has_waiting_room")
  insuranceId                Int?               @map("insurance_id")
  insuranceName              String?            @map("insurance_name")
  comments                   String?
  serviceId                  Int                @map("service_id")
  serviceName                String             @map("service_name")
  eventServices              Json?              @map("event_services")
  serviceColorSchemaId       Int                @map("service_color_schema_id")
  colorSchemaId              Int?               @map("color_schema_id")
  serviceIsDeleted           Boolean            @default(false) @map("service_is_deleted")
  attendance                 Int                @default(0)
  patientExternalId          Int                @map("patient_external_id")
  patientReferenceId         String             @map("patient_reference_id")
  patientPhone               String?            @map("patient_phone")
  patientEmail               String?            @map("patient_email")
  patientBirthDate           DateTime?          @map("patient_birth_date")
  patientArrivalTime         DateTime?          @map("patient_arrival_time") @db.Timestamptz(3)
  isPatientFirstTime         Boolean            @default(false) @map("is_patient_first_time")
  isPatientFirstAdminBooking Boolean            @default(false) @map("is_patient_first_admin_booking")
  isBookedViaSecretaryAi     Boolean            @default(false) @map("is_booked_via_secretary_ai")
  onlinePaymentType          String?            @map("online_payment_type")
  onlinePaymentStatus        String?            @map("online_payment_status")
  isPaidOnline               Boolean            @default(false) @map("is_paid_online")
  communicationChannel       String?            @map("communication_channel")
  fake                       Boolean            @default(false)
  isEventWithVoucher         Boolean            @default(false) @map("is_event_with_voucher")
  duration                   Int
  canNotifyPatient           Boolean            @map("can_notify_patient")
  noShowProtection           Boolean            @default(false) @map("no_show_protection")
  createdAt                  DateTime                     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                  DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  schedule                   DoctoraliaSchedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  emailNotifications         DoctoraliaEmailNotification[]

  @@unique([scheduleId, externalId])
  @@index([scheduleId])
  @@index([startAt])
  @@index([patientExternalId])
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("doctoralia_calendar_appointments")
}

model DoctoraliaWorkPeriod {
  id         Int                @id @default(autoincrement())
  scheduleId Int                @map("schedule_id")
  startAt    DateTime           @map("start_at") @db.Timestamptz(3)
  endAt      DateTime           @map("end_at") @db.Timestamptz(3)
  isPrivate  Boolean            @default(false) @map("is_private")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  schedule   DoctoraliaSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([startAt])
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("doctoralia_work_periods")
}

// ============================================================
// HAULMER INTEGRATION
// ============================================================

model HaulmerSyncLog {
  id           String   @id @default(uuid())
  period       String   @db.VarChar(6)                        // YYYYMM format (e.g., "202602")
  rut          String   @db.VarChar(20)                       // Haulmer RUT
  docType      String   @map("doc_type") @db.VarChar(20)      // "sales" | "purchases"
  status       String   @default("PENDING") @db.VarChar(20)   // PENDING | SUCCESS | FAILED
  rowsCreated  Int      @default(0) @map("rows_created")
  rowsUpdated  Int      @default(0) @map("rows_updated")
  rowsSkipped  Int      @default(0) @map("rows_skipped")
  csvSize      Int?     @map("csv_size")                      // Size of CSV file in bytes
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([period])
  @@index([rut])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@unique([period, rut, docType])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)

  @@map("haulmer_sync_logs")
}

// ============================================================
// DOCTORALIA EMAIL NOTIFICATIONS
// ============================================================

model DoctoraliaEmailNotification {
  id                      String                         @id @default(cuid())
  emailMessageId          String                         @unique @map("email_message_id")
  eventType               DoctoraliaEmailEventType       @default(BOOKING) @map("event_type")
  patientName             String                         @map("patient_name")
  patientPhone            String?                        @map("patient_phone")
  patientEmail            String?                        @map("patient_email")
  appointmentDate         DateTime?                      @map("appointment_date") @db.Timestamptz(3)
  previousAppointmentDate DateTime?                      @map("previous_appointment_date") @db.Timestamptz(3)
  appointmentService      String?                        @map("appointment_service")
  appointmentDoctor       String?                        @map("appointment_doctor")
  clinicAddress           String?                        @map("clinic_address")
  calendarAppointmentId   Int?                           @map("calendar_appointment_id")
  createdAt               DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  calendarAppointment     DoctoraliaCalendarAppointment? @relation(fields: [calendarAppointmentId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([eventType])
  @@index([calendarAppointmentId])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("doctoralia_email_notifications")
}

enum DoctoraliaEmailEventType {
  BOOKING
  MODIFICATION
  CANCELLATION
}

// Singleton (one row, label="default") storing the raw Doctoralia panel session
// cookies pasted from the user's browser. The scraper reads from here via a
// bearer-token API so we never check credentials into disk/git. Schema-level
// policies only permit authenticated reads — raw cookies never leave the API
// to the browser (the oRPC layer exposes metadata only).
model DoctoraliaCookieStore {
  id              Int       @id @default(autoincrement())
  label           String    @unique @default("default")
  cookiesJson     Json      @map("cookies_json")
  lastUsedAt      DateTime? @map("last_used_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  updatedByUserId Int?      @map("updated_by_user_id")
  updatedBy       User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read,create,update', auth().status == 'ACTIVE')

  @@map("doctoralia_cookie_store")
}

// ============================================================
// WHATSAPP INTEGRATION
// ============================================================

model WhatsappNotification {
  id                 String                       @id @default(cuid())
  patientName        String                       @map("patient_name")
  patientPhone       String                       @map("patient_phone")
  patientEmail       String?                      @map("patient_email")
  appointmentDate    DateTime?                    @map("appointment_date")
  appointmentService String?                      @map("appointment_service")
  appointmentDoctor  String?                      @map("appointment_doctor")
  emailMessageId     String                       @unique @map("email_message_id")
  waMessageId        String?                      @map("wa_message_id")
  recipientWaId      String?                      @map("recipient_wa_id")
  messagePacingStatus String?                     @map("message_pacing_status")
  status             WhatsappNotificationStatus   @default(PENDING)
  errorMessage       String?                      @map("error_message")
  sentAt             DateTime?                    @map("sent_at")
  deliveredAt        DateTime?                    @map("delivered_at")
  readAt             DateTime?                    @map("read_at")
  playedAt           DateTime?                    @map("played_at")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @default(now()) @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_notifications")
}

model WhatsappConversationState {
  phone                String    @id
  waId                 String?   @map("wa_id")
  lastInboundMessageId String?   @map("last_inbound_message_id")
  lastInboundAt        DateTime? @map("last_inbound_at")
  lastInboundText      String?   @map("last_inbound_text")
  lastInboundCallId    String?   @map("last_inbound_call_id")
  lastInboundCallAt    DateTime? @map("last_inbound_call_at")
  optInStatus          WhatsappOptInStatus @default(UNKNOWN) @map("opt_in_status")
  optedInAt            DateTime? @map("opted_in_at")
  optedOutAt           DateTime? @map("opted_out_at")
  optInSource          String?   @map("opt_in_source")
  conversationId       String?   @map("conversation_id")
  conversationOriginType String? @map("conversation_origin_type")
  conversationExpiresAt DateTime? @map("conversation_expires_at")
  windowExpiresAt      DateTime? @map("window_expires_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([windowExpiresAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_conversation_state")
}

model WhatsappMessage {
  id            String                   @id @default(cuid())
  remoteJid     String                   @map("remote_jid")
  messageId     String                   @map("message_id")
  participantJid String?                 @map("participant_jid")
  participantJidKey String               @default("") @map("participant_jid_key")
  fromMe        Boolean                  @default(false) @map("from_me")
  direction     WhatsappMessageDirection
  messageType   String                   @map("message_type")
  status        WhatsappMessageStatus    @default(PENDING)
  phone         String?
  waId          String?                  @map("wa_id")
  textPreview   String?                  @map("text_preview")
  sentAt        DateTime?                @map("sent_at")
  deliveredAt   DateTime?                @map("delivered_at")
  readAt        DateTime?                @map("read_at")
  playedAt      DateTime?                @map("played_at")
  messageTimestamp DateTime?             @map("message_timestamp")
  deletedForEveryone Boolean             @default(false) @map("deleted_for_everyone")
  deletedForMe  Boolean                  @default(false) @map("deleted_for_me")
  starred       Boolean                  @default(false)
  hasMedia      Boolean                  @default(false) @map("has_media")
  mediaMissing  Boolean                  @default(false) @map("media_missing")
  rawMessageJson Json?                   @map("raw_message_json")
  rawContentJson Json?                   @map("raw_content_json")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @default(now()) @updatedAt @map("updated_at")

  @@unique([remoteJid, messageId, participantJidKey])
  @@index([phone, createdAt(sort: Desc)])
  @@index([remoteJid, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_messages")
}

model WhatsappChat {
  id             String     @id @default(cuid())
  jid            String     @unique
  name           String?
  conversationTimestamp DateTime? @map("conversation_timestamp")
  unreadCount    Int?       @map("unread_count")
  archived       Boolean?   @default(false)
  pinned         Boolean?   @default(false)
  muteEndTime    DateTime?  @map("mute_end_time")
  notSpam        Boolean?   @map("not_spam")
  lastMessageId  String?    @map("last_message_id")
  lastMessagePreview String? @map("last_message_preview")
  profilePictureUrl String?  @map("profile_picture_url")
  ephemeralExpiration Int?   @map("ephemeral_expiration")
  isBlocked      Boolean?    @default(false) @map("is_blocked")
  isGroup        Boolean?    @default(false) @map("is_group")
  rawChatJson    Json?      @map("raw_chat_json")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @default(now()) @updatedAt @map("updated_at")

  @@index([conversationTimestamp(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_chats")
}

model WhatsappContact {
  id             String   @id @default(cuid())
  jid            String   @unique
  phone          String?
  name           String?
  notify         String?
  verifiedName   String?  @map("verified_name")
  imgUrl         String?  @map("img_url")
  rawContactJson Json?    @map("raw_contact_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([phone])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_contacts")
}

model WhatsappMessageReaction {
  remoteJid   String   @map("remote_jid")
  messageId   String   @map("message_id")
  actorJid    String   @map("actor_jid")
  emoji       String
  removed     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([remoteJid, messageId, actorJid, emoji])
  @@index([remoteJid, messageId, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_message_reactions")
}

model WhatsappMessageReceipt {
  remoteJid      String   @map("remote_jid")
  messageId      String   @map("message_id")
  recipientJid   String   @map("recipient_jid")
  receiptType    String   @map("receipt_type")
  receiptAt      DateTime? @map("receipt_at")
  readAt         DateTime? @map("read_at")
  playedAt       DateTime? @map("played_at")
  deliveredDevices Json?   @map("delivered_devices")
  pendingDevices Json?     @map("pending_devices")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([remoteJid, messageId, recipientJid, receiptType])
  @@index([remoteJid, messageId, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_message_receipts")
}

model WhatsappPresenceState {
  chatJid          String   @map("chat_jid")
  participantJid   String   @map("participant_jid")
  lastKnownPresence String  @map("last_known_presence")
  lastSeen         DateTime? @map("last_seen")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([chatJid, participantJid])
  @@index([chatJid, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_presence_states")
}

model WhatsappGroup {
  jid         String   @id
  subject     String
  owner       String?
  desc        String?
  creation    DateTime?
  size        Int?
  ephemeralDuration Int? @map("ephemeral_duration")
  rawGroupJson Json?  @map("raw_group_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_groups")
}

model WhatsappGroupParticipant {
  groupJid     String   @map("group_jid")
  participantJid String @map("participant_jid")
  admin        String?
  isSuperAdmin Boolean? @map("is_super_admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([groupJid, participantJid])
  @@index([groupJid, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_group_participants")
}

model WhatsappBlockedJid {
  jid         String   @id
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_blocked_jids")
}

model WhatsappBusinessQuickReply {
  timestamp   String   @id
  shortcut    String
  message     String
  keywords    Json?
  count       Int?     @default(0)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([deleted, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_business_quick_replies")
}

model WhatsappBusinessLabel {
  id          String   @id
  name        String?
  color       Int?
  deleted     Boolean  @default(false)
  predefinedId String? @map("predefined_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([deleted, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("whatsapp_business_labels")
}

model WhatsappBusinessChatLabel {
  labelId   String   @map("label_id")
  chatJid   String   @map("chat_jid")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([labelId, chatJid])
  @@index([chatJid, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_business_chat_labels")
}

model WhatsappBusinessMessageLabel {
  labelId   String   @map("label_id")
  chatJid   String   @map("chat_jid")
  messageId String   @map("message_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([labelId, chatJid, messageId])
  @@index([chatJid, messageId, updatedAt(sort: Desc)])
  @@deny('all', auth() == null)
  @@allow('read', auth() != null)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("whatsapp_business_message_labels")
}

