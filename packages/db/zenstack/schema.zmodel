// ============================================================
// PERSONAL FINANCE SCHEMA
// ============================================================

model PersonalCredit {
  id                Int                         @id @default(autoincrement())
  bankName          String                      @map("bank_name") // BCI, Falabella, Itaú
  creditNumber      String                      @unique @map("credit_number") // Identifier
  description       String?  // "Crédito de Consumo", "Hipotecario"
  
  // Financial Details
  totalAmount       Decimal                     @map("total_amount") @db.Decimal(15, 2)
  currency          String                      @default("CLP") // CLP, UF
  interestRate      Decimal?                    @map("interest_rate") @db.Decimal(5, 2) // Monthly/Yearly rate
  startDate         DateTime                    @map("start_date") @db.Date
  
  // Status
  totalInstallments Int                         @map("total_installments")
  status            String                      @default("ACTIVE") // ACTIVE, PAID, REFINANCED

  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @default(now()) @updatedAt @map("updated_at")

  installments      PersonalCreditInstallment[]

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@schema("personal")
  @@map("credits")
}

model PersonalCreditInstallment {
  id                Int            @id @default(autoincrement())
  creditId          Int            @map("credit_id")

  installmentNumber Int            @map("installment_number") // 1/48
  dueDate           DateTime       @map("due_date") @db.Date
  
  // Amounts
  amount            Decimal        @db.Decimal(15, 2) // Total Quota Amount
  capitalAmount     Decimal?       @map("capital_amount") @db.Decimal(15, 2) // Amortization
  interestAmount    Decimal?       @map("interest_amount") @db.Decimal(15, 2)
  otherCharges      Decimal?       @map("other_charges") @db.Decimal(15, 2) // Insurance, etc.
  
  // Status
  status            String         @default("PENDING") // PENDING, PAID
  paidAt            DateTime?      @map("paid_at")
  paidAmount        Decimal?       @map("paid_amount") @db.Decimal(15, 2)
  paidAmountCLP     Decimal?       @map("paid_amount_clp") @db.Decimal(15, 2) // CLP equivalent for UF credits

  credit            PersonalCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('update', auth().status == 'ACTIVE')

  @@schema("personal")
  @@index([creditId])
  @@unique([creditId, installmentNumber])
  @@map("credit_installments")
}


model MedicalCertificate {
  id            String    @id @default(cuid())
  patientName   String    @map("patient_name")
  patientRut    String    @map("patient_rut")
  birthDate     DateTime  @map("birth_date") @db.Date
  address       String

  diagnosis     String
  symptoms      String?
  restDays      Int?      @map("rest_days")
  restStartDate DateTime? @map("rest_start_date") @db.Date
  restEndDate   DateTime? @map("rest_end_date") @db.Date
  purpose       String
  purposeDetail String?   @map("purpose_detail")

  issuedBy      Int       @map("issued_by")
  issuedAt      DateTime  @default(now()) @map("issued_at")

  patientId     Int?      @map("patient_id") // Optional link to Patient

  driveFileId   String    @map("drive_file_id") // Google Drive file ID
  pdfHash       String    @map("pdf_hash") // SHA-256

  metadata      Json?    // Full certificate data as backup

  issuer        User      @relation(fields: [issuedBy], references: [id])
  patient       Patient?  @relation(fields: [patientId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().id == issuedBy)
  @@allow('create', auth().status == 'ACTIVE')
  @@allow('read', auth() != null)

  @@index([patientRut])
  @@index([issuedAt])
  @@map("medical_certificates")
}
model Patient {
  id                  Int                    @id @default(autoincrement())
  personId            Int                    @unique @map("person_id")
  birthDate           DateTime?              @map("birth_date") @db.Date
  bloodType           String?                @map("blood_type")
  notes               String?  // Notas generales del paciente

  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @default(now()) @updatedAt @map("updated_at")

  person              Person                 @relation(fields: [personId], references: [id], onDelete: Cascade)
  consultations       Consultation[]
  medicalCertificates MedicalCertificate[]
  budgets             Budget[]
  payments            PatientPayment[]
  attachments         PatientAttachment[]
  dteSaleSources      PatientDteSaleSource[]
  shipments           Shipment[]
  clinicalSeries      ClinicalSeries[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("patients")
}

model Shipment {
  id                   Int      @id @default(autoincrement())
  patientId            Int      @map("patient_id")
  otNumber             String   @unique @map("ot_number")
  serviceTypeCode      String   @map("service_type_code")
  serviceDescription   String   @map("service_description")
  cashOnDelivery       Decimal  @map("cash_on_delivery") @db.Decimal(12, 2)
  declaredValue        Decimal  @map("declared_value") @db.Decimal(12, 2)
  weight               Decimal  @db.Decimal(8, 2)
  height               Decimal  @db.Decimal(8, 2)
  width                Decimal  @db.Decimal(8, 2)
  length               Decimal  @db.Decimal(8, 2)
  recipientName        String   @map("recipient_name")
  recipientPhone       String   @map("recipient_phone")
  recipientEmail       String?  @map("recipient_email")
  commercialOfficeId   String   @map("commercial_office_id")
  commercialOfficeName String   @map("commercial_office_name")
  coverageCode         String   @map("coverage_code")
  contentDescription   String   @map("content_description")
  labelBase64          String?  @map("label_base64") @db.Text
  status               String   @default("CREATED")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("shipments")
}

model PatientDteSaleSource {
  id              Int       @id @default(autoincrement())
  patientId       Int?      @map("patient_id")
  clientRUT       String    @unique @map("client_rut") @db.VarChar(20)
  clientName      String    @map("client_name")
  documentType    Int       @map("document_type")
  documentDate    DateTime? @map("document_date") @db.Date
  folio           String?   @map("folio") @db.VarChar(20)
  period          String?   @map("period") @db.VarChar(6)
  sourceUpdatedAt DateTime? @map("source_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([documentDate])
  @@index([period])
  @@map("patient_dte_sale_sources")
}

model Consultation {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  eventId   Int?     @map("event_id") // Link to Calendar Event
  date      DateTime @db.Date
  reason    String   // Motivo de consulta
  diagnosis String?  // Diagnóstico
  treatment String?  // Tratamiento indicado
  notes     String?  // Notas adicionales

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([eventId])
  @@index([date])
  @@map("consultations")
}

model Budget {
  id          Int              @id @default(autoincrement())
  patientId   Int              @map("patient_id")
  title       String
  totalAmount Decimal          @map("total_amount") @db.Decimal(15, 2)
  discount    Decimal          @default(0) @db.Decimal(15, 2)
  finalAmount Decimal          @map("final_amount") @db.Decimal(15, 2)
  status      BudgetStatus     @default(DRAFT)
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")

  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments    PatientPayment[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@map("budgets")
}

model PatientPayment {
  id            Int      @id @default(autoincrement())
  patientId     Int      @map("patient_id")
  budgetId      Int?     @map("budget_id")
  amount        Decimal  @db.Decimal(15, 2)
  paymentDate   DateTime @default(now()) @map("payment_date")
  paymentMethod String   @map("payment_method") // Transfer, Cash, Card
  reference     String?       // Transaction ID or Receipt number
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  budget        Budget?  @relation(fields: [budgetId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([budgetId])
  @@map("patient_payments")
}

model PatientAttachment {
  id          String         @id @default(cuid())
  patientId   Int            @map("patient_id")
  name        String
  type        AttachmentType @default(OTHER)
  driveFileId String         @map("drive_file_id")
  mimeType    String?        @map("mime_type")
  uploadedBy  Int            @map("uploaded_by")
  uploadedAt  DateTime       @default(now()) @map("uploaded_at")

  patient     Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader    User           @relation(fields: [uploadedBy], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@map("patient_attachments")
}

enum BudgetStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AttachmentType {
  CONSENT
  EXAM
  RECIPE
  OTHER
}

// ============================================================
// DTE (Documentos Tributarios Electrónicos) - Accounting
// ============================================================
// DTE PURCHASE & SALES DETAILS
// ============================================================

model DTEPurchaseDetail {
  id                    String    @id @default(uuid())
  registerNumber        Int       @map("register_number") // Nº field from CSV
  documentType          Int       @default(33) @map("document_type") // 33 = Factura de Compra
  purchaseType          String    @map("purchase_type") // "Compras del Giro", etc.
  providerRUT           String    @map("provider_rut") @db.VarChar(20)
  providerName          String    @map("provider_name")
  folio                 String    @map("folio") @db.VarChar(20)
  documentDate          DateTime  @db.Date @map("document_date")
  receiptDate           DateTime  @db.Date @map("receipt_date")
  acknowledgeDate       DateTime? @db.Date @map("acknowledge_date")
  period                String?   @map("period") @db.VarChar(6) // Format: YYYYMM
  
  // Financial amounts
  exemptAmount          Decimal   @default(0) @map("exempt_amount") @db.Decimal(15, 2)
  netAmount             Decimal   @default(0) @map("net_amount") @db.Decimal(15, 2)
  recoverableIVA        Decimal   @default(0) @map("recoverable_iva") @db.Decimal(15, 2)
  nonRecoverableIVA     Decimal   @default(0) @map("non_recoverable_iva") @db.Decimal(15, 2)
  nonRecoverableIVACode String?   @map("non_recoverable_iva_code") @db.VarChar(10)
  totalAmount           Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  fixedAssetNetAmount   Decimal   @default(0) @map("fixed_asset_net_amount") @db.Decimal(15, 2)
  commonUseIVA          Decimal   @default(0) @map("common_use_iva") @db.Decimal(15, 2)
  nonCreditableTax      Decimal   @default(0) @map("non_creditable_tax") @db.Decimal(15, 2)
  nonRetainedIVA        Decimal   @default(0) @map("non_retained_iva") @db.Decimal(15, 2)
  
  // Tobacco fields (usually zero)
  pureTobacco           Decimal   @default(0) @map("pure_tobacco") @db.Decimal(15, 2)
  cigaretteTobacco      Decimal   @default(0) @map("cigarette_tobacco") @db.Decimal(15, 2)
  elaboratedTobacco     Decimal   @default(0) @map("elaborated_tobacco") @db.Decimal(15, 2)
  
  // Other tax
  otherTaxCode          String?   @map("other_tax_code") @db.VarChar(10)
  otherTaxAmount        Decimal   @default(0) @map("other_tax_amount") @db.Decimal(15, 2)
  otherTaxRate          Decimal?  @map("other_tax_rate") @db.Decimal(5, 2)
  
  // Additional notes
  referenceDocNote      String?   @map("reference_doc_note") // NCE o NDE Sobre Fact. de Compra
  notes                 String?

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  lineItems             DTELineItem[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([providerRUT, folio])
  @@index([providerRUT])
  @@index([documentDate])
  @@map("dte_purchase_details")
}

model DTESaleDetail {
  id                             String    @id @default(uuid())
  registerNumber                 Int       @map("register_number") // Nº field from CSV
  documentType                   Int       @map("document_type") // 41 = Boleta, 61 = Nota Crédito, etc.
  saleType                       String    @map("sale_type") // "Del Giro", etc.
  clientRUT                      String    @map("client_rut") @db.VarChar(20)
  clientName                     String    @map("client_name")
  folio                          String    @map("folio") @db.VarChar(20)
  documentDate                   DateTime  @db.Date @map("document_date")
  receiptDate                    DateTime  @db.Date @map("receipt_date")
  receiptAcknowledgeDate         DateTime? @db.Date @map("receipt_acknowledge_date")
  claimDate                      DateTime? @db.Date @map("claim_date")
  period                         String?   @map("period") @db.VarChar(6) // Format: YYYYMM
  
  // Financial amounts
  exemptAmount                   Decimal   @default(0) @map("exempt_amount") @db.Decimal(15, 2)
  netAmount                      Decimal   @default(0) @map("net_amount") @db.Decimal(15, 2)
  ivaAmount                      Decimal   @default(0) @map("iva_amount") @db.Decimal(15, 2)
  totalAmount                    Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  
  // IVA details
  totalRetainedIVA               Decimal   @default(0) @map("total_retained_iva") @db.Decimal(15, 2)
  partialRetainedIVA             Decimal   @default(0) @map("partial_retained_iva") @db.Decimal(15, 2)
  nonRetainedIVA                 Decimal   @default(0) @map("non_retained_iva") @db.Decimal(15, 2)
  ownIVA                         Decimal   @default(0) @map("own_iva") @db.Decimal(15, 2)
  thirdPartyIVA                  Decimal   @default(0) @map("third_party_iva") @db.Decimal(15, 2)
  lateIVA                        Decimal   @default(0) @map("late_iva") @db.Decimal(15, 2)
  
  // Commission details
  emitterRUT                     String?   @map("emitter_rut") @db.VarChar(20)
  commissionNetAmount            Decimal   @default(0) @map("commission_net_amount") @db.Decimal(15, 2)
  commissionExemptAmount         Decimal   @default(0) @map("commission_exempt_amount") @db.Decimal(15, 2)
  commissionIVA                  Decimal   @default(0) @map("commission_iva") @db.Decimal(15, 2)
  
  // Reference document
  referenceDocType               String?   @map("reference_doc_type") @db.VarChar(10)
  referenceDocFolio              String?   @map("reference_doc_folio") @db.VarChar(20)
  
  // Foreign buyer details
  foreignBuyerIdentifier         String?   @map("foreign_buyer_identifier") @db.VarChar(20)
  foreignBuyerNationality        String?   @map("foreign_buyer_nationality") @db.VarChar(50)
  
  // Special conditions
  constructorCreditAmount        Decimal   @default(0) @map("constructor_credit_amount") @db.Decimal(15, 2)
  freeTradeZoneAmount            Decimal   @default(0) @map("free_trade_zone_amount") @db.Decimal(15, 2)
  containerGuaranteeAmount       Decimal   @default(0) @map("container_guarantee_amount") @db.Decimal(15, 2)
  nonBillableAmount              Decimal   @default(0) @map("non_billable_amount") @db.Decimal(15, 2)
  internationalTransportAmount   Decimal   @default(0) @map("international_transport_amount") @db.Decimal(15, 2) // Venta Pasajes Transporte Internacional
  
  // Special indicators
  nonCostSaleIndicator           Int       @default(0) @map("non_cost_sale_indicator") // Indicador Venta sin Costo
  periodicServiceIndicator       Int       @default(0) @map("periodic_service_indicator") // Indicador Servicio Periódico
  totalPeriodAmount              Decimal   @default(0) @map("total_period_amount") @db.Decimal(15, 2) // Total Monto Periodo
  nationalTransportPassageAmount Decimal   @default(0) @map("national_transport_passage_amount") @db.Decimal(15, 2) // Venta Pasajes Transporte Nacional
  
  // Identifiers
  internalNumber                 Int?      @map("internal_number")
  branchCode                     String?   @map("branch_code") @db.VarChar(20)
  
  // Metadata
  origin                         String?   @map("origin") @db.VarChar(20) // "WEB", "MANUAL", etc.
  informativeNote                String?   @map("informative_note")
  paymentNote                    String?   @map("payment_note")
  notes                          String?

  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @default(now()) @updatedAt @map("updated_at")
  autoLinkAttempts               EventDteAutoLinkAttempt[]
  eventLinks                     EventDteSaleLink[]
  lineItems                      DTELineItem[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([folio, documentType])
  @@index([clientRUT])
  @@index([documentDate])
  @@index([documentType])
  @@index([documentDate, totalAmount])
  @@map("dte_sale_details")
}

model DTELineItem {
  id                String             @id @default(uuid())
  lineNumber        Int                @map("line_number")        // NroLinDet
  itemName          String             @map("item_name")          // NmbItem
  itemDescription   String?            @map("item_description")   // DscItem
  quantity          Decimal            @default(1) @map("quantity") @db.Decimal(15, 6) // QtyItem
  unit              String?            @map("unit") @db.VarChar(10) // UnmdItem
  unitPrice         Decimal            @default(0) @map("unit_price") @db.Decimal(15, 6) // PrcItem
  amount            Decimal            @default(0) @map("amount") @db.Decimal(15, 2) // MontoItem
  isExempt          Boolean            @default(false) @map("is_exempt") // IndExe = 1
  itemCode          String?            @map("item_code") @db.VarChar(50)  // CdgItem/VlrCodigo
  itemCodeType      String?            @map("item_code_type") @db.VarChar(20) // CdgItem/TpoCodigo
  discountPercent   Decimal?           @map("discount_percent") @db.Decimal(5, 2) // DescuentoPct
  discountAmount    Decimal?           @map("discount_amount") @db.Decimal(15, 2) // DescuentoMonto

  // Polymorphic FK: one of these is set
  dteSaleDetailId   String?            @map("dte_sale_detail_id")
  dtePurchaseDetailId String?          @map("dte_purchase_detail_id")

  createdAt         DateTime           @default(now()) @map("created_at")

  dteSaleDetail     DTESaleDetail?     @relation(fields: [dteSaleDetailId], references: [id], onDelete: Cascade)
  dtePurchaseDetail DTEPurchaseDetail? @relation(fields: [dtePurchaseDetailId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([dteSaleDetailId, lineNumber])
  @@unique([dtePurchaseDetailId, lineNumber])
  @@index([dteSaleDetailId])
  @@index([dtePurchaseDetailId])
  @@map("dte_line_items")
}

model EventDteSaleLink {
  id              BigInt        @id @default(autoincrement())
  eventId         Int           @map("event_id")
  dteSaleDetailId String        @unique @map("dte_sale_detail_id")
  status          String        @default("CONFIRMED") @db.VarChar(20)
  matchedBy       String        @map("matched_by") @db.VarChar(30)
  confidenceScore Decimal       @map("confidence_score") @db.Decimal(5, 2)
  matchedRUT      String?       @map("matched_rut") @db.VarChar(20)
  matchedName     String?       @map("matched_name")
  evidence        Json?
  createdBy       Int?          @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")

  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dteSaleDetail   DTESaleDetail @relation(fields: [dteSaleDetailId], references: [id], onDelete: Cascade)
  creator         User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_sale_links")
}

model EventDteAutoLinkAttempt {
  id                     BigInt         @id @default(autoincrement())
  eventId                Int            @map("event_id")
  candidateDteSaleDetailId String?      @map("candidate_dte_sale_detail_id")
  status                 String         @db.VarChar(20)
  reason                 String
  confidenceScore        Decimal?       @map("confidence_score") @db.Decimal(5, 2)
  createdBy              Int?           @map("created_by")
  createdAt              DateTime       @default(now()) @map("created_at")

  event                  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  candidateDteSaleDetail DTESaleDetail? @relation(fields: [candidateDteSaleDetailId], references: [id], onDelete: SetNull)
  creator                User?          @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId, createdAt(sort: Desc)])
  @@index([candidateDteSaleDetailId])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_auto_link_attempts")
}

model EventDteMatchReview {
  id              BigInt   @id @default(autoincrement())
  eventId         Int      @map("event_id")
  action          String   @db.VarChar(20)
  hypothesisKind  String?  @map("hypothesis_kind") @db.VarChar(20)
  dteSaleDetailIds Json    @map("dte_sale_detail_ids")
  hypothesis      Json?
  createdBy       Int?     @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator         User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_match_reviews")
}

// ============================================================
// DTE SYNC LOGS
// ============================================================

model DTESyncLog {
  id                String    @id @default(uuid())
  period            String    @db.VarChar(6)                        // YYYYMM format (e.g., "202602")
  docTypes          String    @db.VarChar(50)                       // "sales" | "purchases" | "both"
  status            String    @default("PENDING") @db.VarChar(20)   // PENDING | SUCCESS | PARTIAL | FAILED
  totalProcessed    Int       @default(0) @map("total_processed")   // Total rows processed across all types
  totalInserted     Int       @default(0) @map("total_inserted")
  totalUpdated      Int       @default(0) @map("total_updated")
  totalSkipped      Int       @default(0) @map("total_skipped")
  salesInserted     Int       @default(0) @map("sales_inserted")
  purchasesInserted Int       @default(0) @map("purchases_inserted")
  errorMessage      String?   @map("error_message")
  triggerSource     String?   @db.VarChar(20)                       // "cron" | "manual" | "user"
  triggerUserId     String?   @map("trigger_user_id")               // User ID if manual trigger
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  
  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([period])
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("dte_sync_logs")
}

enum DTEType {
  PURCHASE
  SALE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CompensationAllocationType {
  MANUAL_ADJUST
  ORIGINAL
  ROLLOVER_IN
  ROLLOVER_OUT
}

model TransactionCategory {
  id                   Int                         @id @default(autoincrement())
  name                 String
  color                String?
  icon                 String?
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  transactions         FinancialTransaction[]
  autoRules            FinancialAutoCategoryRule[]
  compensationProfiles CompensationProfile[]
  services             Service[]

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@map("transaction_categories")
}

model FinancialAutoCategoryRule {
  id                  Int                 @id @default(autoincrement())
  name                String
  type                TransactionType     @default(EXPENSE)
  counterpartId       Int?                @map("counterpart_id")
  categoryId          Int                 @map("category_id")
  minAmount           Decimal?            @map("min_amount") @db.Decimal(19, 4)
  maxAmount           Decimal?            @map("max_amount") @db.Decimal(19, 4)
  amountsExact        Decimal[]           @default([]) @map("amounts_exact") @db.Decimal(19, 4)
  paymentMethods      String[]            @default([]) @map("payment_methods")
  matchAmountOn       String              @default("net") @map("match_amount_on")
  commentContains     String?             @map("comment_contains")
  descriptionContains String?             @map("description_contains")
  isActive            Boolean             @default(true) @map("is_active")
  priority            Int                 @default(0)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  counterpart         Counterpart?        @relation(fields: [counterpartId], references: [id], onDelete: Cascade)
  category            TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([counterpartId])
  @@index([categoryId])
  @@index([isActive])
  @@map("financial_auto_category_rules")
}

model FinancialTransaction {
  id               Int                              @id @default(autoincrement())
  date             DateTime
  description      String
  amount           Decimal                          @db.Decimal(19, 4)
  type             TransactionType
  sourceId         String?                          @map("source_id")
  categoryId       Int?                             @map("category_id")
  counterpartId    Int?                             @map("counterpart_id")
  category         TransactionCategory?             @relation(fields: [categoryId], references: [id])
  counterpart      Counterpart?                     @relation(fields: [counterpartId], references: [id])
  allocations      FinancialTransactionAllocation[]
  loanSchedules    LoanSchedule[]
  serviceSchedules ServiceSchedule[]
  comment          String?

  createdAt        DateTime                         @default(now()) @map("created_at")
  updatedAt        DateTime                         @updatedAt @map("updated_at")

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([counterpartId])
  @@map("financial_transactions")
}

model CompensationProfile {
  id            Int                              @id @default(autoincrement())
  name          String
  categoryId    Int                              @map("category_id")
  counterpartId Int?                             @map("counterpart_id")
  isActive      Boolean                          @default(true) @map("is_active")
  timezone      String                           @default("America/Santiago")
  createdAt     DateTime                         @default(now()) @map("created_at")
  updatedAt     DateTime                         @updatedAt @map("updated_at")

  category      TransactionCategory              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  counterpart   Counterpart?                     @relation(fields: [counterpartId], references: [id], onDelete: SetNull)
  budgets       CompensationPeriodBudget[]
  allocations   FinancialTransactionAllocation[]

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([categoryId])
  @@index([counterpartId])
  @@index([isActive])
  @@map("compensation_profiles")
}

model CompensationPeriodBudget {
  id         Int                 @id @default(autoincrement())
  profileId  Int                 @map("profile_id")
  period     String              @db.VarChar(7) // YYYY-MM
  baseAmount Decimal             @map("base_amount") @db.Decimal(19, 4)
  isLocked   Boolean             @default(false) @map("is_locked")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  profile    CompensationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@unique([profileId, period])
  @@index([profileId])
  @@index([period])
  @@map("compensation_period_budgets")
}

model FinancialTransactionAllocation {
  id                 Int                              @id @default(autoincrement())
  transactionId      Int                              @map("transaction_id")
  profileId          Int                              @map("profile_id")
  period             String                           @db.VarChar(7) // YYYY-MM
  amount             Decimal                          @db.Decimal(19, 4)
  allocationType     CompensationAllocationType       @default(MANUAL_ADJUST) @map("allocation_type")
  sourceAllocationId Int?                             @map("source_allocation_id")
  createdAt          DateTime                         @default(now()) @map("created_at")
  updatedAt          DateTime                         @updatedAt @map("updated_at")

  transaction        FinancialTransaction             @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  profile            CompensationProfile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sourceAllocation   FinancialTransactionAllocation?  @relation("AllocationSource", fields: [sourceAllocationId], references: [id], onDelete: SetNull)
  derivedAllocations FinancialTransactionAllocation[] @relation("AllocationSource")

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([transactionId])
  @@index([profileId])
  @@index([period])
  @@index([sourceAllocationId])
  @@map("financial_transaction_allocations")
}

enum PatientCampaignRecipientStatus {
  PENDING
  SENT
  INFO_REQUESTED
  IN_NEGOTIATION
  ACCEPTED
  DISMISSED
  NO_RESPONSE
}

model PatientCampaign {
  id              Int                         @id @default(autoincrement())
  name            String
  description     String?
  messageTemplate String?                     @map("message_template")
  imageUrl        String?                     @map("image_url")
  isActive        Boolean                     @default(true) @map("is_active")
  createdBy       Int?                        @map("created_by")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @default(now()) @updatedAt @map("updated_at")

  recipients      PatientCampaignRecipient[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([isActive])
  @@map("patient_campaigns")
}

model PatientCampaignRecipient {
  id            Int                            @id @default(autoincrement())
  campaignId    Int                            @map("campaign_id")
  patientRut    String                         @map("patient_rut") @db.VarChar(20)
  patientName   String?                        @map("patient_name")
  patientPhone  String?                        @map("patient_phone")
  status        PatientCampaignRecipientStatus @default(PENDING)
  notes         String?
  sentAt        DateTime?                      @map("sent_at")
  respondedAt   DateTime?                      @map("responded_at")
  updatedBy     Int?                           @map("updated_by")
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @default(now()) @updatedAt @map("updated_at")

  campaign      PatientCampaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([campaignId, patientRut])
  @@index([patientRut])
  @@index([status])
  @@index([campaignId])
  @@map("patient_campaign_recipients")
}

// ============================================================
// OUTREACH (Schools/Educational establishments outreach module)
// ============================================================

enum OutreachDependencia {
  MUNICIPAL
  PARTICULAR_SUBVENCIONADO
  PARTICULAR_PAGADO
  SLEP
  CORPORACION_MUNICIPAL
  OTRO
}

enum OutreachStatus {
  SIN_CONTACTAR
  CONTACTADO
  SIN_RESPUESTA
  RESPONDIO_INTERES
  RESPONDIO_MAS_INFO
  RESPONDIO_DESISTIO
  REUNION_AGENDADA
  CONVENIO_FIRMADO
  DESCARTADO
}

enum OutreachPriority {
  ALTA
  MEDIA
  BAJA
}

enum OutreachProspectType {
  COLEGIO
  EMPRESA
  MUNICIPIO
  INSTITUCION
  UNIVERSIDAD
  OTRO
}

enum OutreachProspectSource {
  MINEDUC
  GOOGLE_PLACES
  CRAWLER
  APOLLO
  HUNTER
  MANUAL
}

enum OutreachInteractionType {
  EMAIL_ENVIADO
  EMAIL_RECIBIDO
  LLAMADA_REALIZADA
  LLAMADA_RECIBIDA
  WHATSAPP
  REUNION_PRESENCIAL
  REUNION_ONLINE
  CHARLA_REALIZADA
  NOTA_INTERNA
}

enum OutreachCampaignStatus {
  BORRADOR
  REVISION
  ENVIANDO
  COMPLETADA
  PAUSADA
  CANCELADA
}

enum OutreachDeliveryStatus {
  PENDIENTE
  ENVIADO
  ERROR
  REBOTADO
  ABIERTO
  RESPONDIDO
}

model OutreachEstablishment {
  // ID semantically: external prospect id.
  // Colegios -> RBD MINEDUC (numeric string).
  // Empresas Google Places -> "gp:<placeId>".
  // Manual -> uuid or "manual:<slug>".
  rbd                  String                   @id @db.VarChar(64)
  nombre               String
  tipo                 OutreachProspectType     @default(COLEGIO)
  fuente               OutreachProspectSource   @default(MINEDUC)
  dependencia          OutreachDependencia      @default(OTRO)
  comuna               String
  ciudad               String?
  region               String
  direccion            String?
  telefonoMineduc      String?                  @map("telefono_mineduc")
  emailMineduc         String?                  @map("email_mineduc")
  directorMineduc      String?                  @map("director_mineduc")
  matriculaTotal       Int?                     @map("matricula_total")
  rural                Boolean                  @default(false)

  // Empresa-specific
  googlePlaceId        String?                  @unique @map("google_place_id")
  categoria            String?
  dominio              String?
  rating               Float?
  totalReviews         Int?                     @map("total_reviews")
  estadoNegocio        String?                  @map("estado_negocio")
  linkedinUrl          String?                  @map("linkedin_url")

  // Enrichment metadata
  apolloOrgId          String?                  @map("apollo_org_id")
  apolloLastFetchedAt  DateTime?                @map("apollo_last_fetched_at")
  hunterLastFetchedAt  DateTime?                @map("hunter_last_fetched_at")
  hunterEmailPattern   String?                  @map("hunter_email_pattern")
  crawledAt            DateTime?                @map("crawled_at")
  crawlSuccess         Boolean                  @default(false) @map("crawl_success")
  score                Int                      @default(0)

  // Manual enrichment
  websiteUrl           String?                  @map("website_url")
  emailsAdicionales    String[]                 @default([]) @map("emails_adicionales")
  telefonosAdicionales String[]                 @default([]) @map("telefonos_adicionales")
  notas                String?
  prioridad            OutreachPriority         @default(MEDIA)
  etiquetas            String[]                 @default([])

  estado               OutreachStatus           @default(SIN_CONTACTAR)
  ultimoContactoAt     DateTime?                @map("ultimo_contacto_at")

  activo               Boolean                  @default(true)
  importadoEn          DateTime                 @default(now()) @map("importado_en")
  actualizadoEn        DateTime                 @default(now()) @updatedAt @map("actualizado_en")

  contactos            OutreachContact[]
  interacciones        OutreachInteraction[]
  envios               OutreachEmailDelivery[]

  @@index([estado])
  @@index([dependencia])
  @@index([comuna])
  @@index([prioridad])
  @@index([activo])
  @@index([tipo])
  @@index([fuente])
  @@index([dominio])
  @@index([score])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_establishments")
}

model OutreachContact {
  id                  Int                       @id @default(autoincrement())
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  nombre              String
  cargo               String
  email               String?
  telefono            String?
  esPrincipal         Boolean                   @default(false) @map("es_principal")
  notas               String?
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")

  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  interacciones       OutreachInteraction[]
  envios              OutreachEmailDelivery[]

  @@index([establecimientoRbd])
  @@index([email])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_contacts")
}

model OutreachInteraction {
  id                  Int                       @id @default(autoincrement())
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  contactoId          Int?                      @map("contacto_id")
  tipo                OutreachInteractionType
  fecha               DateTime
  asunto              String?
  contenido           String
  emailDesde          String?                   @map("email_desde")
  emailHacia          String?                   @map("email_hacia")
  resultado           String?
  creadoPorUserId     Int?                      @map("creado_por_user_id")
  creadoPorNombre     String?                   @map("creado_por_nombre")
  createdAt           DateTime                  @default(now()) @map("created_at")

  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  contacto            OutreachContact?          @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  @@index([establecimientoRbd])
  @@index([contactoId])
  @@index([tipo])
  @@index([fecha])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_interactions")
}

model OutreachEmailCampaign {
  id                  Int                       @id @default(autoincrement())
  nombre              String
  asunto              String
  cuerpoHtml          String                    @map("cuerpo_html")
  cuerpoTexto         String                    @map("cuerpo_texto")
  fromEmail           String                    @map("from_email")
  fromNombre          String                    @map("from_nombre")
  replyTo             String?                   @map("reply_to")
  filtros             Json                      @default("{}")
  ratePerHour         Int                       @default(50) @map("rate_per_hour")
  estado              OutreachCampaignStatus    @default(BORRADOR)

  totalDestinatarios  Int                       @default(0) @map("total_destinatarios")
  enviados            Int                       @default(0)
  errores             Int                       @default(0)
  respondidos         Int                       @default(0)

  createdByUserId     Int?                      @map("created_by_user_id")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")
  enviadoEn           DateTime?                 @map("enviado_en")

  envios              OutreachEmailDelivery[]

  @@index([estado])
  @@index([createdByUserId])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_email_campaigns")
}

model OutreachEmailDelivery {
  id                  Int                       @id @default(autoincrement())
  campaignId          Int                       @map("campaign_id")
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  contactoId          Int?                      @map("contacto_id")
  emailDestinatario   String                    @map("email_destinatario")
  asuntoRender        String?                   @map("asunto_render")
  cuerpoHtmlRender    String?                   @map("cuerpo_html_render")
  cuerpoTextoRender   String?                   @map("cuerpo_texto_render")
  estado              OutreachDeliveryStatus    @default(PENDIENTE)
  errorMensaje        String?                   @map("error_mensaje")
  intentos            Int                       @default(0)
  enviadoEn           DateTime?                 @map("enviado_en")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")

  campaign            OutreachEmailCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  contacto            OutreachContact?          @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([establecimientoRbd])
  @@index([estado])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_email_deliveries")
}

model OutreachImportLog {
  id                Int       @id @default(autoincrement())
  source            String
  fileUrl           String?   @map("file_url")
  totalRows         Int       @default(0) @map("total_rows")
  nuevos            Int       @default(0)
  actualizados      Int       @default(0)
  inactivos         Int       @default(0)
  errores           Int       @default(0)
  errorDetalle      String?   @map("error_detalle")
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdByUserId   Int?      @map("created_by_user_id")

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_import_logs")
}

// ============================================================
// BAILEYS (WhatsApp) AUTH STATE
// Managed via raw Kysely queries — not through ZenStack ORM.
// Included here so `db push` does not drop these tables.
// ============================================================

model BaileysAuthCreds {
  id        String   @id @default("default")
  creds     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@allow('all', true)
  @@map("baileys_auth_creds")
}

model BaileysAuthKeys {
  type  String
  id    String
  value Json

  @@id([type, id])
  @@allow('all', true)
  @@map("baileys_auth_keys")
}

// ============================================================
// WHATSAPP CLOUD API (Meta official) — paralelo a Baileys (WhatsappX)
// ============================================================

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum WaMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACTS
  INTERACTIVE
  BUTTON
  TEMPLATE
  REACTION
  SYSTEM
  UNSUPPORTED
}

enum WaConversationStatus {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
}

enum WaTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
  PAUSED
}

enum WaTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

model WaBusinessAccount {
  id                  Int       @id @default(autoincrement())
  wabaId              String    @unique @map("waba_id")
  metaBusinessId      String?   @map("meta_business_id")
  appId               String?   @map("app_id")
  appSecret           String?   @map("app_secret")
  systemUserToken     String?   @map("system_user_token")
  webhookVerifyToken  String?   @map("webhook_verify_token")
  graphApiVersion     String    @default("v21.0") @map("graph_api_version")
  displayName         String?   @map("display_name")
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  phoneNumbers        WaPhoneNumber[]
  templates           WaTemplate[]

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_business_accounts")
}

model WaPhoneNumber {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  phoneNumberId       String    @unique @map("phone_number_id")
  displayPhoneNumber  String    @map("display_phone_number")
  label               String?
  qualityRating       String?   @map("quality_rating")
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  account             WaBusinessAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages            WaMessage[]
  conversations       WaConversationChannel[]

  @@index([accountId])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_phone_numbers")
}

model WaContact {
  id                  Int       @id @default(autoincrement())
  phoneE164           String    @unique @map("phone_e164")
  name                String?
  pushName            String?   @map("push_name")
  optInStatus         String    @default("UNKNOWN") @map("opt_in_status")
  notas               String?
  etiquetas           String[]  @default([])
  patientRut          String?   @map("patient_rut") @db.VarChar(20)
  metadata            Json      @default("{}")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  conversations       WaConversation[]
  messages            WaMessage[]

  @@index([patientRut])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_contacts")
}

model WaConversation {
  id                  Int                   @id @default(autoincrement())
  contactId           Int                   @map("contact_id")
  status              WaConversationStatus  @default(OPEN)
  assignedToUserId    Int?                  @map("assigned_to_user_id")
  unreadCount         Int                   @default(0) @map("unread_count")
  lastInboundAt       DateTime?             @map("last_inbound_at")
  lastMessageAt       DateTime?             @map("last_message_at")
  lastMessagePreview  String?               @map("last_message_preview")
  notas               String?
  etiquetas           String[]              @default([])
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")

  contact             WaContact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channels            WaConversationChannel[]
  messages            WaMessage[]

  @@unique([contactId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_conversations")
}

model WaConversationChannel {
  id                  Int            @id @default(autoincrement())
  conversationId      Int            @map("conversation_id")
  phoneNumberId       Int            @map("phone_number_id")
  lastMessageAt       DateTime?      @map("last_message_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  conversation        WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  phoneNumber         WaPhoneNumber  @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([conversationId, phoneNumberId])
  @@index([phoneNumberId])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_conversation_channels")
}

model WaMessage {
  id                  Int                  @id @default(autoincrement())
  conversationId      Int                  @map("conversation_id")
  contactId           Int                  @map("contact_id")
  phoneNumberId       Int                  @map("phone_number_id")
  metaMessageId       String?              @map("meta_message_id")
  direction           WaMessageDirection
  type                WaMessageType
  status              WaMessageStatus      @default(PENDING)
  body                String?
  mediaUrl            String?              @map("media_url")
  mediaMimeType       String?              @map("media_mime_type")
  mediaCaption        String?              @map("media_caption")
  templateName        String?              @map("template_name")
  templateLanguage    String?              @map("template_language")
  payload             Json                 @default("{}")
  errorCode           String?              @map("error_code")
  errorTitle          String?              @map("error_title")
  errorDetails        String?              @map("error_details")
  sentByUserId        Int?                 @map("sent_by_user_id")
  contextMetaMessageId String?             @map("context_meta_message_id")
  timestamp           DateTime
  deliveredAt         DateTime?            @map("delivered_at")
  readAt              DateTime?            @map("read_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")

  conversation        WaConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact             WaContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneNumber         WaPhoneNumber        @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([metaMessageId])
  @@index([conversationId])
  @@index([contactId])
  @@index([phoneNumberId])
  @@index([timestamp])
  @@index([direction, status])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_messages")
}

model WaTemplate {
  id                  Int                 @id @default(autoincrement())
  accountId           Int                 @map("account_id")
  name                String
  language            String
  category            WaTemplateCategory  @default(UTILITY)
  status              WaTemplateStatus    @default(PENDING)
  components          Json                @default("[]")
  qualityScore        String?             @map("quality_score")
  metaTemplateId      String?             @map("meta_template_id")
  syncedAt            DateTime?           @map("synced_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")

  account             WaBusinessAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name, language])
  @@index([status])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_templates")
}

model WaWebhookLog {
  id                  Int       @id @default(autoincrement())
  receivedAt          DateTime  @default(now()) @map("received_at")
  signatureValid      Boolean   @map("signature_valid")
  payload             Json
  processed           Boolean   @default(false)
  errorMessage        String?   @map("error_message")
  eventCount          Int       @default(0) @map("event_count")

  @@index([receivedAt])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_webhook_logs")
}

// ─── Expenses ────────────────────────────────────────────────────────────────

enum ExpenseScope {
  BIOALERGIA
  PERSONAL
}

enum ExpenseStatus {
  PENDING
  PAID
  OVERDUE
  SKIPPED
}

enum ExpenseSource {
  MANUAL
  TEMPLATE
  TRANSACTION
}

enum ExpenseRecurrence {
  MONTHLY
  ONE_TIME
}

model ExpenseService {
  id             Int               @id @default(autoincrement())
  publicId       String            @unique @default(cuid()) @map("public_id")
  name           String
  detail         String?
  scope          ExpenseScope
  category       String?
  billingDay     Int?              @map("billing_day")
  dueDateRule    String?           @map("due_date_rule")
  defaultAmount  Decimal?          @map("default_amount") @db.Decimal(14, 2)
  isFixed        Boolean           @default(false) @map("is_fixed")
  recurrence     ExpenseRecurrence @default(MONTHLY)
  startDate      DateTime?         @map("start_date") @db.Date
  endDate        DateTime?         @map("end_date") @db.Date
  isActive       Boolean           @default(true) @map("is_active")
  notes          String?
  tags           String[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at")

  expenses       Expense[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@map("expense_services")
}

model Expense {
  id             Int             @id @default(autoincrement())
  publicId       String          @unique @default(cuid()) @map("public_id")
  serviceId      Int?            @map("service_id")
  name           String
  detail         String?
  scope          ExpenseScope
  expenseMonth   String          @map("expense_month")
  dueDate        DateTime?       @map("due_date") @db.Date
  amountExpected Decimal         @map("amount_expected") @db.Decimal(14, 2)
  amountApplied  Decimal         @default(0) @map("amount_applied") @db.Decimal(14, 2)
  status         ExpenseStatus   @default(PENDING)
  source         ExpenseSource   @default(MANUAL)
  category       String?
  notes          String?
  tags           String[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")

  service        ExpenseService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  transactions   ExpenseTransaction[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@index([expenseMonth])
  @@index([scope])
  @@index([serviceId])
  @@map("expenses")
}

// ─── Utility Accounts ────────────────────────────────────────────────────────

enum UtilityProvider {
  ESSBIO
  CGE
  OTHER
}

model UtilityAccount {
  id               Int             @id @default(autoincrement())
  provider         UtilityProvider
  scope            ExpenseScope    @default(PERSONAL)
  serviceNumber    String          @unique @map("service_number") // Essbio: numero_servicio, CGE: CTA_CTO
  label            String?         // e.g. "Casa San Pedro", "Clínica"

  // Cached from last API fetch
  clientName       String?         @map("client_name")
  address          String?
  lastFetchedAt    DateTime?       @map("last_fetched_at")
  lastAmount       Decimal?        @map("last_amount") @db.Decimal(15, 2)
  lastPreviousAmount Decimal?      @map("last_previous_amount") @db.Decimal(15, 2)

  // Optional link to ExpenseService for auto-generating monthly expenses
  expenseServiceId Int?            @map("expense_service_id")

  isActive         Boolean         @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([scope])
  @@schema("personal")
  @@map("utility_accounts")
}

model ExpenseTransaction {
  id            Int      @id @default(autoincrement())
  expenseId     Int      @map("expense_id")
  transactionId Int      @map("transaction_id")
  amount        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@unique([expenseId, transactionId])
  @@map("expense_transactions")
}
