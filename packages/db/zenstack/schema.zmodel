  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  calendar   Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([calendarId])
  @@map("calendar_watch_channels")
}

model Event {
  id                Int                      @id @default(autoincrement())
  calendarId        Int                      @map("calendar_id")
  clinicalSeriesId  Int?                     @map("clinical_series_id")
  patientName       String?                  @map("patient_name")
  patientRut        String?                  @map("patient_rut")
  beneficiaryName   String?                  @map("beneficiary_name")
  beneficiaryRut    String?                  @map("beneficiary_rut")
  externalEventId   String                   @map("external_event_id")
  eventStatus       String?                  @map("event_status")
  eventType         String?                  @map("event_type")
  summary           String?
  description       String?
  startDate         DateTime?                @map("start_date") @db.Date
  startDateTime     DateTime?                @map("start_date_time") @db.Timestamptz(3)
  startTimeZone     String?                  @map("start_time_zone")
  endDate           DateTime?                @map("end_date") @db.Date
  endDateTime       DateTime?                @map("end_date_time") @db.Timestamptz(3)
  endTimeZone       String?                  @map("end_time_zone")
  eventCreatedAt    DateTime?                @map("event_created_at") @db.Timestamptz(3)
  eventUpdatedAt    DateTime?                @map("event_updated_at") @db.Timestamptz(3)
  colorId           String?                  @map("color_id")
  location          String?
  transparency      String?
  visibility        String?
  hangoutLink       String?                  @map("hangout_link")
  category          String?
  amountExpected    Int?                     @map("amount_expected")
  amountPaid        Int?                     @map("amount_paid")
  attended          Boolean?
  
  // Custom tracking fields
  treatmentStage    String?                  @map("treatment_stage")
  controlIncluded   Boolean                  @default(false) @map("control_included")
  isDomicilio       Boolean                  @default(false) @map("is_domicilio")
  rawEvent          Json?                    @map("raw_event")
  lastSyncedAt      DateTime?                @map("last_synced_at")

  dosageValue       Float?                   @map("dosage_value")
  dosageUnit        String?                  @map("dosage_unit")
  seriesStageKind   ClinicalSeriesStageKind? @map("series_stage_kind")
  seriesStageNumber Int?                     @map("series_stage_number")
  seriesStageLabel  String?                  @map("series_stage_label")
  testMetadata      Json?                    @map("test_metadata")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @default(now()) @updatedAt @map("updated_at")
  calendar          Calendar                 @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  clinicalSeries    ClinicalSeries?          @relation(fields: [clinicalSeriesId], references: [id], onDelete: SetNull)
  consultations     Consultation[]
  dteAutoLinkAttempts EventDteAutoLinkAttempt[]
  dteMatchReviews   EventDteMatchReview[]
  dteSaleLinks      EventDteSaleLink[]

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([calendarId, externalEventId])
  @@index([calendarId])
  @@index([clinicalSeriesId])
  @@index([patientRut])
  @@index([beneficiaryRut])
  @@map("events")
}

model ClinicalSeries {
  id               Int                       @id @default(autoincrement())
  kind             ClinicalSeriesKind
  status           ClinicalSeriesStatus      @default(ACTIVE)
  displayName      String?                   @map("display_name")
  patientId        Int?                      @map("patient_id")
  patientName      String?                   @map("patient_name")
  patientRut       String?                   @map("patient_rut")
  patientPhones    Json?                     @map("patient_phones")
  beneficiaryName  String?                   @map("beneficiary_name")
  beneficiaryRut   String?                   @map("beneficiary_rut")
  beneficiaryPhones Json?                    @map("beneficiary_phones")
  allergenType     SubcutaneousAllergenType?  @map("allergen_type")
  vaccineProduct   SubcutaneousVaccineProduct? @map("vaccine_product")
  healthInsurance  HealthInsuranceType?        @map("health_insurance")
  isapreName       String?                     @map("isapre_name")
  deliveryModality DeliveryModality?           @map("delivery_modality")
  expectedSessions Int?                        @map("expected_sessions")
  notes            String?
  completedAt      DateTime?                 @map("completed_at")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @default(now()) @updatedAt @map("updated_at")
  patient          Patient?                  @relation(fields: [patientId], references: [id], onDelete: SetNull)
  events     Event[]
  mergeLogs  ClinicalSeriesMergeLog[]
  abandonmentContacts AbandonmentContact[]
  skinTests  ClinicalSkinTest[]
  documentImports ClinicalDocumentImport[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([kind, status])
  @@index([patientId])
  @@index([patientRut])
  @@index([beneficiaryRut])
  @@map("clinical_series")
}

model ClinicalXlsxFile {
  id                    String                       @id @default(cuid())
  oneDriveAccountId     String?                      @map("onedrive_account_id")
  oneDriveItemId        String                       @map("onedrive_item_id")
  oneDriveDriveId       String?                      @map("onedrive_drive_id")
  oneDriveSourceKey     String?                      @map("onedrive_source_key")
  oneDriveSourceDriveId String?                      @map("onedrive_source_drive_id")
  oneDriveSourceItemId  String?                      @map("onedrive_source_item_id")
  oneDriveSharePointUniqueId String?                 @map("onedrive_sharepoint_unique_id")
  oneDriveQuickXorHash  String?                      @map("onedrive_quick_xor_hash")
  oneDriveSha1Hash      String?                      @map("onedrive_sha1_hash")
  oneDriveCrc32Hash     String?                      @map("onedrive_crc32_hash")
  oneDriveETag          String?                      @map("onedrive_etag")
  oneDriveCTag          String?                      @map("onedrive_ctag")
  oneDriveWebUrl        String?                      @map("onedrive_web_url")
  path                  String?
  filename              String
  mimeType              String?                      @map("mime_type")
  size                  Int?
  modifiedAt            DateTime?                    @map("modified_at") @db.Timestamptz(3)
  classification        ClinicalXlsxFileClassification @default(OTHER)
  classificationReason  String?                      @map("classification_reason")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @default(now()) @updatedAt @map("updated_at")

  oneDriveAccount       OneDriveAccount?             @relation(fields: [oneDriveAccountId], references: [accountId], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([classification])
  @@index([modifiedAt])
  @@index([oneDriveAccountId])
  @@index([oneDriveSourceKey])
  @@unique([oneDriveAccountId, oneDriveDriveId, oneDriveItemId])
  @@map("clinical_xlsx_files")
}

model ClinicalSkinTestImport {
  id                    String                    @id @default(cuid())
  oneDriveAccountId     String?                   @map("onedrive_account_id")
  oneDriveItemId        String                    @map("onedrive_item_id")
  oneDriveDriveId       String?                   @map("onedrive_drive_id")
  oneDriveSourceKey     String?                   @map("onedrive_source_key")
  oneDriveSourceDriveId String?                   @map("onedrive_source_drive_id")
  oneDriveSourceItemId  String?                   @map("onedrive_source_item_id")
  oneDriveSharePointUniqueId String?              @map("onedrive_sharepoint_unique_id")
  oneDriveQuickXorHash  String?                   @map("onedrive_quick_xor_hash")
  oneDriveSha1Hash      String?                   @map("onedrive_sha1_hash")
  oneDriveCrc32Hash     String?                   @map("onedrive_crc32_hash")
  oneDriveETag          String?                   @map("onedrive_etag")
  oneDriveCTag          String?                   @map("onedrive_ctag")
  oneDriveWebUrl        String?                   @map("onedrive_web_url")
  path                  String?
  filename              String
  mimeType              String?                   @map("mime_type")
  size                  Int?
  modifiedAt            DateTime?                 @map("modified_at") @db.Timestamptz(3)
  parserVersion         String                    @map("parser_version")
  status                ClinicalSkinTestImportStatus @default(PENDING_REVIEW)
  confidence            Int                       @default(0)
  error                 String?
  issues                Json?
  parsedPayload         Json?                     @map("parsed_payload")
  resultHash            String?                   @map("result_hash")
  duplicateOfImportId   String?                   @map("duplicate_of_import_id")
  workbookSnapshotStatus ClinicalSkinTestWorkbookSnapshotStatus @default(MISSING) @map("workbook_snapshot_status")
  workbookSnapshotError  String?                   @map("workbook_snapshot_error")
  workbookSnapshotArchivedAt DateTime?             @map("workbook_snapshot_archived_at") @db.Timestamptz(3)
  reviewedBy            Int?                      @map("reviewed_by")
  reviewedAt            DateTime?                 @map("reviewed_at") @db.Timestamptz(3)
  reviewNotes           String?                   @map("review_notes")
  importedAt            DateTime?                 @map("imported_at") @db.Timestamptz(3)
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at")

  skinTest              ClinicalSkinTest?
  results               ClinicalSkinTestResult[]
  workbookSnapshot      ClinicalSkinTestWorkbookSnapshot?
  oneDriveAccount       OneDriveAccount?          @relation(fields: [oneDriveAccountId], references: [accountId], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([status])
  @@index([modifiedAt])
  @@index([oneDriveAccountId])
  @@index([oneDriveSourceKey])
  @@index([workbookSnapshotStatus])
  @@unique([oneDriveAccountId, oneDriveDriveId, oneDriveItemId])
  @@map("clinical_skin_test_imports")
}

model ClinicalSkinTestWorkbookFile {
  id               String                 @id @default(cuid())
  extractorVersion String                 @map("extractor_version")
  sha256           String
  sizeBytes        Int?                   @map("size_bytes")
  sheetName        String                 @map("sheet_name")
  cellCount        Int                    @default(0) @map("cell_count")
  mergeCount       Int                    @default(0) @map("merge_count")
  textHash         String                 @map("text_hash")
  snapshotJson     Json                   @map("snapshot_json")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at")

  snapshots        ClinicalSkinTestWorkbookSnapshot[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([sha256, extractorVersion])
  @@index([sha256])
  @@index([textHash])
  @@index([createdAt])
  @@map("clinical_skin_test_workbook_files")
}

model ClinicalSkinTestWorkbookSnapshot {
  id               String                 @id @default(cuid())
  sourceImportId   String                 @unique @map("source_import_id")
  workbookFileId   String                 @map("workbook_file_id")
  sourceETag       String?                @map("source_etag")
  sourceCTag       String?                @map("source_ctag")
  status           ClinicalSkinTestWorkbookSnapshotStatus @default(ARCHIVED)
  error            String?
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at")

  sourceImport     ClinicalSkinTestImport @relation(fields: [sourceImportId], references: [id], onDelete: Cascade)
  workbookFile     ClinicalSkinTestWorkbookFile @relation(fields: [workbookFileId], references: [id], onDelete: Restrict)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([workbookFileId])
  @@index([status])
  @@index([createdAt])
  @@map("clinical_skin_test_workbook_snapshots")
}

