// ============================================================
// PERSONAL FINANCE SCHEMA
// ============================================================

model PersonalCredit {
  id                Int                         @id @default(autoincrement())
  bankName          String                      @map("bank_name") // BCI, Falabella, Itaú
  creditNumber      String                      @unique @map("credit_number") // Identifier
  description       String?  // "Crédito de Consumo", "Hipotecario"
  
  // Financial Details
  totalAmount       Decimal                     @map("total_amount") @db.Decimal(15, 2)
  currency          String                      @default("CLP") // CLP, UF
  interestRate      Decimal?                    @map("interest_rate") @db.Decimal(5, 2) // Monthly/Yearly rate
  startDate         DateTime                    @map("start_date") @db.Date
  
  // Status
  totalInstallments Int                         @map("total_installments")
  status            String                      @default("ACTIVE") // ACTIVE, PAID, REFINANCED

  createdAt         DateTime                    @default(now()) @map("created_at")
  updatedAt         DateTime                    @default(now()) @updatedAt @map("updated_at")

  installments      PersonalCreditInstallment[]

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@schema("personal")
  @@map("credits")
}

model PersonalCreditInstallment {
  id                Int            @id @default(autoincrement())
  creditId          Int            @map("credit_id")

  installmentNumber Int            @map("installment_number") // 1/48
  dueDate           DateTime       @map("due_date") @db.Date
  
  // Amounts
  amount            Decimal        @db.Decimal(15, 2) // Total Quota Amount
  capitalAmount     Decimal?       @map("capital_amount") @db.Decimal(15, 2) // Amortization
  interestAmount    Decimal?       @map("interest_amount") @db.Decimal(15, 2)
  otherCharges      Decimal?       @map("other_charges") @db.Decimal(15, 2) // Insurance, etc.
  
  // Status
  status            String         @default("PENDING") // PENDING, PAID
  paidAt            DateTime?      @map("paid_at")
  paidAmount        Decimal?       @map("paid_amount") @db.Decimal(15, 2)
  paidAmountCLP     Decimal?       @map("paid_amount_clp") @db.Decimal(15, 2) // CLP equivalent for UF credits

  credit            PersonalCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)

  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('update', auth().status == 'ACTIVE')

  @@schema("personal")
  @@index([creditId])
  @@unique([creditId, installmentNumber])
  @@map("credit_installments")
}


model MedicalCertificate {
  id            String    @id @default(cuid())
  patientName   String    @map("patient_name")
  patientRut    String    @map("patient_rut")
  birthDate     DateTime  @map("birth_date") @db.Date
  address       String

  diagnosis     String
  symptoms      String?
  restDays      Int?      @map("rest_days")
  restStartDate DateTime? @map("rest_start_date") @db.Date
  restEndDate   DateTime? @map("rest_end_date") @db.Date
  purpose       String
  purposeDetail String?   @map("purpose_detail")

  issuedBy      Int       @map("issued_by")
  issuedAt      DateTime  @default(now()) @map("issued_at")

  patientId     Int?      @map("patient_id") // Optional link to Patient

  driveFileId   String    @map("drive_file_id") // Google Drive file ID
  pdfHash       String    @map("pdf_hash") // SHA-256

  metadata      Json?    // Full certificate data as backup

  issuer        User      @relation(fields: [issuedBy], references: [id])
  patient       Patient?  @relation(fields: [patientId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().id == issuedBy)
  @@allow('create', auth().status == 'ACTIVE')
  @@allow('read', auth() != null)

  @@index([patientRut])
  @@index([issuedAt])
  @@map("medical_certificates")
}
model Patient {
  id                  Int                    @id @default(autoincrement())
  personId            Int                    @unique @map("person_id")
  birthDate           DateTime?              @map("birth_date") @db.Date
  bloodType           String?                @map("blood_type")
  notes               String?  // Notas generales del paciente

  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @default(now()) @updatedAt @map("updated_at")

  person              Person                 @relation(fields: [personId], references: [id], onDelete: Cascade)
  consultations       Consultation[]
  medicalCertificates MedicalCertificate[]
  budgets             Budget[]
  payments            PatientPayment[]
  attachments         PatientAttachment[]
  dteSaleSources      PatientDteSaleSource[]
  shipments           Shipment[]
  clinicalSeries      ClinicalSeries[]
  clinicalRecordImports ClinicalRecordImport[]
  examReports         ExamReport[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("patients")
}

model Shipment {
  id                   Int      @id @default(autoincrement())
  patientId            Int      @map("patient_id")
  otNumber             String   @unique @map("ot_number")
  serviceTypeCode      String   @map("service_type_code")
  serviceDescription   String   @map("service_description")
  serviceFullDesc      String?  @map("service_full_desc")
  cashOnDelivery       Decimal  @map("cash_on_delivery") @db.Decimal(12, 2)
  declaredValue        Decimal  @map("declared_value") @db.Decimal(12, 2)
  weight               Decimal  @db.Decimal(8, 2)
  height               Decimal  @db.Decimal(8, 2)
  width                Decimal  @db.Decimal(8, 2)
  length               Decimal  @db.Decimal(8, 2)
  recipientName        String   @map("recipient_name")
  recipientPhone       String   @map("recipient_phone")
  recipientEmail       String?  @map("recipient_email")
  commercialOfficeId   String   @map("commercial_office_id")
  commercialOfficeName String   @map("commercial_office_name")
  coverageCode         String   @map("coverage_code")
  contentDescription   String   @map("content_description")
  // Etiqueta y números devueltos por Chilexpress al crear la OT.
  certificateNumber    Int?     @map("certificate_number")
  reference            String?
  barcode              String?
  labelBase64          String?  @map("label_base64") @db.Text
  labelType            Int?     @map("label_type")
  // Chilexpress add-on services attached to the package at OT time
  // (e.g. 417 = "Cobertura Extendida"). Persisted so revenue reports
  // can attribute the extra cost back to the shipment, and so a
  // future reprint/reissue can mirror the original config.
  additionalServiceCodes Int[]    @default([]) @map("additional_service_codes")
  additionalServicesCost Decimal  @default(0) @map("additional_services_cost") @db.Decimal(12, 2)
  // Tracking
  trackingStatus       String?  @map("tracking_status")
  trackingUpdatedAt    DateTime? @map("tracking_updated_at")
  status               String   @default("CREATED")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update', auth().status == 'ACTIVE')

  @@map("shipments")
}

model PatientDteSaleSource {
  id              Int       @id @default(autoincrement())
  patientId       Int?      @map("patient_id")
  clientRUT       String    @unique @map("client_rut") @db.VarChar(20)
  clientName      String    @map("client_name")
  documentType    Int       @map("document_type")
  documentDate    DateTime? @map("document_date") @db.Date
  folio           String?   @map("folio") @db.VarChar(20)
  period          String?   @map("period") @db.VarChar(6)
  sourceUpdatedAt DateTime? @map("source_updated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  patient         Patient?  @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([documentDate])
  @@index([period])
  @@map("patient_dte_sale_sources")
}

model Consultation {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  eventId   Int?     @map("event_id") // Link to Calendar Event
  date      DateTime @db.Date
  reason    String   // Motivo de consulta
  diagnosis String?  // Diagnóstico
  treatment String?  // Tratamiento indicado
  notes     String?  // Notas adicionales

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  event     Event?   @relation(fields: [eventId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([eventId])
  @@index([date])
  @@map("consultations")
}

model Budget {
  id          Int              @id @default(autoincrement())
  patientId   Int              @map("patient_id")
  title       String
  totalAmount Decimal          @map("total_amount") @db.Decimal(15, 2)
  discount    Decimal          @default(0) @db.Decimal(15, 2)
  finalAmount Decimal          @map("final_amount") @db.Decimal(15, 2)
  status      BudgetStatus     @default(DRAFT)
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")

  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments    PatientPayment[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@map("budgets")
}

// Catálogo editable de productos de inmunoterapia subcutánea para PRESUPUESTO
// (cobro al paciente). Las etapas de dosis y precios varían por producto
// (Clustoid/Roxall, Alxoid, …) y son 100% editables desde DB — sin precios
// hardcodeados. El presupuesto es ANUAL: fase inicio (dosis escalonadas) +
// N dosis de mantención. El costo del vial (interno) NO se modela aquí.
model ImmunotherapyProduct {
  id                    Int      @id @default(autoincrement())
  name                  String   // "Clustoid", "Alxoid"
  lab                   String?  // "Roxall"
  vaccineProduct        SubcutaneousVaccineProduct? @map("vaccine_product") // link opcional al enum clínico
  // Composición/potencia (metadata, NO afecta el precio al paciente — el
  // esquema de dosis manda). Se imprime en el PDF.
  concentrationUtMl     Int?     @map("concentration_ut_ml") // ej. 10000, 30000 (UT/mL)
  perAllergen           Boolean  @default(false) @map("per_allergen") // potencia es UT/mL POR alérgeno
  maxAllergens          Int?     @map("max_allergens") // límite de alérgenos (Forte = 1); null = sin límite
  maintenanceTargetMl   Decimal  @default(0.5) @map("maintenance_target_ml") @db.Decimal(5, 2) // volumen base de la etapa de mantención
  maintenanceStepMl     Decimal  @default(0.25) @map("maintenance_step_ml") @db.Decimal(5, 2) // tramo de ajuste proporcional
  maintenanceDefaultQty Int      @default(11) @map("maintenance_default_qty") // dosis de mantención/año por defecto
  defaultDiscountPct    Decimal? @map("default_discount_pct") @db.Decimal(5, 2) // ej. 10.00 = 10%
  isActive              Boolean  @default(true) @map("is_active")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  stages                ImmunotherapyDoseStage[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("immunotherapy_products")
}

// Etapa de dosis dentro de un producto: fase inicio (escalonada, qty fija) o
// mantención (qty = maintenanceDefaultQty del producto, precio ajustable por
// volumen). unitPrice de la etapa de mantención es el precio BASE al volumen
// maintenanceTargetMl; para otro volumen se ajusta proporcional lineal.
model ImmunotherapyDoseStage {
  id            Int      @id @default(autoincrement())
  productId     Int      @map("product_id")
  label         String   // "Primera dosis", "Dosis mantención"
  unitPrice     Decimal  @map("unit_price") @db.Decimal(15, 2)
  defaultQty    Int      @default(1) @map("default_qty")
  isMaintenance Boolean  @default(false) @map("is_maintenance") // la etapa ajustable por volumen
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  product       ImmunotherapyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([productId])
  @@map("immunotherapy_dose_stages")
}

model PatientPayment {
  id            Int      @id @default(autoincrement())
  patientId     Int      @map("patient_id")
  budgetId      Int?     @map("budget_id")
  amount        Decimal  @db.Decimal(15, 2)
  paymentDate   DateTime @default(now()) @map("payment_date")
  paymentMethod String   @map("payment_method") // Transfer, Cash, Card
  reference     String?       // Transaction ID or Receipt number
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  budget        Budget?  @relation(fields: [budgetId], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([budgetId])
  @@map("patient_payments")
}

model PatientAttachment {
  id          String         @id @default(cuid())
  patientId   Int            @map("patient_id")
  name        String
  type        AttachmentType @default(OTHER)
  driveFileId String         @map("drive_file_id")
  mimeType    String?        @map("mime_type")
  uploadedBy  Int            @map("uploaded_by")
  uploadedAt  DateTime       @default(now()) @map("uploaded_at")

  patient     Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploader    User           @relation(fields: [uploadedBy], references: [id])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@map("patient_attachments")
}

enum BudgetStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AttachmentType {
  CONSENT
  EXAM
  RECIPE
  OTHER
}

// ============================================================
// DTE (Documentos Tributarios Electrónicos) - Accounting
// ============================================================
// DTE PURCHASE & SALES DETAILS
// ============================================================

model DTEPurchaseDetail {
  id                    String    @id @default(uuid())
  registerNumber        Int       @map("register_number") // Nº field from CSV
  documentType          Int       @default(33) @map("document_type") // 33 = Factura de Compra
  purchaseType          String    @map("purchase_type") // "Compras del Giro", etc.
  providerRUT           String    @map("provider_rut") @db.VarChar(20)
  providerName          String    @map("provider_name")
  folio                 String    @map("folio") @db.VarChar(20)
  documentDate          DateTime  @db.Date @map("document_date")
  receiptDate           DateTime  @db.Date @map("receipt_date")
  acknowledgeDate       DateTime? @db.Date @map("acknowledge_date")
  period                String?   @map("period") @db.VarChar(6) // Format: YYYYMM
  
  // Financial amounts
  exemptAmount          Decimal   @default(0) @map("exempt_amount") @db.Decimal(15, 2)
  netAmount             Decimal   @default(0) @map("net_amount") @db.Decimal(15, 2)
  recoverableIVA        Decimal   @default(0) @map("recoverable_iva") @db.Decimal(15, 2)
  nonRecoverableIVA     Decimal   @default(0) @map("non_recoverable_iva") @db.Decimal(15, 2)
  nonRecoverableIVACode String?   @map("non_recoverable_iva_code") @db.VarChar(10)
  totalAmount           Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  fixedAssetNetAmount   Decimal   @default(0) @map("fixed_asset_net_amount") @db.Decimal(15, 2)
  commonUseIVA          Decimal   @default(0) @map("common_use_iva") @db.Decimal(15, 2)
  nonCreditableTax      Decimal   @default(0) @map("non_creditable_tax") @db.Decimal(15, 2)
  nonRetainedIVA        Decimal   @default(0) @map("non_retained_iva") @db.Decimal(15, 2)
  
  // Tobacco fields (usually zero)
  pureTobacco           Decimal   @default(0) @map("pure_tobacco") @db.Decimal(15, 2)
  cigaretteTobacco      Decimal   @default(0) @map("cigarette_tobacco") @db.Decimal(15, 2)
  elaboratedTobacco     Decimal   @default(0) @map("elaborated_tobacco") @db.Decimal(15, 2)
  
  // Other tax
  otherTaxCode          String?   @map("other_tax_code") @db.VarChar(10)
  otherTaxAmount        Decimal   @default(0) @map("other_tax_amount") @db.Decimal(15, 2)
  otherTaxRate          Decimal?  @map("other_tax_rate") @db.Decimal(5, 2)
  
  // Additional notes
  referenceDocNote      String?   @map("reference_doc_note") // NCE o NDE Sobre Fact. de Compra
  notes                 String?

  // Link to generated Expense (after DTE matcher runs)
  expenseId             Int?      @map("expense_id")
  matchedAt             DateTime? @map("matched_at")
  matchSource           String?   @map("match_source") // 'AUTO', 'MANUAL', 'RULE'

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  lineItems             DTELineItem[]
  expense               Expense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([providerRUT, folio])
  @@index([providerRUT])
  @@index([documentDate])
  @@index([expenseId])
  @@map("dte_purchase_details")
}

model DTESaleDetail {
  id                             String    @id @default(uuid())
  registerNumber                 Int       @map("register_number") // Nº field from CSV
  documentType                   Int       @map("document_type") // 41 = Boleta, 61 = Nota Crédito, etc.
  saleType                       String    @map("sale_type") // "Del Giro", etc.
  clientRUT                      String    @map("client_rut") @db.VarChar(20)
  clientName                     String    @map("client_name")
  folio                          String    @map("folio") @db.VarChar(20)
  documentDate                   DateTime  @db.Date @map("document_date")
  receiptDate                    DateTime  @db.Date @map("receipt_date")
  receiptAcknowledgeDate         DateTime? @db.Date @map("receipt_acknowledge_date")
  claimDate                      DateTime? @db.Date @map("claim_date")
  period                         String?   @map("period") @db.VarChar(6) // Format: YYYYMM
  
  // Financial amounts
  exemptAmount                   Decimal   @default(0) @map("exempt_amount") @db.Decimal(15, 2)
  netAmount                      Decimal   @default(0) @map("net_amount") @db.Decimal(15, 2)
  ivaAmount                      Decimal   @default(0) @map("iva_amount") @db.Decimal(15, 2)
  totalAmount                    Decimal   @default(0) @map("total_amount") @db.Decimal(15, 2)
  
  // IVA details
  totalRetainedIVA               Decimal   @default(0) @map("total_retained_iva") @db.Decimal(15, 2)
  partialRetainedIVA             Decimal   @default(0) @map("partial_retained_iva") @db.Decimal(15, 2)
  nonRetainedIVA                 Decimal   @default(0) @map("non_retained_iva") @db.Decimal(15, 2)
  ownIVA                         Decimal   @default(0) @map("own_iva") @db.Decimal(15, 2)
  thirdPartyIVA                  Decimal   @default(0) @map("third_party_iva") @db.Decimal(15, 2)
  lateIVA                        Decimal   @default(0) @map("late_iva") @db.Decimal(15, 2)
  
  // Commission details
  emitterRUT                     String?   @map("emitter_rut") @db.VarChar(20)
  commissionNetAmount            Decimal   @default(0) @map("commission_net_amount") @db.Decimal(15, 2)
  commissionExemptAmount         Decimal   @default(0) @map("commission_exempt_amount") @db.Decimal(15, 2)
  commissionIVA                  Decimal   @default(0) @map("commission_iva") @db.Decimal(15, 2)
  
  // Reference document
  referenceDocType               String?   @map("reference_doc_type") @db.VarChar(10)
  referenceDocFolio              String?   @map("reference_doc_folio") @db.VarChar(20)
  
  // Foreign buyer details
  foreignBuyerIdentifier         String?   @map("foreign_buyer_identifier") @db.VarChar(20)
  foreignBuyerNationality        String?   @map("foreign_buyer_nationality") @db.VarChar(50)
  
  // Special conditions
  constructorCreditAmount        Decimal   @default(0) @map("constructor_credit_amount") @db.Decimal(15, 2)
  freeTradeZoneAmount            Decimal   @default(0) @map("free_trade_zone_amount") @db.Decimal(15, 2)
  containerGuaranteeAmount       Decimal   @default(0) @map("container_guarantee_amount") @db.Decimal(15, 2)
  nonBillableAmount              Decimal   @default(0) @map("non_billable_amount") @db.Decimal(15, 2)
  internationalTransportAmount   Decimal   @default(0) @map("international_transport_amount") @db.Decimal(15, 2) // Venta Pasajes Transporte Internacional
  
  // Special indicators
  nonCostSaleIndicator           Int       @default(0) @map("non_cost_sale_indicator") // Indicador Venta sin Costo
  periodicServiceIndicator       Int       @default(0) @map("periodic_service_indicator") // Indicador Servicio Periódico
  totalPeriodAmount              Decimal   @default(0) @map("total_period_amount") @db.Decimal(15, 2) // Total Monto Periodo
  nationalTransportPassageAmount Decimal   @default(0) @map("national_transport_passage_amount") @db.Decimal(15, 2) // Venta Pasajes Transporte Nacional
  
  // Identifiers
  internalNumber                 Int?      @map("internal_number")
  branchCode                     String?   @map("branch_code") @db.VarChar(20)
  
  // Metadata
  origin                         String?   @map("origin") @db.VarChar(20) // "WEB", "MANUAL", etc.
  informativeNote                String?   @map("informative_note")
  paymentNote                    String?   @map("payment_note")
  notes                          String?

  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @default(now()) @updatedAt @map("updated_at")
  autoLinkAttempts               EventDteAutoLinkAttempt[]
  eventLinks                     EventDteSaleLink[]
  lineItems                      DTELineItem[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([folio, documentType])
  @@index([clientRUT])
  @@index([documentDate])
  @@index([documentType])
  @@index([documentDate, totalAmount])
  @@map("dte_sale_details")
}

model DTELineItem {
  id                String             @id @default(uuid())
  lineNumber        Int                @map("line_number")        // NroLinDet
  itemName          String             @map("item_name")          // NmbItem
  itemDescription   String?            @map("item_description")   // DscItem
  quantity          Decimal            @default(1) @map("quantity") @db.Decimal(15, 6) // QtyItem
  unit              String?            @map("unit") @db.VarChar(10) // UnmdItem
  unitPrice         Decimal            @default(0) @map("unit_price") @db.Decimal(15, 6) // PrcItem
  amount            Decimal            @default(0) @map("amount") @db.Decimal(15, 2) // MontoItem
  isExempt          Boolean            @default(false) @map("is_exempt") // IndExe = 1
  itemCode          String?            @map("item_code") @db.VarChar(50)  // CdgItem/VlrCodigo
  itemCodeType      String?            @map("item_code_type") @db.VarChar(20) // CdgItem/TpoCodigo
  discountPercent   Decimal?           @map("discount_percent") @db.Decimal(5, 2) // DescuentoPct
  discountAmount    Decimal?           @map("discount_amount") @db.Decimal(15, 2) // DescuentoMonto

  // Polymorphic FK: one of these is set
  dteSaleDetailId   String?            @map("dte_sale_detail_id")
  dtePurchaseDetailId String?          @map("dte_purchase_detail_id")

  createdAt         DateTime           @default(now()) @map("created_at")

  dteSaleDetail     DTESaleDetail?     @relation(fields: [dteSaleDetailId], references: [id], onDelete: Cascade)
  dtePurchaseDetail DTEPurchaseDetail? @relation(fields: [dtePurchaseDetailId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([dteSaleDetailId, lineNumber])
  @@unique([dtePurchaseDetailId, lineNumber])
  @@index([dteSaleDetailId])
  @@index([dtePurchaseDetailId])
  @@map("dte_line_items")
}

model EventDteSaleLink {
  id              BigInt        @id @default(autoincrement())
  eventId         Int           @map("event_id")
  dteSaleDetailId String        @unique @map("dte_sale_detail_id")
  status          String        @default("CONFIRMED") @db.VarChar(20)
  matchedBy       String        @map("matched_by") @db.VarChar(30)
  confidenceScore Decimal       @map("confidence_score") @db.Decimal(5, 2)
  matchedRUT      String?       @map("matched_rut") @db.VarChar(20)
  matchedName     String?       @map("matched_name")
  evidence        Json?
  createdBy       Int?          @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at")

  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dteSaleDetail   DTESaleDetail @relation(fields: [dteSaleDetailId], references: [id], onDelete: Cascade)
  creator         User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_sale_links")
}

model EventDteAutoLinkAttempt {
  id                     BigInt         @id @default(autoincrement())
  eventId                Int            @map("event_id")
  candidateDteSaleDetailId String?      @map("candidate_dte_sale_detail_id")
  status                 String         @db.VarChar(20)
  reason                 String
  confidenceScore        Decimal?       @map("confidence_score") @db.Decimal(5, 2)
  createdBy              Int?           @map("created_by")
  createdAt              DateTime       @default(now()) @map("created_at")

  event                  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  candidateDteSaleDetail DTESaleDetail? @relation(fields: [candidateDteSaleDetailId], references: [id], onDelete: SetNull)
  creator                User?          @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId, createdAt(sort: Desc)])
  @@index([candidateDteSaleDetailId])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_auto_link_attempts")
}

model EventDteMatchReview {
  id              BigInt   @id @default(autoincrement())
  eventId         Int      @map("event_id")
  action          String   @db.VarChar(20)
  hypothesisKind  String?  @map("hypothesis_kind") @db.VarChar(20)
  dteSaleDetailIds Json    @map("dte_sale_detail_ids")
  hypothesis      Json?
  createdBy       Int?     @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator         User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([eventId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("event_dte_match_reviews")
}

// ============================================================
// DTE SYNC LOGS
// ============================================================

model DTESyncLog {
  id                String    @id @default(uuid())
  period            String    @db.VarChar(6)                        // YYYYMM format (e.g., "202602")
  docTypes          String    @db.VarChar(50)                       // "sales" | "purchases" | "both"
  status            String    @default("PENDING") @db.VarChar(20)   // PENDING | SUCCESS | PARTIAL | FAILED
  totalProcessed    Int       @default(0) @map("total_processed")   // Total rows processed across all types
  totalInserted     Int       @default(0) @map("total_inserted")
  totalUpdated      Int       @default(0) @map("total_updated")
  totalSkipped      Int       @default(0) @map("total_skipped")
  salesInserted     Int       @default(0) @map("sales_inserted")
  purchasesInserted Int       @default(0) @map("purchases_inserted")
  errorMessage      String?   @map("error_message")
  triggerSource     String?   @db.VarChar(20)                       // "cron" | "manual" | "user"
  triggerUserId     String?   @map("trigger_user_id")               // User ID if manual trigger
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime? @map("completed_at")
  
  // Access policies
  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([period])
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("dte_sync_logs")
}

enum DTEType {
  PURCHASE
  SALE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CompensationAllocationType {
  MANUAL_ADJUST
  ORIGINAL
  ROLLOVER_IN
  ROLLOVER_OUT
}

model TransactionCategory {
  id                   Int                         @id @default(autoincrement())
  name                 String
  color                String?
  icon                 String?
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  transactions         FinancialTransaction[]
  autoRules            FinancialAutoCategoryRule[]
  compensationProfiles CompensationProfile[]
  services             Service[]
  expenseServices      ExpenseService[]

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@map("transaction_categories")
}

model FinancialAutoCategoryRule {
  id                  Int                 @id @default(autoincrement())
  name                String
  type                TransactionType     @default(EXPENSE)
  counterpartId       Int?                @map("counterpart_id")
  categoryId          Int                 @map("category_id")
  minAmount           Decimal?            @map("min_amount") @db.Decimal(19, 4)
  maxAmount           Decimal?            @map("max_amount") @db.Decimal(19, 4)
  amountsExact        Decimal[]           @default([]) @map("amounts_exact") @db.Decimal(19, 4)
  paymentMethods      String[]            @default([]) @map("payment_methods")
  matchAmountOn       String              @default("net") @map("match_amount_on")
  commentContains     String?             @map("comment_contains")
  descriptionContains String?             @map("description_contains")
  isActive            Boolean             @default(true) @map("is_active")
  priority            Int                 @default(0)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  counterpart         Counterpart?        @relation(fields: [counterpartId], references: [id], onDelete: Cascade)
  category            TransactionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([counterpartId])
  @@index([categoryId])
  @@index([isActive])
  @@map("financial_auto_category_rules")
}

model FinancialTransaction {
  id               Int                              @id @default(autoincrement())
  date             DateTime
  description      String
  amount           Decimal                          @db.Decimal(19, 4)
  type             TransactionType
  sourceId         String?                          @map("source_id")
  categoryId       Int?                             @map("category_id")
  counterpartId    Int?                             @map("counterpart_id")
  category         TransactionCategory?             @relation(fields: [categoryId], references: [id])
  counterpart      Counterpart?                     @relation(fields: [counterpartId], references: [id])
  allocations      FinancialTransactionAllocation[]
  loanSchedules    LoanSchedule[]
  serviceSchedules ServiceSchedule[]
  comment          String?

  createdAt        DateTime                         @default(now()) @map("created_at")
  updatedAt        DateTime                         @updatedAt @map("updated_at")

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([counterpartId])
  @@map("financial_transactions")
}

model CompensationProfile {
  id            Int                              @id @default(autoincrement())
  name          String
  categoryId    Int                              @map("category_id")
  counterpartId Int?                             @map("counterpart_id")
  isActive      Boolean                          @default(true) @map("is_active")
  timezone      String                           @default("America/Santiago")
  createdAt     DateTime                         @default(now()) @map("created_at")
  updatedAt     DateTime                         @updatedAt @map("updated_at")

  category      TransactionCategory              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  counterpart   Counterpart?                     @relation(fields: [counterpartId], references: [id], onDelete: SetNull)
  budgets       CompensationPeriodBudget[]
  allocations   FinancialTransactionAllocation[]

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([categoryId])
  @@index([counterpartId])
  @@index([isActive])
  @@map("compensation_profiles")
}

model CompensationPeriodBudget {
  id         Int                 @id @default(autoincrement())
  profileId  Int                 @map("profile_id")
  period     String              @db.VarChar(7) // YYYY-MM
  baseAmount Decimal             @map("base_amount") @db.Decimal(19, 4)
  isLocked   Boolean             @default(false) @map("is_locked")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  profile    CompensationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@unique([profileId, period])
  @@index([profileId])
  @@index([period])
  @@map("compensation_period_budgets")
}

model FinancialTransactionAllocation {
  id                 Int                              @id @default(autoincrement())
  transactionId      Int                              @map("transaction_id")
  profileId          Int                              @map("profile_id")
  period             String                           @db.VarChar(7) // YYYY-MM
  amount             Decimal                          @db.Decimal(19, 4)
  allocationType     CompensationAllocationType       @default(MANUAL_ADJUST) @map("allocation_type")
  sourceAllocationId Int?                             @map("source_allocation_id")
  createdAt          DateTime                         @default(now()) @map("created_at")
  updatedAt          DateTime                         @updatedAt @map("updated_at")

  transaction        FinancialTransaction             @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  profile            CompensationProfile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sourceAllocation   FinancialTransactionAllocation?  @relation("AllocationSource", fields: [sourceAllocationId], references: [id], onDelete: SetNull)
  derivedAllocations FinancialTransactionAllocation[] @relation("AllocationSource")

  // Access policies
  @@allow('all', auth().status == 'ACTIVE')

  @@index([transactionId])
  @@index([profileId])
  @@index([period])
  @@index([sourceAllocationId])
  @@map("financial_transaction_allocations")
}

enum PatientCampaignRecipientStatus {
  PENDING
  SENT
  INFO_REQUESTED
  IN_NEGOTIATION
  ACCEPTED
  DISMISSED
  NO_RESPONSE
}

model PatientCampaign {
  id              Int                         @id @default(autoincrement())
  name            String
  description     String?
  messageTemplate String?                     @map("message_template")
  imageUrl        String?                     @map("image_url")
  isActive        Boolean                     @default(true) @map("is_active")
  createdBy       Int?                        @map("created_by")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @default(now()) @updatedAt @map("updated_at")

  recipients      PatientCampaignRecipient[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([isActive])
  @@map("patient_campaigns")
}

model PatientCampaignRecipient {
  id            Int                            @id @default(autoincrement())
  campaignId    Int                            @map("campaign_id")
  patientRut    String                         @map("patient_rut") @db.VarChar(20)
  patientName   String?                        @map("patient_name")
  patientPhone  String?                        @map("patient_phone")
  status        PatientCampaignRecipientStatus @default(PENDING)
  notes         String?
  sentAt        DateTime?                      @map("sent_at")
  respondedAt   DateTime?                      @map("responded_at")
  updatedBy     Int?                           @map("updated_by")
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @default(now()) @updatedAt @map("updated_at")

  campaign      PatientCampaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([campaignId, patientRut])
  @@index([patientRut])
  @@index([status])
  @@index([campaignId])
  @@map("patient_campaign_recipients")
}

// ============================================================
// OUTREACH (Schools/Educational establishments outreach module)
// ============================================================

enum OutreachDependencia {
  MUNICIPAL
  PARTICULAR_SUBVENCIONADO
  PARTICULAR_PAGADO
  SLEP
  CORPORACION_MUNICIPAL
  OTRO
}

enum OutreachStatus {
  SIN_CONTACTAR
  CONTACTADO
  SIN_RESPUESTA
  RESPONDIO_INTERES
  RESPONDIO_MAS_INFO
  RESPONDIO_DESISTIO
  REUNION_AGENDADA
  CONVENIO_FIRMADO
  DESCARTADO
}

enum OutreachPriority {
  ALTA
  MEDIA
  BAJA
}

enum OutreachProspectType {
  COLEGIO
  EMPRESA
  MUNICIPIO
  INSTITUCION
  UNIVERSIDAD
  OTRO
}

enum OutreachProspectSource {
  MINEDUC
  GOOGLE_PLACES
  CRAWLER
  APOLLO
  HUNTER
  MANUAL
}

enum OutreachInteractionType {
  EMAIL_ENVIADO
  EMAIL_RECIBIDO
  LLAMADA_REALIZADA
  LLAMADA_RECIBIDA
  WHATSAPP
  REUNION_PRESENCIAL
  REUNION_ONLINE
  CHARLA_REALIZADA
  NOTA_INTERNA
}

enum OutreachCampaignStatus {
  BORRADOR
  REVISION
  ENVIANDO
  COMPLETADA
  PAUSADA
  CANCELADA
}

enum OutreachDeliveryStatus {
  PENDIENTE
  ENVIADO
  ERROR
  REBOTADO
  ABIERTO
  RESPONDIDO
}

model OutreachEstablishment {
  // ID semantically: external prospect id.
  // Colegios -> RBD MINEDUC (numeric string).
  // Empresas Google Places -> "gp:<placeId>".
  // Manual -> uuid or "manual:<slug>".
  rbd                  String                   @id @db.VarChar(64)
  nombre               String
  tipo                 OutreachProspectType     @default(COLEGIO)
  fuente               OutreachProspectSource   @default(MINEDUC)
  dependencia          OutreachDependencia      @default(OTRO)
  comuna               String
  ciudad               String?
  region               String
  direccion            String?
  telefonoMineduc      String?                  @map("telefono_mineduc")
  emailMineduc         String?                  @map("email_mineduc")
  directorMineduc      String?                  @map("director_mineduc")
  matriculaTotal       Int?                     @map("matricula_total")
  rural                Boolean                  @default(false)

  // Empresa-specific
  googlePlaceId        String?                  @unique @map("google_place_id")
  categoria            String?
  dominio              String?
  rating               Float?
  totalReviews         Int?                     @map("total_reviews")
  estadoNegocio        String?                  @map("estado_negocio")
  linkedinUrl          String?                  @map("linkedin_url")

  // Enrichment metadata
  apolloOrgId          String?                  @map("apollo_org_id")
  apolloLastFetchedAt  DateTime?                @map("apollo_last_fetched_at")
  hunterLastFetchedAt  DateTime?                @map("hunter_last_fetched_at")
  hunterEmailPattern   String?                  @map("hunter_email_pattern")
  crawledAt            DateTime?                @map("crawled_at")
  crawlSuccess         Boolean                  @default(false) @map("crawl_success")
  score                Int                      @default(0)

  // Manual enrichment
  websiteUrl           String?                  @map("website_url")
  emailsAdicionales    String[]                 @default([]) @map("emails_adicionales")
  telefonosAdicionales String[]                 @default([]) @map("telefonos_adicionales")
  notas                String?
  prioridad            OutreachPriority         @default(MEDIA)
  etiquetas            String[]                 @default([])

  estado               OutreachStatus           @default(SIN_CONTACTAR)
  ultimoContactoAt     DateTime?                @map("ultimo_contacto_at")

  activo               Boolean                  @default(true)
  importadoEn          DateTime                 @default(now()) @map("importado_en")
  actualizadoEn        DateTime                 @default(now()) @updatedAt @map("actualizado_en")

  contactos            OutreachContact[]
  interacciones        OutreachInteraction[]
  envios               OutreachEmailDelivery[]

  @@index([estado])
  @@index([dependencia])
  @@index([comuna])
  @@index([prioridad])
  @@index([activo])
  @@index([tipo])
  @@index([fuente])
  @@index([dominio])
  @@index([score])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_establishments")
}

model OutreachContact {
  id                  Int                       @id @default(autoincrement())
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  nombre              String
  cargo               String
  email               String?
  telefono            String?
  esPrincipal         Boolean                   @default(false) @map("es_principal")
  notas               String?
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")

  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  interacciones       OutreachInteraction[]
  envios              OutreachEmailDelivery[]

  @@index([establecimientoRbd])
  @@index([email])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_contacts")
}

model OutreachInteraction {
  id                  Int                       @id @default(autoincrement())
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  contactoId          Int?                      @map("contacto_id")
  tipo                OutreachInteractionType
  fecha               DateTime
  asunto              String?
  contenido           String
  emailDesde          String?                   @map("email_desde")
  emailHacia          String?                   @map("email_hacia")
  resultado           String?
  creadoPorUserId     Int?                      @map("creado_por_user_id")
  creadoPorNombre     String?                   @map("creado_por_nombre")
  createdAt           DateTime                  @default(now()) @map("created_at")

  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  contacto            OutreachContact?          @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  @@index([establecimientoRbd])
  @@index([contactoId])
  @@index([tipo])
  @@index([fecha])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_interactions")
}

model OutreachEmailCampaign {
  id                  Int                       @id @default(autoincrement())
  nombre              String
  asunto              String
  cuerpoHtml          String                    @map("cuerpo_html")
  cuerpoTexto         String                    @map("cuerpo_texto")
  fromEmail           String                    @map("from_email")
  fromNombre          String                    @map("from_nombre")
  replyTo             String?                   @map("reply_to")
  filtros             Json                      @default("{}")
  ratePerHour         Int                       @default(50) @map("rate_per_hour")
  estado              OutreachCampaignStatus    @default(BORRADOR)

  totalDestinatarios  Int                       @default(0) @map("total_destinatarios")
  enviados            Int                       @default(0)
  errores             Int                       @default(0)
  respondidos         Int                       @default(0)

  createdByUserId     Int?                      @map("created_by_user_id")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")
  enviadoEn           DateTime?                 @map("enviado_en")

  envios              OutreachEmailDelivery[]

  @@index([estado])
  @@index([createdByUserId])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_email_campaigns")
}

model OutreachEmailDelivery {
  id                  Int                       @id @default(autoincrement())
  campaignId          Int                       @map("campaign_id")
  establecimientoRbd  String                    @map("establecimiento_rbd") @db.VarChar(64)
  contactoId          Int?                      @map("contacto_id")
  emailDestinatario   String                    @map("email_destinatario")
  asuntoRender        String?                   @map("asunto_render")
  cuerpoHtmlRender    String?                   @map("cuerpo_html_render")
  cuerpoTextoRender   String?                   @map("cuerpo_texto_render")
  estado              OutreachDeliveryStatus    @default(PENDIENTE)
  errorMensaje        String?                   @map("error_mensaje")
  intentos            Int                       @default(0)
  enviadoEn           DateTime?                 @map("enviado_en")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @default(now()) @updatedAt @map("updated_at")

  campaign            OutreachEmailCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  establishment       OutreachEstablishment     @relation(fields: [establecimientoRbd], references: [rbd], onDelete: Cascade)
  contacto            OutreachContact?          @relation(fields: [contactoId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([establecimientoRbd])
  @@index([estado])

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_email_deliveries")
}

model OutreachImportLog {
  id                Int       @id @default(autoincrement())
  source            String
  fileUrl           String?   @map("file_url")
  totalRows         Int       @default(0) @map("total_rows")
  nuevos            Int       @default(0)
  actualizados      Int       @default(0)
  inactivos         Int       @default(0)
  errores           Int       @default(0)
  errorDetalle      String?   @map("error_detalle")
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  createdByUserId   Int?      @map("created_by_user_id")

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("outreach_import_logs")
}

// ============================================================
// WHATSAPP CLOUD API (Meta official)
// ============================================================

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum WaMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACTS
  INTERACTIVE
  BUTTON
  TEMPLATE
  REACTION
  SYSTEM
  UNSUPPORTED
}

enum WaConversationStatus {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
}

enum WaTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
  PAUSED
}

enum WaTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

model WaBusinessAccount {
  id                  Int       @id @default(autoincrement())
  wabaId              String    @unique @map("waba_id")
  metaBusinessId      String?   @map("meta_business_id")
  appId               String?   @map("app_id")
  appSecret           String?   @map("app_secret")
  systemUserToken     String?   @map("system_user_token")
  webhookVerifyToken  String?   @map("webhook_verify_token")
  graphApiVersion     String    @default("v21.0") @map("graph_api_version")
  displayName         String?   @map("display_name")
  active              Boolean   @default(true)
  // Meta Commerce catalog id linked to this WABA. Set to enable
  // single-product / multi-product (MPM) interactive messages. Configured
  // once in Meta Business Suite and stored here; we do not manage the
  // catalog itself, only reference it.
  commerceCatalogId   String?   @map("commerce_catalog_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  phoneNumbers        WaPhoneNumber[]
  templates           WaTemplate[]
  broadcasts          WaBroadcast[]
  accountEvents       WaAccountEvent[]

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_business_accounts")
}

model WaPhoneNumber {
  id                  Int       @id @default(autoincrement())
  accountId           Int       @map("account_id")
  phoneNumberId       String    @unique @map("phone_number_id")
  displayPhoneNumber  String    @map("display_phone_number")
  label               String?
  qualityRating       String?   @map("quality_rating")
  active              Boolean   @default(true)
  // Onboarding flow used to provision this phone:
  //   "coexistence"      — Meta 2025 Coexistence (WA Business app keeps using SIM,
  //                         Cloud API mirrors via Messaging Echoes; 5 mps cap)
  //   "embedded_signup"  — full Embedded Signup, phone exclusive to Cloud API
  //   "migration"        — addMigratingPhoneNumber + request_code + register flow
  //   null               — legacy / manual upsert
  onboardingFlow      String?   @map("onboarding_flow")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  account             WaBusinessAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages            WaMessage[]
  conversations       WaConversationChannel[]
  scheduledMessages   WaScheduledMessage[]
  broadcasts          WaBroadcast[]
  accountEvents       WaAccountEvent[]

  @@index([accountId])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_phone_numbers")
}

model WaContact {
  id                  Int       @id @default(autoincrement())
  phoneE164           String    @unique @map("phone_e164")
  name                String?
  pushName            String?   @map("push_name")
  optInStatus         String    @default("UNKNOWN") @map("opt_in_status")
  notas               String?
  etiquetas           String[]  @default([])
  patientRut          String?   @map("patient_rut") @db.VarChar(20)
  metadata            Json      @default("{}")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  // user_preferences webhook (per-category opt-in/out, e.g. marketing)
  marketingOptIn      Boolean?  @map("marketing_opt_in")
  marketingOptInAt    DateTime? @map("marketing_opt_in_at")
  // Block status (set after successful POST /{phone-id}/block_users)
  blockedAt           DateTime? @map("blocked_at")
  blockedByUserId     Int?      @map("blocked_by_user_id")
  // Meta 2026: Business-Scoped User ID (BSUID) — replaces wa_id when contact
  // adopts a username. Stored alongside phoneE164 for forward compatibility.
  bsuid               String?   @unique

  conversations       WaConversation[]
  messages            WaMessage[]
  scheduledMessages   WaScheduledMessage[]

  @@index([patientRut])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_contacts")
}

model WaConversation {
  id                  Int                   @id @default(autoincrement())
  contactId           Int                   @map("contact_id")
  status              WaConversationStatus  @default(OPEN)
  assignedToUserId    Int?                  @map("assigned_to_user_id")
  unreadCount         Int                   @default(0) @map("unread_count")
  lastInboundAt       DateTime?             @map("last_inbound_at")
  lastMessageAt       DateTime?             @map("last_message_at")
  lastMessagePreview  String?               @map("last_message_preview")
  notas               String?
  etiquetas           String[]              @default([])
  // Per-conversation push-notification mute. Webhook handler skips
  // broadcastPushNotification when set in the past (or null=unmuted).
  // Storing a timestamp instead of a boolean lets the UI offer
  // "mute until tomorrow 9am" later without a schema change.
  mutedUntil          DateTime?             @map("muted_until")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at")

  contact             WaContact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channels            WaConversationChannel[]
  messages            WaMessage[]
  scheduledMessages   WaScheduledMessage[]

  @@unique([contactId])
  @@index([status])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_conversations")
}

model WaConversationChannel {
  id                  Int            @id @default(autoincrement())
  conversationId      Int            @map("conversation_id")
  phoneNumberId       Int            @map("phone_number_id")
  lastMessageAt       DateTime?      @map("last_message_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  conversation        WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  phoneNumber         WaPhoneNumber  @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([conversationId, phoneNumberId])
  @@index([phoneNumberId])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_conversation_channels")
}

model WaMessage {
  id                  Int                  @id @default(autoincrement())
  conversationId      Int                  @map("conversation_id")
  contactId           Int                  @map("contact_id")
  phoneNumberId       Int                  @map("phone_number_id")
  metaMessageId       String?              @map("meta_message_id")
  direction           WaMessageDirection
  type                WaMessageType
  status              WaMessageStatus      @default(PENDING)
  body                String?
  mediaUrl            String?              @map("media_url")
  mediaMimeType       String?              @map("media_mime_type")
  mediaCaption        String?              @map("media_caption")
  templateName        String?              @map("template_name")
  templateLanguage    String?              @map("template_language")
  payload             Json                 @default("{}")
  errorCode           String?              @map("error_code")
  errorTitle          String?              @map("error_title")
  errorDetails        String?              @map("error_details")
  sentByUserId        Int?                 @map("sent_by_user_id")
  contextMetaMessageId String?             @map("context_meta_message_id")
  // Status enrichment (Meta status webhook)
  conversationWindowId String?             @map("conversation_window_id")
  conversationOrigin  String?              @map("conversation_origin")
  pricingBillable     Boolean?             @map("pricing_billable")
  pricingModel        String?              @map("pricing_model")
  pricingCategory     String?              @map("pricing_category")
  bizCallbackData     String?              @map("biz_callback_data")
  // Click-to-WhatsApp ad referral attribution (inbound only)
  referralSourceUrl   String?              @map("referral_source_url")
  referralSourceType  String?              @map("referral_source_type")
  referralSourceId    String?              @map("referral_source_id")
  referralCtwaClid    String?              @map("referral_ctwa_clid")
  referralHeadline    String?              @map("referral_headline")
  referralBodyText    String?              @map("referral_body_text")
  referralMediaType   String?              @map("referral_media_type")
  referralMediaUrl    String?              @map("referral_media_url")
  timestamp           DateTime
  deliveredAt         DateTime?            @map("delivered_at")
  readAt              DateTime?            @map("read_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at")

  conversation        WaConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact             WaContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneNumber         WaPhoneNumber        @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([metaMessageId])
  @@index([conversationId])
  @@index([contactId])
  @@index([phoneNumberId])
  @@index([timestamp])
  @@index([direction, status])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_messages")
}

model WaTemplate {
  id                  Int                 @id @default(autoincrement())
  accountId           Int                 @map("account_id")
  name                String
  language            String
  category            WaTemplateCategory  @default(UTILITY)
  status              WaTemplateStatus    @default(PENDING)
  components          Json                @default("[]")
  qualityScore        String?             @map("quality_score")
  metaTemplateId      String?             @map("meta_template_id")
  syncedAt            DateTime?           @map("synced_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")

  account             WaBusinessAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name, language])
  @@index([status])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_templates")
}

model WaWebhookLog {
  id                  Int       @id @default(autoincrement())
  receivedAt          DateTime  @default(now()) @map("received_at")
  signatureValid      Boolean   @map("signature_valid")
  payload             Json
  processed           Boolean   @default(false)
  errorMessage        String?   @map("error_message")
  eventCount          Int       @default(0) @map("event_count")

  @@index([receivedAt])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_webhook_logs")
}

// ── Saved interactive entities (curated catalog) ────────────────────────────

model WaSavedLocation {
  id          Int      @id @default(autoincrement())
  name        String
  latitude    Float
  longitude   Float
  address     String?
  isDefault   Boolean  @default(false) @map("is_default")
  archived    Boolean  @default(false)
  createdByUserId Int  @map("created_by_user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([archived])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_saved_locations")
}

model WaSavedInteractiveList {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  headerText   String?  @map("header_text")
  bodyText     String   @map("body_text")
  footerText   String?  @map("footer_text")
  buttonText   String   @map("button_text")
  sections     Json
  archived     Boolean  @default(false)
  hitCount     Int      @default(0) @map("hit_count")
  lastUsedAt   DateTime? @map("last_used_at")
  createdByUserId Int   @map("created_by_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([archived])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_saved_interactive_lists")
}

model WaSavedFlow {
  id              Int      @id @default(autoincrement())
  accountId       Int?     @map("account_id")
  name            String
  description     String?
  flowId          String   @map("flow_id")
  flowToken       String?  @map("flow_token")
  initialScreen   String?  @map("initial_screen")
  defaultBody     String   @map("default_body")
  defaultHeader   String?  @map("default_header")
  defaultFooter   String?  @map("default_footer")
  defaultCta      String   @default("Iniciar") @map("default_cta")
  // Meta-synced metadata (refreshed via syncFlows)
  metaStatus      String?  @map("meta_status")
  metaCategories  String[] @default([]) @map("meta_categories")
  metaHealth      String?  @map("meta_health")
  metaSyncedAt    DateTime? @map("meta_synced_at")
  archived        Boolean  @default(false)
  hitCount        Int      @default(0) @map("hit_count")
  lastUsedAt      DateTime? @map("last_used_at")
  createdByUserId Int      @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([flowId])
  @@index([archived])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_saved_flows")
}

enum WaSnippetKind {
  TEXT
  MEDIA_DOCUMENT
  MEDIA_IMAGE
  MEDIA_VIDEO
  MEDIA_AUDIO
  MEDIA_STICKER
  CTA_URL
  REPLY_BUTTONS
}

model WaSnippet {
  id                  Int            @id @default(autoincrement())
  accountId           Int?           @map("account_id")
  kind                WaSnippetKind
  category            String?
  name                String
  description         String?
  shortcut            String?        // e.g. "/horario" for inline insert
  // TEXT / CTA_URL / REPLY_BUTTONS / media caption
  bodyText            String?        @map("body_text")
  // CTA_URL
  ctaUrl              String?        @map("cta_url")
  ctaButtonText       String?        @map("cta_button_text")
  ctaHeader           String?        @map("cta_header")
  ctaFooter           String?        @map("cta_footer")
  // REPLY_BUTTONS — JSON array of {id, title}
  replyButtons        Json?          @map("reply_buttons")
  replyHeader         String?        @map("reply_header")
  replyFooter         String?        @map("reply_footer")
  // Media (Meta media id is account-scoped, valid 30 days)
  mediaHandle         String?        @map("media_handle")
  mediaHandleExpiresAt DateTime?     @map("media_handle_expires_at")
  mediaUrl            String?        @map("media_url")
  mediaMimeType       String?        @map("media_mime_type")
  mediaFilename       String?        @map("media_filename")
  mediaSize           Int?           @map("media_size")
  mediaUploadedByPhoneNumberId Int?  @map("media_uploaded_by_phone_number_id")
  // Variables {{1}}, {{2}}, …
  variables           String[]       @default([])
  archived            Boolean        @default(false)
  hitCount            Int            @default(0) @map("hit_count")
  lastUsedAt          DateTime?      @map("last_used_at")
  createdByUserId     Int            @map("created_by_user_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at")

  @@index([archived, kind])
  @@index([category])
  @@index([shortcut])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_snippets")
}

enum WaScheduledStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum WaAccountEventKind {
  ACCOUNT_ALERT
  ACCOUNT_REVIEW
  ACCOUNT_SETTINGS
  ACCOUNT_UPDATE
  BUSINESS_CAPABILITY
  BUSINESS_STATUS
  SECURITY
  PARTNER_SOLUTIONS
  PAYMENT_CONFIG
  USER_PREFERENCES
  PHONE_QUALITY
  PHONE_NAME
  TEMPLATE_STATUS
  TEMPLATE_QUALITY
  TEMPLATE_CATEGORY
  AUTOMATIC
  TRACKING
  OTHER
}

model WaAccountEvent {
  id                   Int                  @id @default(autoincrement())
  accountId            Int?                 @map("account_id")
  phoneNumberId        Int?                 @map("phone_number_id")
  kind                 WaAccountEventKind
  field                String
  severity             String               @default("info")
  title                String
  description          String?
  payload              Json
  acknowledged         Boolean              @default(false)
  acknowledgedAt       DateTime?            @map("acknowledged_at")
  acknowledgedByUserId Int?                 @map("acknowledged_by_user_id")
  receivedAt           DateTime             @default(now()) @map("received_at")

  account              WaBusinessAccount?   @relation(fields: [accountId], references: [id], onDelete: SetNull)
  phoneNumber          WaPhoneNumber?       @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)

  @@index([acknowledged, receivedAt])
  @@index([accountId])
  @@index([severity])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_account_events")
}

enum WaBroadcastStatus {
  DRAFT
  QUEUED
  SENDING
  DONE
  CANCELLED
  FAILED
}

enum WaBroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model WaBroadcast {
  id                   Int                  @id @default(autoincrement())
  accountId            Int                  @map("account_id")
  phoneNumberId        Int                  @map("phone_number_id")
  name                 String
  templateName         String               @map("template_name")
  templateLanguage     String               @map("template_language")
  status               WaBroadcastStatus    @default(DRAFT)
  scheduledAt          DateTime?            @map("scheduled_at")
  startedAt            DateTime?            @map("started_at")
  finishedAt           DateTime?            @map("finished_at")
  totalRecipients      Int                  @default(0) @map("total_recipients")
  sentCount            Int                  @default(0) @map("sent_count")
  failedCount          Int                  @default(0) @map("failed_count")
  rateLimitPerSecond   Int                  @default(5) @map("rate_limit_per_second")
  createdByUserId      Int                  @map("created_by_user_id")
  errorMessage         String?              @map("error_message")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at")

  account              WaBusinessAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  phoneNumber          WaPhoneNumber        @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  recipients           WaBroadcastRecipient[]

  @@index([status])
  @@index([scheduledAt])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_broadcasts")
}

model WaBroadcastRecipient {
  id              Int                          @id @default(autoincrement())
  broadcastId     Int                          @map("broadcast_id")
  phoneE164       String                       @map("phone_e164")
  variables       Json                         @default("[]")
  status          WaBroadcastRecipientStatus   @default(PENDING)
  sentMessageId   Int?                         @map("sent_message_id")
  metaMessageId   String?                      @map("meta_message_id")
  errorMessage    String?                      @map("error_message")
  attempts        Int                          @default(0)
  sentAt          DateTime?                    @map("sent_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @default(now()) @updatedAt @map("updated_at")

  broadcast       WaBroadcast                  @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, phoneE164])
  @@index([broadcastId, status])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_broadcast_recipients")
}

model WaScheduledMessage {
  id                   Int                @id @default(autoincrement())
  conversationId       Int                @map("conversation_id")
  contactId            Int                @map("contact_id")
  phoneNumberId        Int                @map("phone_number_id")
  scheduledAt          DateTime           @map("scheduled_at")
  status               WaScheduledStatus  @default(PENDING)
  type                 WaMessageType
  body                 String?
  templateName         String?            @map("template_name")
  templateLanguage     String?            @map("template_language")
  templateVars         Json               @default("[]") @map("template_vars")
  contextMetaMessageId String?            @map("context_meta_message_id")
  createdByUserId      Int                @map("created_by_user_id")
  sentMessageId        Int?               @map("sent_message_id")
  errorMessage         String?            @map("error_message")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at")

  conversation         WaConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact              WaContact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneNumber          WaPhoneNumber      @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([conversationId])
  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')
  @@map("wa_scheduled_messages")
}

// ─── Expenses ────────────────────────────────────────────────────────────────

enum ExpenseScope {
  BIOALERGIA
  PERSONAL
}

enum ExpenseStatus {
  PENDING
  PAID
  OVERDUE
  SKIPPED
}

enum ExpenseSource {
  MANUAL
  TEMPLATE
  TRANSACTION
}

enum ExpenseRecurrence {
  MONTHLY
  ONE_TIME
}

model ExpenseService {
  id                    Int                  @id @default(autoincrement())
  publicId              String               @unique @default(cuid()) @map("public_id")
  name                  String
  detail                String?
  scope                 ExpenseScope
  category              String?
  billingDay            Int?                 @map("billing_day")
  emissionDay           Int?                 @map("emission_day")
  dueDateRule           String?              @map("due_date_rule")
  defaultAmount         Decimal?             @map("default_amount") @db.Decimal(14, 2)
  isFixed               Boolean              @default(false) @map("is_fixed")
  recurrence            ExpenseRecurrence    @default(MONTHLY)
  startDate             DateTime?            @map("start_date") @db.Date
  endDate               DateTime?            @map("end_date") @db.Date
  isActive              Boolean              @default(true) @map("is_active")
  notes                 String?
  tags                  String[]
  transactionCategoryId Int?                 @map("transaction_category_id")
  counterpartId         Int?                 @map("counterpart_id")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at")

  expenses              Expense[]
  transactionCategory   TransactionCategory? @relation(fields: [transactionCategoryId], references: [id], onDelete: SetNull)
  counterpart           Counterpart?         @relation(fields: [counterpartId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@index([transactionCategoryId])
  @@index([counterpartId])
  @@map("expense_services")
}

model Expense {
  id             Int             @id @default(autoincrement())
  publicId       String          @unique @default(cuid()) @map("public_id")
  serviceId      Int?            @map("service_id")
  name           String
  detail         String?
  scope          ExpenseScope
  expenseMonth   String          @map("expense_month")
  dueDate        DateTime?       @map("due_date") @db.Date
  amountExpected Decimal         @map("amount_expected") @db.Decimal(14, 2)
  amountApplied  Decimal         @default(0) @map("amount_applied") @db.Decimal(14, 2)
  status         ExpenseStatus   @default(PENDING)
  source         ExpenseSource   @default(MANUAL)
  category       String?
  notes          String?
  tags           String[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")

  service        ExpenseService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  transactions   ExpenseTransaction[]
  // Reverse relation back to DTEPurchaseDetail.expense (added in the
  // utility-bills/expense session). Required by zenstack/Prisma; the
  // DB side already carries the FK via dte_purchase_details.expense_id.
  dtePurchaseDetails DTEPurchaseDetail[]

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@index([expenseMonth])
  @@index([scope])
  @@index([serviceId])
  @@map("expenses")
}

// ─── Utility Accounts ────────────────────────────────────────────────────────

enum UtilityProvider {
  ESSBIO
  CGE
  TELSUR
  MOVISTAR
  DOCTORALIA
  MEDIPASS
  MASVIDA
  PREVIRED
  SII
  TGR
  GASTOS_COMUNES
  OTHER

  @@schema("personal")
}

enum ProviderAuthMethod {
  NONE_PUBLIC
  RUT_PASSWORD
  CLAVE_UNICA
  CLAVE_TRIBUTARIA
  OAUTH
  API_KEY
  EMAIL_FORWARDING

  @@schema("personal")
}

model UtilityAccount {
  id               Int             @id @default(autoincrement())
  provider         UtilityProvider
  scope            ExpenseScope    @default(PERSONAL)
  serviceNumber    String          @unique @map("service_number") // Essbio: numero_servicio, CGE: CTA_CTO
  externalAccountId String?        @map("external_account_id") // Essbio: id_servicio (677471), requerido para /getDatos/facturacion
  label            String?         // e.g. "Casa San Pedro", "Clínica"

  // Cached from last API fetch
  clientName       String?         @map("client_name")
  address          String?
  lastFetchedAt    DateTime?       @map("last_fetched_at")
  lastAmount       Decimal?        @map("last_amount") @db.Decimal(15, 2)
  lastPreviousAmount Decimal?      @map("last_previous_amount") @db.Decimal(15, 2)

  // Optional link to ExpenseService for auto-generating monthly expenses
  expenseServiceId Int?            @map("expense_service_id")

  // Optional link to ProviderCredential for scrapers requiring auth
  credentialId     Int?            @map("credential_id")

  isActive         Boolean         @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")

  snapshots        UtilityBillSnapshot[]
  credential       ProviderCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([scope])
  @@index([credentialId])
  @@schema("personal")
  @@map("utility_accounts")
}

// Historial completo de cada fetch de boleta — para diferencias, tendencias, alertas.
model UtilityBillSnapshot {
  id               BigInt          @id @default(autoincrement())
  utilityAccountId Int             @map("utility_account_id")
  fetchedAt        DateTime        @default(now()) @map("fetched_at")
  source           String          @default("MANUAL") // 'CRON', 'MANUAL', 'EMAIL_PARSE', 'SCRAPE'

  // Standardized fields across providers
  currentAmount    Decimal?        @map("current_amount") @db.Decimal(15, 2)
  previousAmount   Decimal?        @map("previous_amount") @db.Decimal(15, 2)
  thirdAmount      Decimal?        @map("third_amount") @db.Decimal(15, 2)   // CGE devuelve 3 últimas
  currentDebt      Decimal?        @map("current_debt") @db.Decimal(15, 2)   // Essbio: deuda actual
  emissionDate     String?         @map("emission_date")                      // YYYY-MM-DD si lo da
  dueDate          String?         @map("due_date")                           // Essbio /corteNoPago EFecha (fecha corte por no pago)
  period           String?         @map("period")                             // Essbio FECFAC MM/YYYY — mes facturado
  folio            String?         @map("folio")                              // Essbio FOLIO (SII-xxx), dedupe key del historial
  consumption      Int?            @map("consumption")                        // Essbio CONSUMO m3
  reading          Int?            @map("reading")                            // Essbio LECTURA medidor
  lastPaymentJson  Json?           @map("last_payment_json")                  // {amount, date}
  observation      String?
  rawResponse      Json            @map("raw_response")                       // todo el response crudo
  errorMessage     String?         @map("error_message")                      // si falló parcial

  account          UtilityAccount  @relation(fields: [utilityAccountId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([utilityAccountId, fetchedAt])
  @@schema("personal")
  @@map("utility_bill_snapshots")
}

// Credenciales encriptadas para scrapers que requieren login.
// secret se guarda cifrado con KMS / pgcrypto / app-level encryption.
model ProviderCredential {
  id               Int                 @id @default(autoincrement())
  provider         UtilityProvider
  scope            ExpenseScope        @default(PERSONAL)
  authMethod       ProviderAuthMethod  @default(RUT_PASSWORD) @map("auth_method")
  label            String?
  identifier       String              // RUT, usuario, email, client_id
  secretEncrypted  String              @map("secret_encrypted")
  metadata         Json?               // cookies cache, last token, refresh_token, otp_seed
  isActive         Boolean             @default(true) @map("is_active")
  lastLoginAt      DateTime?           @map("last_login_at")
  lastErrorAt      DateTime?           @map("last_error_at")
  lastError        String?             @map("last_error")
  notes            String?
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at")

  accounts         UtilityAccount[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@unique([provider, identifier])
  @@index([provider])
  @@schema("personal")
  @@map("provider_credentials")
}

model ExpenseTransaction {
  id            Int      @id @default(autoincrement())
  expenseId     Int      @map("expense_id")
  transactionId Int      @map("transaction_id")
  amount        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  expense       Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')
  @@unique([expenseId, transactionId])
  @@map("expense_transactions")
}

// =====================================================================
// Skin-test exam reports — generic structured reports printable as PDF.
// One polymorphic ExamReport handles all 5 exam types via typed
// sections that hold reactions to specific allergens. Footer info
// (clinic name, address, phones, doctor signature) lives in
// ClinicSettings — never hardcoded — and conclusion phrases
// ("Piel reactiva valida el examen") live in ConclusionTemplate so
// staff can manage them from the UI.
// =====================================================================

enum ExamType {
  PATCH                  // Test de Parche (lecturas 48h y 96h)
  MULTITEST_PANELS       // Multitest Panel 1, 2, 3 y Acaros
  FOOD_PANEL             // Panel Alimentario I
  AEROALLERGENS_I        // Aeroalergenos I (Acaros, Epitelios, Polenes)
  AEROALLERGENS_II       // Aeroalergenos II
}

enum SkinReaction {
  NEGATIVA          // sin reacción (papule < threshold)
  DEBIL             // positiva débil
  MODERADA          // positiva moderada
  FUERTE            // positiva fuerte
}

model ExamReport {
  id                    Int                    @id @default(autoincrement())
  patientId             Int                    @map("patient_id")
  examType              ExamType               @map("exam_type")
  // Conclusion is denormalized so renaming/deleting a template never
  // mutates historical reports; the FK is bookkeeping only.
  conclusionText        String                 @map("conclusion_text")
  conclusionTemplateId  Int?                   @map("conclusion_template_id")
  // Methodology footer — defaults pulled from ClinicSettings at create
  // time but stored per-report so future settings changes don't
  // rewrite history.
  reagents              String?
  technique             String?
  notes                 String?                // e.g. "*solo se considera reacción positiva con pápula mayor a 3 mm"
  doctorName            String                 @map("doctor_name")
  doctorSpecialty       String                 @map("doctor_specialty")
  doctorRut             String?                @map("doctor_rut")
  // Validity-gate controls (mm pápula). Nullable to keep all historical
  // rows valid; new wizard writes them so reopening a report can
  // round-trip without re-deriving from the XLSX skin-test snapshot.
  // Feature is "live-but-quiet": old reports render `—` for these
  // fields, new ones persist whatever the operator submitted (XLSX
  // prefill or manual entry).
  histamineMm           Decimal?               @map("histamine_mm") @db.Decimal(5, 2)
  salineMm              Decimal?               @map("saline_mm")    @db.Decimal(5, 2)
  generatedAt           DateTime?              @map("generated_at")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at")
  createdById           Int?                   @map("created_by_id")

  patient               Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  conclusionTemplate    ConclusionTemplate?    @relation(fields: [conclusionTemplateId], references: [id], onDelete: SetNull)
  createdBy             User?                  @relation("ExamReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sections              ExamReportSection[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([patientId])
  @@index([examType])
  @@index([createdAt])
  @@map("exam_reports")
}

model ExamReportSection {
  id              Int                       @id @default(autoincrement())
  examReportId    Int                       @map("exam_report_id")
  // Logical key used by the renderer ("lectura_48h", "panel_1",
  // "polenes_arboles", "acaros", etc.) — keeps the PDF layout stable
  // even if the visible label is edited.
  sectionKey      String                    @map("section_key")
  label           String                    // visible "PANEL 1"
  position        Int                       @default(0)

  examReport      ExamReport                @relation(fields: [examReportId], references: [id], onDelete: Cascade)
  reactions       ExamReportReaction[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([examReportId])
  @@map("exam_report_sections")
}

model ExamReportReaction {
  id           Int                @id @default(autoincrement())
  sectionId    Int                @map("section_id")
  allergenId   String             @map("allergen_id")
  reaction     SkinReaction
  // Pápula in mm — preserves the raw reading; reaction enum is the
  // clinical interpretation (clinic threshold lives in ClinicSettings).
  papuleMm     Decimal?           @map("papule_mm") @db.Decimal(5, 2)
  notes        String?
  position     Int                @default(0)

  section      ExamReportSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  allergen     ClinicalAllergen   @relation(fields: [allergenId], references: [id], onDelete: Restrict)

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([sectionId])
  @@index([allergenId])
  @@map("exam_report_reactions")
}

model ConclusionTemplate {
  id          Int          @id @default(autoincrement())
  text        String       // "Piel reactiva valida el examen"
  examType    ExamType?    @map("exam_type")  // null = available for any exam type
  isDefault   Boolean      @default(false) @map("is_default")
  isActive    Boolean      @default(true) @map("is_active")
  position    Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")

  reports     ExamReport[]

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@index([examType])
  @@map("conclusion_templates")
}

model ClinicSettings {
  // Singleton — id pinned to 1 by application code; never insert another row.
  id                Int      @id @default(1)
  name              String   @default("Bioalergia")
  address           String   @default("San Martín 870, Edificio Caram, Torre B, Of. 208 A – 208 B, Concepción")
  phoneWhatsapp     String   @default("+569 30963316") @map("phone_whatsapp")
  phoneLandline     String   @default("(41) 33355293") @map("phone_landline")
  email             String   @default("contacto@bioalergia.cl")
  website           String   @default("www.bioalergia.cl")
  websiteSecondary  String   @default("www.jmmmartinez-alergia-inmunologia.com/") @map("website_secondary")
  defaultReagents   String   @default("Inmunotek - Diater España") @map("default_reagents")
  defaultTechnique  String   @default("Método Doan T Zeiss Modificado") @map("default_technique")
  doctorName        String   @default("DR JOSE MANUEL MARTINEZ M.") @map("doctor_name")
  doctorSpecialty   String   @default("ALERGOLOGO-INMUNOLOGO") @map("doctor_specialty")
  doctorRut         String?  @map("doctor_rut")
  // Prestador institucional (razón social + RUT) para encabezado de
  // presupuestos/consentimientos. Nullable → editable desde admin, sin hardcode.
  legalName         String?  @map("legal_name")
  legalRut          String?  @map("legal_rut")
  // Condiciones económicas / disclosures del presupuesto de inmunoterapia
  // (vigencia anual, renovación, ajuste proporcional 0,25 mL, no reembolsable,
  // suspensión, no garantía). Editable; se imprime al pie del PDF de presupuesto.
  immunoBudgetTerms String?  @map("immuno_budget_terms") @db.Text
  signatureUrl      String?  @map("signature_url") @db.Text
  papuleThresholdMm Decimal  @default(3.0) @map("papule_threshold_mm") @db.Decimal(5, 2)
  // Prestador Superintendencia de Salud N — printed under doctor's signature
  // block on every exam-report PDF. Free-text (Superintendencia issues alpha-
  // numeric codes); nullable so a fresh deploy renders "—" instead of "0".
  superintendenciaNumber String? @map("superintendencia_number")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@deny('all', auth() == null)
  @@allow('read', auth().status == 'ACTIVE')
  @@allow('update', auth().status == 'ACTIVE')

  @@map("clinic_settings")
}

// ============================================================================
// Ecommerce — catálogo público, carrito, checkout MercadoPago, sync MercadoLibre
// PG = source-of-truth catálogo. Haulmer se invoca post-venta sólo para DTE.
// ============================================================================

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum DocumentType {
  BOLETA
  FACTURA
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum OrderChannel {
  WEB
  MERCADO_LIBRE
}

enum PaymentProvider {
  MERCADO_PAGO
  MERCADO_LIBRE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CHARGED_BACK
}

enum MlListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ERROR
}

enum SalesChannel {
  WEB
  MERCADO_LIBRE
  UBER_EATS
  PEDIDOS_YA
  RAPPI
}

model ProductCategory {
  id            Int               @id @default(autoincrement())
  slug          String            @unique
  name          String
  description   String?
  parentId      Int?              @map("parent_id")
  displayOrder  Int               @default(0) @map("display_order")
  mlCategoryId  String?           @map("ml_category_id")
  imageUrl      String?           @map("image_url")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")

  parent        ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      ProductCategory[] @relation("ProductCategoryHierarchy")
  products      Product[]

  @@index([parentId])
  @@index([slug])

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("product_categories")
}

model Product {
  id                  Int                 @id @default(autoincrement())
  slug                String              @unique
  sku                 String              @unique
  name                String
  shortDescription    String?             @map("short_description")
  description         String?
  categoryId          Int?                @map("category_id")
  brand               String?
  priceClp            Int                 @map("price_clp")
  compareAtPriceClp   Int?                @map("compare_at_price_clp")
  costClp             Int?                @map("cost_clp")
  weightGrams         Int?                @map("weight_grams")
  barcode             String?
  requiresPrescription Boolean            @default(false) @map("requires_prescription")
  status              ProductStatus       @default(DRAFT)
  seoTitle            String?             @map("seo_title")
  seoDescription      String?             @map("seo_description")
  availableQty        Int                 @default(0) @map("available_qty")
  safetyStock         Int                 @default(2) @map("safety_stock")
  version             Int                 @default(0)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @default(now()) @updatedAt @map("updated_at")

  category            ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images              ProductImage[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  reservations        StockReservation[]
  mlListing           MlListing?
  channelPrices       ProductChannelPrice[]
  reviews             ProductReview[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([sku])

  @@deny('all', auth() == null && status != 'ACTIVE')
  @@allow('read', status == 'ACTIVE')
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("products")
}

model ProductReview {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  authorName    String    @map("author_name")
  authorEmail   String?   @map("author_email")
  rating        Int       // 1-5
  title         String?
  body          String
  verified      Boolean   @default(false)
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, status])
  @@index([status])

  @@allow('read', status == 'APPROVED')
  @@allow('create', true)
  @@allow('read,update,delete', auth().status == 'ACTIVE')

  @@map("product_reviews")
}

model ProductImage {
  id          Int       @id @default(autoincrement())
  productId   Int       @map("product_id")
  r2Key       String    @map("r2_key")
  cdnUrl      String    @map("cdn_url")
  alt         String?
  position    Int       @default(0)
  width       Int?
  height      Int?
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])

  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("product_images")
}

model StockReservation {
  id          Int                @id @default(autoincrement())
  productId   Int                @map("product_id")
  qty         Int
  cartId      Int?               @map("cart_id")
  orderId     Int?               @map("order_id")
  expiresAt   DateTime           @map("expires_at")
  status      ReservationStatus  @default(ACTIVE)
  createdAt   DateTime           @default(now()) @map("created_at")

  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  cart        Cart?              @relation(fields: [cartId], references: [id], onDelete: SetNull)
  order       Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([expiresAt, status])
  @@index([productId, status])
  @@index([cartId])
  @@index([orderId])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("stock_reservations")
}

model Cart {
  id          Int                @id @default(autoincrement())
  // SHA-256 hex hash de un token bearer de 32 bytes random (256 bits).
  // El token plano vive sólo en cookie httpOnly+Secure+SameSite=Lax `cart_token`.
  tokenHash   String             @unique @map("token_hash")
  userId      Int?               @map("user_id")
  currency    String             @default("CLP")
  expiresAt   DateTime?          @map("expires_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")

  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  items       CartItem[]
  reservations StockReservation[]

  @@index([userId])
  @@index([expiresAt])

  @@deny('all', auth() == null)
  @@allow('read,update,delete', auth().id == userId)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("carts")
}

model CartItem {
  id            Int       @id @default(autoincrement())
  cartId        Int       @map("cart_id")
  productId     Int       @map("product_id")
  qty           Int
  unitPriceClp  Int       @map("unit_price_clp")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  cart          Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([productId])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("cart_items")
}

model Order {
  id                Int                 @id @default(autoincrement())
  number            String              @unique
  cartId            Int?                @map("cart_id")
  userId            Int?                @map("user_id")
  customerEmail     String              @map("customer_email")
  customerRut       String?             @map("customer_rut")
  customerName      String              @map("customer_name")
  customerPhone     String?             @map("customer_phone")
  billingType       DocumentType        @default(BOLETA) @map("billing_type")
  shippingAddress   Json?               @map("shipping_address")
  subtotalClp       Int                 @map("subtotal_clp")
  shippingClp       Int                 @default(0) @map("shipping_clp")
  discountClp       Int                 @default(0) @map("discount_clp")
  totalClp          Int                 @map("total_clp")
  status            OrderStatus         @default(PENDING)
  channel           OrderChannel        @default(WEB)
  mlOrderId         String?             @unique @map("ml_order_id")
  dteFolio          String?             @map("dte_folio")
  dteType           String?             @map("dte_type")
  notes             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at")

  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  reservations      StockReservation[]

  @@index([status, createdAt])
  @@index([channel])
  @@index([customerEmail])
  @@index([userId])

  @@deny('all', auth() == null)
  @@allow('read', auth().id == userId)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("orders")
}

model OrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int       @map("order_id")
  productId       Int       @map("product_id")
  productSnapshot Json      @map("product_snapshot")
  qty             Int
  unitPriceClp    Int       @map("unit_price_clp")
  lineTotalClp    Int       @map("line_total_clp")
  createdAt       DateTime  @default(now()) @map("created_at")

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("order_items")
}

model Payment {
  id                  Int               @id @default(autoincrement())
  orderId             Int               @map("order_id")
  provider            PaymentProvider
  providerPaymentId   String?           @unique @map("provider_payment_id")
  idempotencyKey      String            @unique @map("idempotency_key")
  amountClp           Int               @map("amount_clp")
  status              PaymentStatus     @default(PENDING)
  rawPayload          Json?             @map("raw_payload")
  approvedAt          DateTime?         @map("approved_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @default(now()) @updatedAt @map("updated_at")

  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("payments")
}

model MlOauthToken {
  id                Int       @id @default(autoincrement())
  mlUserId          String    @unique @map("ml_user_id")
  accessTokenEnc    String    @map("access_token_enc")
  refreshTokenEnc   String    @map("refresh_token_enc")
  expiresAt         DateTime  @map("expires_at")
  scope             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("ml_oauth_tokens")
}

model MlListing {
  id              Int               @id @default(autoincrement())
  productId       Int               @unique @map("product_id")
  mlItemId        String            @unique @map("ml_item_id")
  status          MlListingStatus   @default(DRAFT)
  permalink       String?
  listingTypeId   String?           @map("listing_type_id")
  categoryId      String?           @map("category_id")
  lastSyncAt      DateTime?         @map("last_sync_at")
  lastError       String?           @map("last_error")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")

  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("ml_listings")
}

// Precio por canal de venta. Si no hay row → fallback Product.priceClp (web).
model ProductChannelPrice {
  id          Int           @id @default(autoincrement())
  productId   Int           @map("product_id")
  channel     SalesChannel
  priceClp    Int           @map("price_clp")
  url         String?
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at")

  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([channel])

  @@deny('all', auth() == null)
  @@allow('read', true)
  @@allow('create,update,delete', auth().status == 'ACTIVE')

  @@map("product_channel_prices")
}

model WebhookEvent {
  id              Int       @id @default(autoincrement())
  provider        String
  topic           String
  externalId      String    @map("external_id")
  signatureValid  Boolean   @default(false) @map("signature_valid")
  processedAt     DateTime? @map("processed_at")
  payload         Json
  error           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([provider, topic, externalId])
  @@index([processedAt])

  @@deny('all', auth() == null)
  @@allow('read,create,update,delete', auth().status == 'ACTIVE')

  @@map("webhook_events")
}
