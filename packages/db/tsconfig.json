{
  "compilerOptions": {
    // db is type-checked here and COMPILED by tsdown (.js + .d.ts). TypeScript
    // is purely a type-checker — no tsc emit, no composite, no tsbuildinfo
    // (golden 2026 monorepo pattern: the bundler owns compilation). Bundler
    // resolution accepts ZenStack's extensionless generated imports; the
    // hand-written source uses explicit `.ts` (allowImportingTsExtensions).
    // `module: preserve` is required — NodeNext rejects bundler resolution
    // (TS5095).
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "target": "esnext",
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": true,
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
