{
  "name": "@finanzas/db",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/zenstack/schema.mjs",
  "types": "./dist/zenstack/schema.d.mts",
  "exports": {
    ".": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs",
      "default": "./dist/client.mjs"
    },
    "./input": {
      "types": "./dist/zenstack/input.d.mts",
      "import": "./dist/zenstack/input.mjs",
      "default": "./dist/zenstack/input.mjs"
    },
    "./schema": {
      "types": "./dist/zenstack/schema.d.mts",
      "import": "./dist/zenstack/schema.mjs",
      "default": "./dist/zenstack/schema.mjs"
    },
    "./schema-lite": {
      "types": "./dist/zenstack/schema-lite.d.mts",
      "import": "./dist/zenstack/schema-lite.mjs",
      "default": "./dist/zenstack/schema-lite.mjs"
    },
    "./slices": {
      "types": "./dist/slices.d.mts",
      "import": "./dist/slices.mjs",
      "default": "./dist/slices.mjs"
    },
    "./models": {
      "types": "./dist/zenstack/models.d.mts",
      "import": "./dist/zenstack/models.mjs",
      "default": "./dist/zenstack/models.mjs"
    },
    "./zod": {
      "types": "./dist/zod.d.mts",
      "import": "./dist/zod.mjs",
      "default": "./dist/zod.mjs"
    }
  },
  "scripts": {
    "build": "pnpm generate && tsdown",
    "type-check": "tsgo --noEmit",
    "generate": "zen generate --lite",
    "zen:watch": "zen generate --watch",
    "db:pull": "zen db pull",
    "db:push": "zen db push",
    "migrate:dev": "zen migrate dev",
    "migrate:deploy": "zen migrate deploy",
    "clean": "rm -rf dist",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && oxfmt --write ."
  },
  "dependencies": {
    "@zenstackhq/language": "^3.7.1",
    "@zenstackhq/orm": "^3.7.1",
    "@zenstackhq/plugin-policy": "^3.7.1",
    "@zenstackhq/schema": "^3.7.1",
    "@zenstackhq/server": "^3.7.1",
    "@zenstackhq/tanstack-query": "^3.7.1",
    "@zenstackhq/zod": "^3.7.1",
    "hono": "^4.12.22",
    "kysely": "^0.29.2",
    "pg": "8.21.0",
    "pg-types": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@zenstackhq/cli": "^3.7.1",
    "@zenstackhq/sdk": "^3.7.1",
    "react": "^19.2.6",
    "ts-morph": "^28.0.0",
    "ts-pattern": "^5.9.0",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=26",
    "npm": ">=10.0.0"
  }
}
