{
  "name": "@finanzas/orpc-contracts",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "default": "./dist/auth.js"
    },
    "./calendar": {
      "types": "./dist/calendar.d.ts",
      "import": "./dist/calendar.js",
      "default": "./dist/calendar.js"
    },
    "./dte-event-links": {
      "types": "./dist/dte-event-links.d.ts",
      "import": "./dist/dte-event-links.js",
      "default": "./dist/dte-event-links.js"
    },
    "./dte-analytics": {
      "types": "./dist/dte-analytics.d.ts",
      "import": "./dist/dte-analytics.js",
      "default": "./dist/dte-analytics.js"
    },
    "./finance": {
      "types": "./dist/finance.d.ts",
      "import": "./dist/finance.js",
      "default": "./dist/finance.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "import": "./dist/settings.js",
      "default": "./dist/settings.js"
    },
    "./system": {
      "types": "./dist/system.d.ts",
      "import": "./dist/system.js",
      "default": "./dist/system.js"
    },
    "./users": {
      "types": "./dist/users.d.ts",
      "import": "./dist/users.js",
      "default": "./dist/users.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "oxlint --type-aware --type-check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && oxfmt --write .",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
