{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "api: type-check",
      "type": "shell",
      "command": "pnpm --filter @finanzas/api type-check",
      "group": "test",
      "problemMatcher": "$tsc"
    },
    {
      "label": "api: type-check watch",
      "type": "shell",
      "command": "pnpm --filter @finanzas/api type-check:watch",
      "isBackground": true,
      "group": "test",
      "problemMatcher": "$tsc-watch",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
