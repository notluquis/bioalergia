{
  "name": "finanzas-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "mail:start": "node scripts/mail-agent.mjs start",
    "mail:status": "node scripts/mail-agent.mjs status",
    "mail:stop": "node scripts/mail-agent.mjs stop",
    "mail:logs": "node scripts/mail-agent.mjs logs",
    "build": "turbo run build --continue=never",
    "test": "turbo run test --continue=never",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "lint:ci:sarif": "oxlint --format=sarif --reporter-file=./reports/oxlint.sarif",
    "type-check": "turbo run type-check --continue=never",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm lint && pnpm type-check",
    "check:fix": "oxlint --fix && oxfmt",
    "check:full": "pnpm check && pnpm test && pnpm build",
    "ci:check": "oxlint --format=github",
    "ci": "pnpm lint:ci && pnpm type-check && pnpm test && pnpm build",
    "audit:dead": "knip --no-progress",
    "audit:dead:advisory": "knip --no-progress --no-exit-code",
    "audit:dead:strict": "knip --no-progress",
    "audit:all": "pnpm -F @finanzas/intranet audit:design && pnpm audit:dead && pnpm -F @finanzas/intranet build && pnpm -F @finanzas/intranet audit:size && pnpm -F @finanzas/intranet audit:e2e && pnpm -F @finanzas/intranet audit:perf",
    "clean": "pnpm -r --if-present clean",
    "devtools": "turbo devtools",
    "prepare": "husky || true"
  },
  "dependencies": {
    "isomorphic-dompurify": "^3.12.0",
    "papaparse": "^5.5.3",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260508.1",
    "@zenstackhq/cli": "^3.6.4",
    "@zenstackhq/sdk": "^3.6.4",
    "husky": "^9.1.7",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.9.12"
  },
  "engines": {
    "node": ">=26",
    "npm": ">=10.0.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "impit",
      "msw"
    ],
    "overrides": {
      "playwright": "1.60.0"
    }
  }
}
