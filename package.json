{
  "name": "finanzas-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "mail:start": "node scripts/mail-agent.mjs start",
    "mail:status": "node scripts/mail-agent.mjs status",
    "mail:stop": "node scripts/mail-agent.mjs stop",
    "mail:logs": "node scripts/mail-agent.mjs logs",
    "build": "turbo run build --continue=never",
    "test": "turbo run test --continue=never",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "lint:ci:sarif": "oxlint --format=sarif --reporter-file=./reports/oxlint.sarif",
    "type-check": "turbo run type-check --continue=never",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm lint && pnpm type-check",
    "check:fix": "oxlint --fix && oxfmt",
    "check:full": "pnpm check && pnpm test && pnpm build",
    "ci:check": "oxlint --format=github",
    "ci": "pnpm lint:ci && pnpm type-check && pnpm test && pnpm build",
    "clean": "pnpm -r --if-present clean",
    "devtools": "turbo devtools",
    "prepare": "husky || true"
  },
  "dependencies": {
    "isomorphic-dompurify": "^3.7.1",
    "papaparse": "^5.5.3",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260408.1",
    "@zenstackhq/cli": "^3.5.6",
    "@zenstackhq/sdk": "^3.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "turbo": "^2.9.5"
  },
  "engines": {
    "node": ">=25",
    "npm": ">=10.0.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "baileys",
      "esbuild",
      "msw"
    ]
  }
}
