{
  "name": "finanzas-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "mail:start": "node scripts/mail-agent.mjs start",
    "mail:status": "node scripts/mail-agent.mjs status",
    "mail:stop": "node scripts/mail-agent.mjs stop",
    "mail:logs": "node scripts/mail-agent.mjs logs",
    "build": "turbo run build --continue=never",
    "test": "turbo run test --continue=never",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "lint:ci:sarif": "oxlint --format=sarif --reporter-file=./reports/oxlint.sarif",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm lint",
    "check:fix": "oxlint --fix && oxfmt",
    "check:full": "pnpm check && pnpm test && pnpm build",
    "ci:check": "oxlint --format=github",
    "ci": "pnpm lint:ci && pnpm test && pnpm build",
    "clean": "pnpm -r --if-present clean",
    "tmp:type-aware:intranet": "cd apps/intranet && OXC_LOG=debug pnpm exec oxlint --type-aware src shared",
    "tmp:type-check:intranet": "cd apps/intranet && pnpm exec tsc -b --pretty false",
    "devtools": "turbo devtools",
    "prepare": "husky || true"
  },
  "dependencies": {
    "isomorphic-dompurify": "3.5.1",
    "papaparse": "^5.5.3",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@zenstackhq/cli": "3.4.6",
    "@zenstackhq/sdk": "3.4.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "turbo": "^2.8.20"
  },
  "engines": {
    "node": ">=25",
    "npm": ">=10.0.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "core-js",
      "msw",
      "protobufjs"
    ]
  }
}
