{
  "name": "finanzas-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "mail:start": "node scripts/mail-agent.mjs start",
    "mail:status": "node scripts/mail-agent.mjs status",
    "mail:stop": "node scripts/mail-agent.mjs stop",
    "mail:logs": "node scripts/mail-agent.mjs logs",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:ci": "oxlint --format=github",
    "lint:ci:sarif": "oxlint --format=sarif --reporter-file=./reports/oxlint.sarif",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm lint && pnpm type-check",
    "check:fix": "oxlint --fix && oxfmt",
    "check:full": "pnpm check && pnpm test && pnpm build",
    "ci:check": "oxlint --format=github",
    "ci": "pnpm lint:ci && pnpm type-check && pnpm test && pnpm build",
    "clean": "pnpm -r --if-present clean",
    "type-check": "turbo run type-check --continue=never",
    "devtools": "turbo devtools",
    "prepare": "husky || true"
  },
  "dependencies": {
    "isomorphic-dompurify": "3.3.0",
    "papaparse": "^5.5.3",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@zenstackhq/cli": "3.4.6",
    "@zenstackhq/sdk": "3.4.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "turbo": "^2.8.17"
  },
  "engines": {
    "node": ">=25.3.0",
    "pnpm": ">=10.28.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "core-js", "msw", "protobufjs"]
  }
}
