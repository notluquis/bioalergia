# 🔧 Variables de Entorno - Bioalergia
# Plantilla combinada (raíz). Copia a .env y completa con tus valores reales.
#
# Esta es una guía rápida con lo más común. La lista COMPLETA y autoritativa
# vive en cada app:
#   - API (Hono):      apps/api/.env.example       (~140 vars)
#   - Intranet (Vite): apps/intranet/.env.example
# Nunca subas el .env real ni secretos al repositorio.

# 🌐 Configuración del Servidor (API)
# La API arranca en :3000 por defecto (apps/api/src/index.ts).
PORT=3000

# 🗄️ Base de Datos PostgreSQL (Railway)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/bioalergia"

# 🔐 Seguridad y Autenticación
# Genera con: openssl rand -hex 32
JWT_SECRET=changeme

# 📢 Notificaciones Push (VAPID)
# Generar con: npx web-push generate-vapid-keys
# El public key es el MISMO valor en API e intranet.
VITE_VAPID_PUBLIC_KEY=changeme
VAPID_PRIVATE_KEY=changeme

# 🚀 Producción y Build
NODE_ENV=development
# Proxy de dev de Vite hacia la API (apps/intranet/vite.config.ts usa
# VITE_API_PROXY_TARGET ?? VITE_API_URL, default http://127.0.0.1:4000).
# Apúntalo a la API local (:3000).
VITE_API_PROXY_TARGET="http://127.0.0.1:3000"
VITE_API_URL="http://127.0.0.1:3000"
# VITE_APP_BUILD_TIMESTAMP se genera automáticamente al compilar.

# 💳 MercadoPago
MERCADOPAGO_ACCESS_TOKEN=changeme
MERCADOPAGO_WEBHOOK_SECRET=changeme

# 📥 IMAP Doctoralia (lectura de OTP / interstitials por email)
DOCTORALIA_IMAP_HOST=
DOCTORALIA_IMAP_USER=
DOCTORALIA_IMAP_PASS=changeme
DOCTORALIA_IMAP_MAILBOX=INBOX
DOCTORALIA_EMAIL_SENDER_FILTER=doctoralia.com

# 🤖 Doctoralia Scraper (app apps/doctoralia-scraper)
DOCTORALIA_SCRAPER_BASE_URL="https://docplanner.doctoralia.cl"
DOCTORALIA_SCRAPER_EMAIL=
DOCTORALIA_SCRAPER_PASSWORD=changeme
DOCTORALIA_SCRAPER_IMPORT_ENDPOINT="http://localhost:3000/api/scraper/doctoralia/calendar/import"
# Bearer compartido entre el bot y la API para leer/guardar cookies en la DB.
# Genéralo con: openssl rand -hex 32 (el mismo valor en el .env del bot y de la API).
DOCTORALIA_SCRAPER_API_TOKEN=changeme
# Dejá DOCTORALIA_SCRAPER_IMPORT_TOKEN vacío para reutilizar DOCTORALIA_SCRAPER_API_TOKEN.
DOCTORALIA_SCRAPER_IMPORT_TOKEN=
DOCTORALIA_SCRAPER_COOKIES_ENDPOINT="http://localhost:3000/api/scraper/doctoralia/cookies"
# Headers obligatorios del API /api/calendarevents (inspeccionar DevTools una vez por cuenta).
DOCTORALIA_SCRAPER_ONE_USER_ID=
DOCTORALIA_SCRAPER_USER_TYPE=secretary
DOCTORALIA_SCRAPER_COUNTRY_ID=CL
# Fallback si no podemos scrapear x-one-front-version desde el shell SPA.
DOCTORALIA_SCRAPER_FRONT_VERSION=
# Ventana semanal: buildWindows(anchor, windowDays, windowsPerRun)
DOCTORALIA_SCRAPER_WINDOW_DAYS=7
DOCTORALIA_SCRAPER_WINDOWS_PER_RUN=8

# 📝 Notas de Seguridad:
# - Nunca subas el archivo .env al repositorio.
# - Usa contraseñas seguras en producción.
# - Genera secrets con: openssl rand -hex 32
