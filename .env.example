# 🔧 Variables de Entorno - Finanzas App
# Copia este archivo a .env y completa con tus valores reales

# 🌐 Configuración del Servidor
PORT=4000

# 🗄️ Base de Datos PostgreSQL (Railway)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:tu_password@containers-us-west-XX.railway.app:6543/railway"

# Para desarrollo local con PostgreSQL:
# DATABASE_URL="postgresql://localhost:5432/finanzas_dev"

# 🔐 Seguridad y Autenticación
JWT_SECRET=genera_un_secret_aleatorio_de_64_caracteres_minimo

# 📢 Notificaciones Push (VAPID)
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=tu_clave_publica_aqui
VAPID_PRIVATE_KEY=tu_clave_privada_aqui

# 🚀 Producción y Build
NODE_ENV=development
VITE_API_URL="http://localhost:4000"
# VITE_APP_BUILD_TIMESTAMP se genera automáticamente al compilar

# 💳 MercadoPago
MP_ACCESS_TOKEN=tu_mp_access_token
MP_WEBHOOK_PASSWORD=tu_webhook_secret
ENABLE_MP_AUTO_SYNC=false
MP_AUTO_SYNC_CRON="*/20 * * * *"
MP_AUTO_SYNC_TIMEZONE="America/Santiago"

# 💬 WhatsApp Cloud API
ENABLE_WHATSAPP_NOTIFICATIONS=false
WHATSAPP_ACCESS_TOKEN=tu_system_user_access_token
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US
# Opcional: mensaje libre usado cuando ya existe una ventana activa de 24h.
# Placeholders disponibles: {{patientName}}, {{appointmentDate}}, {{appointmentService}},
# {{appointmentDoctor}}, {{clinicAddress}}
WHATSAPP_FREEFORM_MESSAGE=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu_verify_token
WHATSAPP_APP_SECRET=tu_meta_app_secret
WHATSAPP_POLL_CRON="*/2 * * * *"
WHATSAPP_POLL_TIMEZONE="America/Santiago"

# 📥 IMAP Doctoralia
DOCTORALIA_IMAP_HOST=
DOCTORALIA_IMAP_PORT=993
DOCTORALIA_IMAP_USER=
DOCTORALIA_IMAP_PASS=
DOCTORALIA_IMAP_MAILBOX=INBOX
DOCTORALIA_IMAP_SECURE=1
DOCTORALIA_EMAIL_SENDER_FILTER=doctoralia.com

# 📝 Notas de Seguridad:
# - Nunca subas el archivo .env al repositorio
# - Usa contraseñas seguras en producción
# - Genera JWT_SECRET con: openssl rand -hex 32
