{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "outDir": "dist",
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
