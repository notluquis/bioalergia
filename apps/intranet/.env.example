# Intranet (Vite) environment template.
# Copy to .env (gitignored) and fill values for local dev.

# Build metadata — usually injected by CI, fine to leave blank locally.
VITE_APP_BUILD_ID=
VITE_APP_BUILD_TIMESTAMP=

# Local mail agent endpoint (optional).
VITE_LOCAL_MAIL_AGENT_URL=

# Sentry DSN.
# Leave EMPTY for dev / preview / unauthed CI — Sentry stays a no-op.
# Only fill in production AFTER signing the Sentry Business + BAA.
# Never commit a real DSN.
VITE_SENTRY_DSN=
