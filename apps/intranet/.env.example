# Intranet (Vite) environment template.
# Copy to .env (gitignored) and fill values for local dev.
# All VITE_* vars are inlined into the client bundle at build time — never put
# secrets here (only public keys / config). NEVER commit a real DSN.

# Build metadata — usually injected by CI, fine to leave blank locally.
VITE_APP_BUILD_ID=
VITE_APP_BUILD_TIMESTAMP=

# Sentry DSN (public). Leave EMPTY for dev / preview / unauthed CI — Sentry
# stays a no-op. Only fill in production AFTER signing the Sentry Business + BAA.
VITE_SENTRY_DSN=

# Web-push public key (VAPID). SAME value as the api's VITE_VAPID_PUBLIC_KEY.
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Meta / WhatsApp Embedded Signup (Facebook Login for Business).
# App id + config id from the Meta app dashboard — both public.
VITE_META_APP_ID=
VITE_META_EMBEDDED_SIGNUP_CONFIG_ID=
