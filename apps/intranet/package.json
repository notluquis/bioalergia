{
  "name": "@finanzas/intranet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "VITE_REACT_COMPILER=false vite",
    "dev:compiler": "VITE_REACT_COMPILER=true vite",
    "build": "NODE_ENV=production vite build",
    "build:fast": "VITE_REACT_COMPILER=true vite build",
    "build:fast:compiler": "VITE_REACT_COMPILER=true vite build",
    "build:fast:no-compiler": "VITE_REACT_COMPILER=false vite build",
    "build:profile": "vite build --profile",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "IS_CHROMATIC=true chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-once-uploaded",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "type-check": "node ./scripts/generate-routes.mjs && tsgo --noEmit",
    "lint:type-aware": "oxlint --type-check-only src shared",
    "lint:heroui-composition": "node ./scripts/check-heroui-composition.mjs",
    "audit:validations": "node ./scripts/audit-validations.mjs",
    "audit:design": "node ./scripts/audit-design-tokens.mjs",
    "audit:css": "stylelint \"src/**/*.css\"",
    "audit:size": "size-limit",
    "audit:size:why": "size-limit --why",
    "audit:e2e": "playwright test",
    "audit:e2e:ui": "playwright test --ui",
    "audit:a11y": "playwright test a11y.spec.ts",
    "audit:perf": "lhci autorun --config=./lighthouserc.json",
    "audit:perf:mobile": "lhci autorun --config=./lighthouserc.mobile.json",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest --project=unit",
    "test:storybook": "vitest --project=storybook",
    "test:coverage": "vitest --project=unit --coverage --run",
    "test:mutation": "stryker run",
    "test:mutation:since": "stryker run --incremental --since=main",
    "clean": "rm -rf dist",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@casl/react": "^7.0.0",
    "@finanzas/db": "workspace:*",
    "@finanzas/orpc-client": "workspace:*",
    "@finanzas/orpc-contracts": "workspace:*",
    "@finanzas/theme": "workspace:*",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@internationalized/date": "^3.12.2",
    "@orpc/client": "^1.14.4",
    "@orpc/contract": "^1.14.4",
    "@orpc/tanstack-query": "^1.14.4",
    "@sentry/react": "^10.56.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.11",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "@zenstackhq/language": "^3.7.2",
    "@zenstackhq/orm": "^3.7.2",
    "@zenstackhq/plugin-policy": "^3.7.2",
    "@zenstackhq/schema": "^3.7.2",
    "@zenstackhq/server": "^3.7.2",
    "@zenstackhq/tanstack-query": "^3.7.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.4.8",
    "frimousse": "^0.3.0",
    "i18next": "^26.3.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "ky": "^2.0.2",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^5.5.7",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@dotenvx/dotenvx": "^1.71.0",
