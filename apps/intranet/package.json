    "@storybook/addon-coverage": "^3.0.1",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/addon-vitest": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-generator": "1.167.13",
    "@tanstack/router-plugin": "^1.168.14",
    "@tanstack/store": "^0.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^17.2.0",
    "concurrently": "^10.0.3",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "pino-pretty": "^13.1.3",
    "postcss-preset-env": "^11.3.0",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.2",
    "storybook-addon-tag-badges": "^3.1.0",
    "stylelint": "^17.12.0",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-plugin-rhythmguard": "^2.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.14.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "@internationalized/date": "3.11.0",
    "hono": "^4.12.1",
    "jspdf": "$jspdf"
  },
  "engines": {
    "node": ">=26",
    "npm": ">=10.0.0"
  }
}
