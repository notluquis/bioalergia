{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/lib/**/*.ts",
    "!src/lib/**/*.test.{ts,tsx}",
    "!src/lib/__tests__/**",
    "!src/lib/**/*.d.ts",
    "!src/lib/sentry.ts",
    "!src/lib/**/types.ts"
  ],
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "concurrency": "50%",
  "ignoreStatic": true,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "ignorePatterns": [
    "dist",
    "dist-storybook",
    "storybook-static",
    "playwright-report",
    "test-results",
    "coverage",
    "node_modules"
  ],
  "reporters": ["html", "clear-text", "progress"]
}
