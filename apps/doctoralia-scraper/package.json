{
  "name": "@finanzas/doctoralia-scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "discover": "tsx src/index.ts --discover",
    "start": "node --import tsx src/index.ts",
    "build": "node -e \"console.log('@finanzas/doctoralia-scraper uses the tsx runtime in production; no JS bundle is emitted during build.')\"",
    "lint": "oxlint",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "impit": "^0.14.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=25"
  }
}
