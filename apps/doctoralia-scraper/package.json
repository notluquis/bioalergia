{
  "name": "@finanzas/doctoralia-scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "scrape": "node src/index.ts",
    "discover": "node src/index.ts --discover",
    "start": "node src/index.ts",
    "build": "node -e \"console.log('@finanzas/doctoralia-scraper runs TypeScript natively via Node.js (>=25.2); no JS bundle is emitted during build.')\"",
    "lint": "oxlint",
    "type-check": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "imapflow": "^1.4.2",
    "impit": "^0.14.2",
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26"
  }
}
