{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/doctoralia-scraper/Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "NEVER",
    "watchPatterns": [
      "apps/doctoralia-scraper/**",
      "package.json",
      "turbo.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml"
    ]
  }
}
