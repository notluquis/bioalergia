{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node"],

    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/db" },
    { "path": "../../packages/orpc-contracts" }
  ]
}
