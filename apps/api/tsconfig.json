{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "incremental": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "noEmit": true,
    "types": ["node"],

    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noImplicitOverride": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/utils/**", "src/lib/**", "src/modules/**", "src/services/**"],
  "references": [
    { "path": "../../packages/orpc-contracts" },
    { "path": "./src/utils" },
    { "path": "./src/lib" },
    { "path": "./src/modules" },
    { "path": "./src/services" }
  ]
}
