{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "../../.tsbuildinfo/api.tsbuildinfo",
    "outDir": "dist",
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
