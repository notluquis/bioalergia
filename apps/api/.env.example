# =============================================================================
# API (Hono) environment template — Bioalergia
# Copy to .env (gitignored) and fill values for local dev.
# NEVER commit real secrets. Placeholders below are safe (changeme / empty).
# [required] = app crashes / feature dead without it. [optional] = has default
# or only needed for a specific feature.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime / server
# -----------------------------------------------------------------------------
NODE_ENV=development          # [optional] development | production
PORT=3000                    # [optional] HTTP port (default 3000)
TZ=America/Santiago          # [required on Railway] graphile-worker cron uses process TZ
APP_URL=http://localhost:3000        # [optional] absolute base URL of this api
PUBLIC_URL=http://localhost:3000     # [optional] public-facing base URL
ORIGIN=http://localhost:5173         # [optional] expected request origin (WebAuthn / CORS)
CORS_ORIGIN=http://localhost:5173    # [optional] allowed CORS origin(s)
DOMAIN_WHITELIST=                    # [optional] comma-separated extra allowed domains

# -----------------------------------------------------------------------------
# Database (PostgreSQL — Railway)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/bioalergia  # [required]

# -----------------------------------------------------------------------------
# Auth / secrets
# -----------------------------------------------------------------------------
JWT_SECRET=changeme                  # [required] PASETO/JWT signing — openssl rand -hex 32
AUDIT_HMAC_KEY=changeme              # [required] HMAC for tamper-evident audit log
PROVIDER_CREDENTIAL_KEY=changeme     # [required] AES key for stored provider credentials
# WebAuthn / passkeys (intranet)
RP_ID=localhost                      # [optional] relying-party id (defaults to host)
RP_NAME=Bioalergia                   # [optional] relying-party display name
# WebAuthn / passkeys (storefront / shop)
SHOP_ORIGIN=http://localhost:5174    # [optional] shop expected origin
SHOP_RP_ID=localhost                 # [optional]
SHOP_RP_NAME=Bioalergia Shop         # [optional]

# -----------------------------------------------------------------------------
# Push notifications (VAPID / web-push)
# -----------------------------------------------------------------------------
# Generate both with: npx web-push generate-vapid-keys
# Public key is the SAME value the intranet ships (VITE_VAPID_PUBLIC_KEY there).
VITE_VAPID_PUBLIC_KEY=changeme       # [optional] read server-side by web-push
VAPID_PRIVATE_KEY=changeme           # [optional]

# -----------------------------------------------------------------------------
# WhatsApp (Cloud API / Meta) secret encryption
# -----------------------------------------------------------------------------
WA_SECRET_KEY=changeme               # [required for WA] active AES key for WA token cipher
WA_SECRET_KEYS_OLD=                  # [optional] comma-separated old keys for rotation/decrypt
WA_SEED_ROLES=                       # [optional] roles seeded with WA access

# -----------------------------------------------------------------------------
# Google (OAuth + Calendar + service account + Places)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=changeme              # [optional]
GOOGLE_OAUTH_CLIENT_SECRET=changeme          # [optional]
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback  # [optional]
GOOGLE_OAUTH_REFRESH_TOKEN=                  # [optional]
GOOGLE_SERVICE_ACCOUNT_EMAIL=                # [optional] backup / calendar service acct
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=          # [optional] PEM (escape newlines as \n)
GOOGLE_BACKUP_FOLDER_ID=                     # [optional] Drive folder for backups
GOOGLE_PLACES_API_KEY=                       # [optional]
# Calendar sync
ENABLE_CALENDAR_SYNC=false                   # [optional]
GOOGLE_CALENDAR_IDS=                          # [optional] comma-separated calendar ids
GOOGLE_CALENDAR_TIMEZONE=America/Santiago     # [optional]
GOOGLE_CALENDAR_SYNC_START=                   # [optional] ISO start date
GOOGLE_CALENDAR_SYNC_LOOKAHEAD_DAYS=          # [optional]
GOOGLE_CALENDAR_WEBHOOK_URL=                  # [optional] push-notification channel URL

# -----------------------------------------------------------------------------
# Microsoft OAuth (OneDrive / IMAP device-code)
# -----------------------------------------------------------------------------
MICROSOFT_OAUTH_CLIENT_ID=changeme           # [optional]
MICROSOFT_OAUTH_CLIENT_SECRET=changeme       # [optional]
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/microsoft/oauth/callback  # [optional]
ONEDRIVE_WEBHOOK_URL=                         # [optional]
ONEDRIVE_ARCHIVE_CONCURRENCY=                 # [optional] numeric, default in code

# -----------------------------------------------------------------------------
# ICD-11 (WHO API — diagnoses)
# -----------------------------------------------------------------------------
ICD_API_CLIENT_ID=changeme                   # [optional]
ICD_API_CLIENT_SECRET=changeme               # [optional]

# -----------------------------------------------------------------------------
# Haulmer / DTE (electronic invoicing) + signing cert
# -----------------------------------------------------------------------------
HAULMER_API_BASE=https://...                 # [optional] Haulmer API base URL
HAULMER_EMAIL=changeme                        # [optional]
HAULMER_PASSWORD=changeme                     # [optional]
HAULMER_RUT=changeme                          # [optional]
HAULMER_RESOURCE_ID=                          # [optional]
HAULMER_WORKSPACE_ID=                         # [optional]
# Signing certificate (provide ONE of PFX_BASE64 or PFX_PATH)
PFX_BASE64=                                   # [optional] base64-encoded .pfx
PFX_PATH=                                     # [optional] path to .pfx on disk
PFX_PASSWORD=changeme                         # [optional] cert password
# DTE reembolso multi-date bundling
DTE_REEMBOLSO_MULTI_DATE_BUNDLE_ENABLED=false # [optional]
DTE_REEMBOLSO_MULTI_DATE_WINDOW_DAYS=         # [optional] numeric

# -----------------------------------------------------------------------------
# MercadoPago (payments)
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=changeme            # [optional] primary access token
MERCADOPAGO_WEBHOOK_SECRET=changeme          # [optional] webhook signature secret
MP_ACCESS_TOKEN=changeme                     # [optional] legacy access token name
MP_WEBHOOK_PASSWORD=changeme                 # [optional] legacy webhook secret

# -----------------------------------------------------------------------------
# MercadoLibre (listings sync)
# -----------------------------------------------------------------------------
ML_CLIENT_ID=changeme                        # [optional]
ML_CLIENT_SECRET=changeme                    # [optional]
ML_REDIRECT_URI=http://localhost:3000/api/mercadolibre/oauth/callback  # [optional]
ML_LISTING_TYPE_ID=                          # [optional]

# -----------------------------------------------------------------------------
# Chilexpress (shipping)
# -----------------------------------------------------------------------------
CHILEXPRESS_API_KEY_COVERAGE=changeme        # [optional]
CHILEXPRESS_API_KEY_RATING=changeme          # [optional]
CHILEXPRESS_API_KEY_ORDERS=changeme          # [optional]
CHILEXPRESS_COMPANY_RUT=                      # [optional]
CHILEXPRESS_ORIGIN_COVERAGE_CODE=             # [optional]
CHILEXPRESS_TCC=                              # [optional]
CHILEXPRESS_SANDBOX=true                      # [optional]

# -----------------------------------------------------------------------------
# Medipass (payments / co-pay)
# -----------------------------------------------------------------------------
MEDIPASS_API_KEY=changeme                    # [optional]
MEDIPASS_ID_EMPRESA=                          # [optional]

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage — product images, non-PHI)
# -----------------------------------------------------------------------------
CF_R2_ACCOUNT_ID=changeme                    # [optional]
CF_R2_ACCESS_KEY=changeme                    # [optional]
CF_R2_SECRET=changeme                        # [optional]
CF_R2_BUCKET=changeme                        # [optional]
CF_R2_PUBLIC_BASE_URL=https://...            # [optional] public CDN base URL

# -----------------------------------------------------------------------------
# Email / Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY=changeme                      # [optional]
RESEND_WEBHOOK_SECRET=changeme               # [optional]

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
# Leave EMPTY for dev / preview / unauthed CI — Sentry stays a no-op
# (init() is gated by `if (dsn)` in src/instrument.ts).
# Only fill in production AFTER signing the Sentry Business + BAA.
SENTRY_DSN=                                   # [optional]

# -----------------------------------------------------------------------------
# Queue (graphile-worker) + scheduled jobs
# -----------------------------------------------------------------------------
DISABLE_QUEUE_RUNNER=                         # [optional] true = disable in-process queue
DB_ORPHAN_CLEANUP=                            # [optional] 1 = run cleanup (else dry-run)
DB_SEQUENCE_AUTO_REPAIR=                      # [optional] 1 = auto-repair PG sequences
OUTREACH_DRAIN_BATCH=10                       # [optional] outreach auto-drain batch size
OUTREACH_SEED_ROLES=                          # [optional] roles seeded with outreach access
QUOTES_SEED_ROLES=                            # [optional] roles seeded with quotes access

# -----------------------------------------------------------------------------
# Skin-test / clinical-record import pipeline
# -----------------------------------------------------------------------------
ENABLE_SKIN_TEST_IMPORT_SYNC=false            # [optional]
SKIN_TEST_IMPORT_SYNC_CRON=                   # [optional] cron expr
SKIN_TEST_IMPORT_SYNC_CONCURRENCY=            # [optional] numeric
SKIN_TEST_ARCHIVE_CONCURRENCY=                # [optional] numeric
CLINICAL_RECORD_REPROCESS_CONCURRENCY=        # [optional] numeric
BIOALERGIA_UPSERT_CHUNK_SIZE=                 # [optional] numeric

# -----------------------------------------------------------------------------
# Doctoralia (calendar sync + IMAP + scraper)
# -----------------------------------------------------------------------------
ENABLE_DOCTORALIA_CALENDAR_SYNC=false         # [optional]
ENABLE_DOCTORALIA_IMAP=false                  # [optional]
DOCTORALIA_CALENDAR_USERNAME=                 # [optional]
DOCTORALIA_CALENDAR_PASSWORD=changeme         # [optional]
DOCTORALIA_CALENDAR_SYNC_CRON=                # [optional]
DOCTORALIA_CALENDAR_MIN_SYNC_INTERVAL_MS=     # [optional] numeric
DOCTORALIA_CALENDAR_APPOINTMENTS_REFRESH_MS=  # [optional] numeric
DOCTORALIA_CALENDAR_ACCEPT_LANGUAGE=          # [optional]
DOCTORALIA_CALENDAR_USER_AGENT=               # [optional]
DOCTORALIA_CALENDAR_AUTH_BASE_URL=https://... # [optional]
DOCTORALIA_CALENDAR_AUTH_BOOTSTRAP_PATH=      # [optional]
DOCTORALIA_CALENDAR_DOCPLANNER_BASE_URL=https://...  # [optional]
DOCTORALIA_CALENDAR_LOGIN_PATH=               # [optional]
DOCTORALIA_CALENDAR_FIXTURE=                  # [optional] path to fixture for tests
# IMAP (OTP / interstitial email reading)
DOCTORALIA_IMAP_HOST=                         # [optional]
DOCTORALIA_IMAP_USER=                         # [optional]
DOCTORALIA_IMAP_PASS=changeme                 # [optional]
DOCTORALIA_IMAP_MAILBOX=INBOX                 # [optional]
DOCTORALIA_EMAIL_SENDER_FILTER=doctoralia.com # [optional]
# Scraper bridge (shared bearer with the doctoralia-scraper app)
DOCTORALIA_SCRAPER_API_TOKEN=changeme         # [optional] openssl rand -hex 32
DOCTORALIA_SCRAPER_COOKIES_LABEL=             # [optional]
DOCTORALIA_BACKFILL_WEEK_DELAY_MS=            # [optional] numeric

# -----------------------------------------------------------------------------
# Job Radar (personal job-offer scraper + Telegram alerts)
# -----------------------------------------------------------------------------
ENABLE_JOB_RADAR=false                        # [optional]
JOB_RADAR_CRON=                               # [optional]
JOB_RADAR_KEYWORDS=                           # [optional] comma-separated
JOB_RADAR_DEPARTMENTS=                        # [optional] comma-separated
JOB_RADAR_GETONBRD=                           # [optional]
JOB_RADAR_BCI=                                # [optional]
JOB_RADAR_MUEVETE=                            # [optional]
JOB_RADAR_EMPLEOSPUBLICOS=                    # [optional]
TELEGRAM_BOT_TOKEN=changeme                   # [optional] shared with Job Radar alerts
TELEGRAM_CHAT_ID=                             # [optional]

# -----------------------------------------------------------------------------
# External data enrichment APIs (optional integrations)
# -----------------------------------------------------------------------------
APOLLO_API_KEY=changeme                       # [optional]
HUNTER_API_KEY=changeme                       # [optional]
CMF_API_KEY=changeme                          # [optional] CMF Chile (UF/financial data)

# -----------------------------------------------------------------------------
# Ghostscript (PDF post-processing)
# -----------------------------------------------------------------------------
GHOSTSCRIPT_BIN=                              # [optional] path to gs binary (autodetect if empty)

# -----------------------------------------------------------------------------
# Reservation / storefront
# -----------------------------------------------------------------------------
RESERVATION_TTL_MIN=                          # [optional] numeric (cart reservation TTL)
STOREFRONT_BASE_URL=http://localhost:5174     # [optional]
VERIFY_BASE_URL=http://localhost:3000         # [optional] prescription verification base URL

# -----------------------------------------------------------------------------
# Railway deploy hooks / metadata (set automatically on Railway; local = empty)
# -----------------------------------------------------------------------------
RAILWAY_API_TOKEN=                            # [optional]
RAILWAY_API_GRAPHQL_ENDPOINT=                 # [optional]
RAILWAY_PROJECT_TOKEN=                        # [optional]
RAILWAY_ENVIRONMENT_ID=                       # [optional] injected by Railway
RAILWAY_SERVICE_ID=                           # [optional] injected by Railway
RAILWAY_PUBLIC_DOMAIN=                        # [optional] injected by Railway
RAILWAY_GIT_COMMIT_SHA=                       # [optional] injected by Railway
RAILWAY_DEPLOY_API_ENVIRONMENT_ID=            # [optional] self-deploy trigger target
RAILWAY_DEPLOY_API_SERVICE_ID=                # [optional]
RAILWAY_DEPLOY_API_LABEL=                     # [optional]
RAILWAY_DEPLOY_INTRANET_ENVIRONMENT_ID=       # [optional]
RAILWAY_DEPLOY_INTRANET_SERVICE_ID=           # [optional]
RAILWAY_DEPLOY_INTRANET_LABEL=                # [optional]
RAILWAY_DEPLOY_ENVIRONMENT_ID=                # [optional]

# -----------------------------------------------------------------------------
# Debug helpers (local diagnostics only — never set in prod)
# -----------------------------------------------------------------------------
ENABLE_DEBUG_TOKENS=                          # [optional]
DEBUG_BASE_URL=                               # [optional]
DEBUG_LOGIN_EMAIL=                            # [optional]
DEBUG_LOGIN_PASSWORD=                         # [optional]
DEBUG_LOGIN_TOTP_TOKEN=                       # [optional]
DEBUG_SESSION_COOKIE=                         # [optional]
DEBUG_SESSION_COOKIE_FILE=                    # [optional]
