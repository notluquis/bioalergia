{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "../../dist/modules",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "incremental": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["**/__tests__/**"],
  "references": [
    { "path": "../../../../packages/db" },
    { "path": "../../../../packages/orpc-contracts" },
    { "path": "../lib" },
    { "path": "../utils" }
  ]
}
