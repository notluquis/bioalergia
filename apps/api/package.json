{
  "name": "@finanzas/api",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "src",
    "assets",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node -e \"console.log('@finanzas/api uses the tsx runtime in production; no JS bundle is emitted during build.')\"",
    "start": "node --import tsx src/index.ts",
    "type-check": "tsgo --noEmit --pretty false",
    "type-check:watch": "tsgo --watch --pretty false",
    "google:auth": "tsx src/scripts/google-auth.ts",
    "doctoralia:diagnose-login": "tsx src/scripts/diagnose-doctoralia-login.ts",
    "doctoralia:import-history": "tsx src/scripts/import-doctoralia-history.ts",
    "debug:intranet-request": "tsx src/scripts/debug-intranet-request.ts",
    "debug:mp-download": "tsx src/scripts/debug-intranet-request.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm lint",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@finanzas/db": "workspace:*",
    "@finanzas/orpc-contracts": "workspace:*",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/drive": "^20.1.0",
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "@orpc/client": "^1.13.13",
    "@orpc/openapi": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/zod": "^1.13.13",
    "@otplib/plugin-base32-scure": "^13.4.0",
    "@otplib/plugin-crypto-node": "^13.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@zenstackhq/language": "^3.5.4",
    "@zenstackhq/orm": "^3.5.4",
    "@zenstackhq/plugin-policy": "^3.5.4",
    "@zenstackhq/schema": "^3.5.4",
    "@zenstackhq/server": "^3.5.4",
    "@zenstackhq/tanstack-query": "^3.5.4",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "decimal.js": "^10.6.0",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.10",
    "hono-rate-limiter": "^0.5.3",
    "imapflow": "^1.2.18",
    "isomorphic-dompurify": "^3.7.1",
    "kysely": "^0.28.15",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "otplib": "^13.4.0",
    "papaparse": "^5.5.3",
    "parse5": "^8.0.0",
    "paseto": "^3.1.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "qs": "^6.15.0",
    "superjson": "^2.2.6",
