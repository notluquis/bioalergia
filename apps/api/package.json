{
  "name": "@finanzas/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node -e \"console.log('@finanzas/api uses the tsx runtime in production; no JS bundle is emitted during build.')\"",
    "start": "node --import tsx src/index.ts",
    "google:auth": "tsx src/scripts/google-auth.ts",
    "doctoralia:diagnose-login": "tsx src/scripts/diagnose-doctoralia-login.ts",
    "type-check": "oxlint src scripts",
    "type-check:lint": "oxlint --type-aware src scripts",
    "type-check:ts": "tsc -b --pretty false",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "pnpm type-check && pnpm type-check:lint && pnpm type-check:ts",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@finanzas/db": "workspace:*",
    "@finanzas/orpc-contracts": "workspace:*",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/drive": "^20.1.0",
    "@hono/node-server": "1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@orpc/client": "^1.13.9",
    "@orpc/openapi": "^1.13.9",
    "@orpc/server": "^1.13.9",
    "@orpc/zod": "^1.13.9",
    "@otplib/plugin-base32-scure": "^13.4.0",
    "@otplib/plugin-crypto-node": "^13.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@zenstackhq/language": "3.4.6",
    "@zenstackhq/orm": "3.4.6",
    "@zenstackhq/plugin-policy": "3.4.6",
    "@zenstackhq/schema": "3.4.6",
    "@zenstackhq/server": "3.4.6",
    "@zenstackhq/tanstack-query": "3.4.6",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "decimal.js": "^10.6.0",
    "gaxios": "^7.1.4",
    "google-auth-library": "^10.6.2",
    "hono": "4.12.8",
    "hono-rate-limiter": "^0.5.3",
    "imapflow": "1.2.16",
    "isomorphic-dompurify": "3.5.1",
    "kysely": "^0.28.13",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.3",
    "otplib": "^13.4.0",
    "papaparse": "^5.5.3",
    "paseto": "^3.1.4",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "qs": "^6.15.0",
    "superjson": "^2.2.6",
    "tsx": "^4.21.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.0",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=25",
    "npm": ">=10.0.0"
  }
}
