# PostHog Analytics Configuration
# Get your API key from: https://app.posthog.com/settings/events
# Using US data residency (appropriate for Chile)
VITE_PUBLIC_POSTHOG_KEY=your_posthog_api_key_here
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Chromatic visual regression (Storybook)
# Token per Chromatic project (1 token = 1 project bucket — site has its own,
# separate from intranet). CI uses GH secret CHROMATIC_PROJECT_TOKEN_SITE.
CHROMATIC_PROJECT_TOKEN=chpt_xxxxxxxxxxxxxxx

# Shop config (canonical URL for JSON-LD + low-stock badge threshold)
VITE_STOREFRONT_URL=https://bioalergia.cl
VITE_LOW_STOCK_THRESHOLD=3
