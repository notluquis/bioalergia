# Global options — see apps/intranet/Caddyfile for rationale.
{
	servers {
		protocols h1 h2
	}
	admin off
}

:{$PORT:3000} {
	# Root directory for static files
	root * /srv

	# Automatic compression (gzip, zstd, brotli)
	encode zstd gzip

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		# Force HTTPS for a year incl. subdomains (matches intranet/Caddyfile).
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

		# CSP — ENFORCING (promovido desde Report-Only tras consola limpia, golden
		# 2026 / web.dev retrofit method). Report-Only sin `report-to` no protegía
		# ni reportaba (solo spam de consola: "policy will have no effect" +
		# "frame-ancestors ignored in report-only"); enforcing sí protege y calla
		# ambos warnings. Las violaciones reportadas (widget certificado Doctoralia,
		# beacon doubleclick) ya están en el allowlist de abajo.
		#
		# OJO revenue-critical: este site embebe terceros de pago (MercadoPago Brick
		# checkout, Google Ads gtag inline, PostHog, widget Doctoralia). Si falta un
		# origen, enforcing lo ROMPE en silencio. MercadoPago no publica CSP oficial:
		# validar el checkout en vivo (network panel) tras cada deploy. Si algo se
		# cae, volver a `Content-Security-Policy-Report-Only` mientras se ajusta.
		#
		# 'unsafe-inline' in script-src/style-src is required here and cannot be
		# dropped without nonce infra: index.html has an inline gtag init block,
		# product pages inject dynamic <script type="application/ld+json">, and
		# Tailwind/MP inject inline styles. Source allowlist is the protection.
		#
		# Origins by purpose:
		#   MercadoPago Brick:  sdk.mercadopago.com, *.mercadopago.com (iframes +
		#     www/.../security.js fingerprint — frame-src *.mercadopago.com is the
		#     one MP-staff-confirmed directive), *.mlstatic.com (shared CDN),
		#     api.mercadopago.com (connect). MP publishes no official CSP doc —
		#     validate against the live checkout network panel before enforcing.
		#   Google Ads gtag:    www.googletagmanager.com, www.google.com,
		#     www.googleadservices.com, googleads.g.doubleclick.net,
		#     *.google-analytics.com (conversion beacons). connect-src
		#     *.doubleclick.net cubre el collect de conversión gtag
		#     (ad.doubleclick.net/ccm/s/collect, googleads/td subdominios).
		#   PostHog (us cloud):  *.i.posthog.com (ingest us.i + assets us-assets).
		#   Doctoralia:          platform.docplanner.com (widget de reserva) +
		#     widgets.doctoralia.cl (frame del widget de certificado en la home).
		#   Fonts:               fonts.googleapis.com (css) + fonts.gstatic.com.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://sdk.mercadopago.com https://*.mercadopago.com https://*.mlstatic.com https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://googleads.g.doubleclick.net https://*.i.posthog.com https://platform.docplanner.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.mercadopago.com https://*.mercadopago.com https://*.mlstatic.com https://*.i.posthog.com https://*.google-analytics.com https://www.googletagmanager.com https://www.google.com https://www.googleadservices.com https://*.doubleclick.net https://platform.docplanner.com; frame-src 'self' https://*.mercadopago.com https://platform.docplanner.com https://www.doctoralia.cl https://widgets.doctoralia.cl https://td.doubleclick.net https://www.google.com; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
	}

	# Allow embedding public brand assets (signature + clinic logo) from
	# external origins. CORP defaults to same-origin above, which blocks
	# cross-origin <img> reads: the intranet (intranet.bioalergia.cl) renders
	# the clinic logo from ClinicSettings.logoUrl (= this origin) and webmail/
	# email clients embed the signature. These are public, non-sensitive brand
	# images meant to be embeddable, so they opt into cross-origin CORP.
	@brand path /firma-lucas-signature.png /logo_sin_eslogan.png /logo_bioalergia_eslogan.svg /logo.png
	header @brand {
		Access-Control-Allow-Origin "*"
		Cross-Origin-Resource-Policy "cross-origin"
	}

	# ========== LOGGING CONFIGURATION ==========
	# Skip health checks and favicon (high-frequency, low-value logs)
	# These go to HTTP Logs in Railway but generate noise
	log_skip /health
	log_skip /favicon.ico

	# Skip static assets (js, css, images, fonts)
	# These are already cached and don't need to be logged
	@assets path_regexp \.(js|css|png|jpe?g|gif|svg|ico|woff|woff2|ttf|eot|webp)$
	log_skip @assets

	# Health check endpoint
	handle /health {
		respond "OK" 200
	}

	# API proxy to backend — same pattern as intranet/Caddyfile.
	# MUST use internal/direct origin (Railway private domain) to avoid
	# CDN loop. Set in Railway: API_INTERNAL_ORIGIN=https://<api-internal>
	# Same-origin proxying lets the SPA share httpOnly cart cookies + CSRF
	# tokens without CORS.
	handle /api/* {
		reverse_proxy {$API_INTERNAL_ORIGIN} {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
		}
	}

	# Google Merchant Center feed — served by api, but Google likes it
	# on the primary domain alongside the products it indexes.
	handle /feed/* {
		reverse_proxy {$API_INTERNAL_ORIGIN} {
			header_up Host {upstream_hostport}
			header_up X-Real-IP {remote_host}
		}
	}

	# SPA routing: try files, fallback to index.html
	handle {
		try_files {path} /index.html
		file_server
	}

	# Cache headers for static assets
	@static {
		path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.webp *.ico *.woff *.woff2 *.ttf *.eot
	}
	header @static {
		Cache-Control "public, max-age=2592000, immutable"
	}

	# No cache for index.html
	@html {
		path /index.html
	}
	header @html {
		Cache-Control "no-store"
	}

	# Structured JSON logging for Railway HTTP Logs
	# Filters unnecessary headers to reduce log size by ~70-80%
	log {
		output stdout
		format filter {
			# Request headers: filter non-critical information
			request>headers>Accept delete
			request>headers>Accept-Language delete
			request>headers>Accept-Encoding delete
			request>headers>Priority delete
			request>headers>Sec-Fetch-Dest delete
			request>headers>Sec-Fetch-Mode delete
			request>headers>Sec-Fetch-Site delete

			# Cloudflare geolocation headers (not essential for debugging)
			request>headers>Cf-Iplatitude delete
			request>headers>Cf-Iplongitude delete
			request>headers>Cf-Postal-Code delete
			request>headers>Cf-Ipcity delete
			request>headers>Cf-Ipcontinent delete
			request>headers>Cf-Ipcountry delete
			request>headers>Cf-Region delete
			request>headers>Cf-Region-Code delete
			request>headers>Cf-Timezone delete
			request>headers>Cf-Visitor delete

			# Cloudflare certificate validation headers
			request>headers>Cf-Cert-Presented delete
			request>headers>Cf-Cert-Revoked delete
			request>headers>Cf-Cert-Verified delete

			# Railway edge headers (X-Railway-Request-Id is kept in response)
			request>headers>X-Railway-Edge delete

			# Response headers: remove CDN/proxy noise
			resp_headers>Cf-Ray delete
			resp_headers>Cf-Cache-Status delete
			resp_headers>Nel delete
			resp_headers>Report-To delete
			resp_headers>Speculation-Rules delete
			resp_headers>Server delete

			wrap json
		}
	}
}
