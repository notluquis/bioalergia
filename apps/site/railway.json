{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/site/Dockerfile"
  },
  "deploy": {
    "watchPatterns": [
      "apps/site/**",
      "package.json",
      "turbo.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml"
    ]
  }
}
