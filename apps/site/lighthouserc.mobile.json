{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/servicios",
        "http://localhost:4173/examenes",
        "http://localhost:4173/inmunoterapia",
        "http://localhost:4173/botiquin",
        "http://localhost:4173/polen",
        "http://localhost:4173/aprende",
        "http://localhost:4173/equipo",
        "http://localhost:4173/eres-alergico",
        "http://localhost:4173/compromiso-social",
        "http://localhost:4173/noticias",
        "http://localhost:4173/tienda"
      ],
      "startServerCommand": "pnpm -F @finanzas/site preview --port 4173 --strictPort",
      "startServerReadyPattern": "Local:\\s+http",
      "startServerReadyTimeout": 180000,
      "numberOfRuns": 1,
      "settings": {
        "//": "No preset → Lighthouse default = mobile emulation (Moto G) + throttling.",
        "chromeFlags": "--no-sandbox --headless=new",
        "skipAudits": [
          "uses-http2",
          "is-on-https",
          "redirects-http",
          "uses-long-cache-ttl",
          "service-worker",
          "errors-in-console",
          "inspector-issues",
          "csp-xss"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": "off",
        "categories:pwa": "off",
        "largest-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "interactive": ["warn", { "maxNumericValue": 7000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 600 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 3000 }],
        "speed-index": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
