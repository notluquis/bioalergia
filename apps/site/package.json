{
  "name": "@finanzas/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "build": "pnpm sitemap && vite build",
    "build:fast": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-once-uploaded",
    "lint": "oxlint",
    "type-check": "tsgo --noEmit",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest --project=unit --passWithNoTests",
    "test:storybook": "vitest --project=storybook",
    "test:coverage": "vitest --project=unit --coverage --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:e2e": "playwright test",
    "audit:a11y": "playwright test a11y.spec.ts",
    "audit:perf": "lhci autorun --config=./lighthouserc.json",
    "audit:perf:mobile": "lhci autorun --config=./lighthouserc.mobile.json",
    "audit:css": "stylelint \"src/**/*.css\"",
    "audit:size": "size-limit",
    "audit:size:why": "size-limit --why",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@finanzas/orpc-client": "workspace:*",
    "@finanzas/orpc-contracts": "workspace:*",
    "@finanzas/theme": "workspace:*",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@mercadopago/sdk-react": "^1.0.7",
    "@orpc/client": "^1.14.6",
    "@orpc/contract": "^1.14.6",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/router-vite-plugin": "^1.167.18",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.393.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superjson": "^2.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.6.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.6",
    "storybook-addon-tag-badges": "^3.1.0",
    "stylelint": "^17.13.0",
    "stylelint-plugin-defensive-css": "^2.9.3",
    "stylelint-plugin-rhythmguard": "^2.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26",
    "npm": ">=10.0.0"
  }
}
