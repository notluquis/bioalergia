{
  "name": "@finanzas/site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:fast": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN --exit-once-uploaded",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@heroui/react": "3.0.0-beta.8",
    "@heroui/styles": "3.0.0-beta.8",
    "@tanstack/react-query": "^5.90.21",
    "posthog-js": "1.360.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-themes": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chromatic": "^15.3.0",
    "msw": "^2.12.13",
    "msw-storybook-addon": "^2.0.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.2.19",
    "storybook-addon-tag-badges": "^3.0.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "8.0.0",
    "vitest": "^4.1.0"
  }
}
