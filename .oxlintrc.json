{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "vitest", "promise", "node", "unicorn"],
  "jsPlugins": ["oxlint-tailwindcss"],
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "settings": {
    "import/resolver": {
      "typescript": true
    },
    "tailwindcss": {
      "entryPoint": [
        "apps/intranet/src/index.css",
        "apps/site/src/index.css"
      ]
    }
  },
  "rules": {
    // ESM Import Extensions (Golden Standard 2026, post Node 26 + native TS)
    // Rule: { "js": "always", "ts": "always", "ignorePackages": true }
    //
    // Node 26 runs TypeScript natively via type stripping; like all Node
    // ESM it has no loader-style fallback for extensionless relative
    // specifiers. So both `.ts` and `.js` must be written explicitly.
    //
    // Examples:
    // ✅ import { foo } from "./foo.ts";                   // server source
    // ✅ import timezone from "dayjs/plugin/timezone.js";  // package subpath
    // ✅ import { z } from "zod";                          // bare specifier
    // ❌ import { foo } from "./foo";                      // ERR_MODULE_NOT_FOUND
    //
    // Reference: https://nodejs.org/api/typescript.html
    "react/only-export-components": ["warn", { "allowConstantExport": true }],
    "import/extensions": ["error", { "js": "always", "ts": "always", "ignorePackages": true }],
    "typescript/no-floating-promises": "error",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-explicit-any": "error",
    // Non-null assertions (`x!`) lie to TypeScript about nullability and
    // turn what should be a compile error into a runtime crash. Prod
    // bug `null is not an object (evaluating 'v.comuna')` traced to
    // `selected!.comuna` where the upstream `?? null` made the var
    // genuinely nullable. Use early returns, `??` defaults, or
    // `invariant()` instead. Suppress with line-level disable + a
    // comment explaining why narrowing TS can't see is correct here.
    "typescript/no-non-null-assertion": "error",
    // ── Type-aware rules (require `oxlint --type-aware`, gated on CI) ──
    // Each catches a class of bug we have hit in production.
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-unsafe-argument": "warn",
    "typescript/no-unsafe-return": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/restrict-template-expressions": "error",
    "typescript/no-base-to-string": "error",
    "typescript/require-array-sort-compare": "error",
    "typescript/prefer-promise-reject-errors": "error",
    "typescript/switch-exhaustiveness-check": "error",
    "promise/no-return-wrap": "error",
    "unicorn/no-array-callback-reference": "warn",
    // Tailwind CSS v4 (oxlint-tailwindcss) — conservative subset:
    // catch real bugs without churn. Shorthand is `warn`, not `error`,
    // so it doesn't block CI. Note: no rule exists for missing
    // `min-w-0` on `flex-1` children (not in the 23-rule plugin set).
    "tailwindcss/no-conflicting-classes": "error",
    "tailwindcss/no-duplicate-classes": "error",
    "tailwindcss/enforce-shorthand": "warn"
  },
  "ignorePatterns": [
    "**/dist",
    "**/.turbo",
    "**/node_modules",
    "**/public/mockServiceWorker.js",
    "**/routeTree.gen.ts"
  ],
  "overrides": [
    {
      "files": [
        "**/context/**",
        "**/lib/authz/**",
        "**/*Columns.tsx",
        "**/main.tsx",
        // TanStack Router file-based routes always export both `Route` and a
        // route component from the same file. Fast-refresh boundary doesn't
        // apply since route files are graph entry points, not hot-reloaded
        // leaves.
        "**/src/routes/**",
        // Shared UI primitives that combine an exported component (host) +
        // imperative helpers in a single module. Splitting them is gratuitous
        // file churn for a fast-refresh win that doesn't matter on shared
        // modules.
        "**/components/ui/ConfirmDialog.tsx",
        "**/wa-cloud/components/_shared.tsx"
      ],
      "rules": {
        "react/only-export-components": "off"
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}", "**/__tests__/**"],
      "rules": {
        "vitest/require-to-throw-message": "off",
        "no-constant-binary-expression": "off",
        // vitest mocks (`.mockResolvedValue`, `.mockReturnValue`) live on
        // `any` by design (vi.fn() returns Mock<any>). Type-aware unsafe-*
        // rules fire on every call site without surfacing a real bug —
        // the alternative (typed mock factories per test) is huge churn
        // for zero runtime safety win. Keep enforcement on src.
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/no-unsafe-assignment": "off",
        // Test fixtures legitimately drill into known-shape mock data
        // (e.g. `mock.calls[0]![0]`); the explicit narrowing is noise
        // when the very next line asserts the value. Source files keep
        // enforcement.
        "typescript/no-non-null-assertion": "off"
      }
    },
    {
      "files": ["**/*.stories.*"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": [
        "**/*.d.ts",
        "**/vite.config.*",
        "**/vitest.config.*",
        "**/lint-staged.config.*",
        "**/.storybook/**/*"
      ],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["packages/db/src/zenstack/schema.ts", "packages/db/src/zenstack/schema-lite.ts"],
      "rules": {}
    },
    {
      "files": ["apps/api/src/config.ts", "apps/api/src/lib/mercadopago/mercadopago-scheduler.ts"],
      "rules": {}
    },
    {
      "files": [
        "apps/intranet/src/features/finance/mercadopago/components/SettlementReleaseColumns.tsx"
      ],
      "rules": {}
    },
    {
      "files": ["packages/db/src/client.ts", "packages/db/src/input.ts"],
      "rules": {}
    }
  ]
}
